#!/opt/bin/sh
# Detour / Keenetic — zapret tpws (DPI-bypass transparent proxy) Entware service.
# tpws reads its CLI args from /opt/etc/zapret-tpws.conf (one shell var: ARGS=...).
# ⚠ VALIDATE the conf format matches the OpenWrt one and tpws binds 0.0.0.0:$ZAPRET_PORT.

export PATH="/opt/bin:/opt/sbin:/usr/bin:/usr/sbin:/bin:/sbin"  # Entware tools live in /opt
. /opt/etc/detour/detour.conf 2>/dev/null

PIDF="/opt/var/run/detour-zapret.pid"
MARK="/opt/etc/detour/zapret.enabled"        # running indicator (gates the fw hook)
AUTOSTART="/opt/etc/detour/autostart.zapret" # «Автозапуск» flag (1|0); absent = on
HOOK="/opt/etc/ndm/netfilter.d/50-detour.sh"
DNS_SVC="/opt/etc/init.d/S50detour-dns"
NAME="tpws-zapret"

apply_fw() { [ -x "$HOOK" ] && "$HOOK" iptables nat >/dev/null 2>&1; }
dns_up()   { [ -x "$DNS_SVC" ] && "$DNS_SVC" start  >/dev/null 2>&1; }
dns_reload() { [ -x "$DNS_SVC" ] && "$DNS_SVC" reload >/dev/null 2>&1; }
dns_down_if_idle() {
    [ -f /opt/etc/detour/singbox.enabled ] && return
    [ -x "$DNS_SVC" ] && "$DNS_SVC" stop >/dev/null 2>&1
}

start() {
    [ -x "$TPWS_BIN" ] || { echo "$NAME: missing $TPWS_BIN"; exit 1; }
    # shellcheck disable=SC1090
    ARGS=""
    [ -f "$TPWS_CONF" ] && . "$TPWS_CONF" 2>/dev/null
    mkdir -p /opt/var/run /opt/var/log
    touch "$MARK"
    echo "Starting $NAME ..."
    # Capture tpws stdout/stderr to a log file (parity with S52detour-singbox): it
    # feeds the panel's log viewer AND the syslog log-bridge (S91detour-logbridge),
    # which tails this file. Truncate on each start so it can't grow unbounded.
    ZLOG=/opt/var/log/zapret-tpws.log
    : > "$ZLOG"
    # tpws runs transparent on $ZAPRET_PORT; --user nobody to drop privileges.
    start-stop-daemon -S -q -b -m -p "$PIDF" \
        -x "$TPWS_BIN" -- --bind-addr=0.0.0.0 --port="$ZAPRET_PORT" --user=nobody $ARGS \
        >>"$ZLOG" 2>&1
    sleep 1
    dns_up          # ensure zapret_domains ipset is populated via the detour dnsmasq
    apply_fw
}

stop() {
    echo "Stopping $NAME ..."
    rm -f "$MARK"
    start-stop-daemon -K -q -p "$PIDF" 2>/dev/null
    rm -f "$PIDF"
    apply_fw
    dns_down_if_idle
}

# reload: re-read the zapret domain list into the ipset (no tpws restart needed).
reload() { dns_reload; apply_fw; }

status() {
    if [ -f "$PIDF" ] && kill -0 "$(cat "$PIDF")" 2>/dev/null; then
        echo "$NAME running (pid $(cat "$PIDF"))"
    else
        echo "$NAME stopped"
    fi
}

# «Автозапуск» (autostart): rc.unslung boot-starts every executable S* with `start`,
# so the boot path honours the panel flag; manual start (panel ▶) uses `force-start`
# to start regardless. enable/disable only flip the durable flag — they no longer
# start/stop (parity with the OpenWrt panel, where «Автозапуск» is independent of the
# running state). The flag lives under /opt/etc/detour, so a service the operator
# turned off stays off across reinstalls and reboots.
set_autostart() { mkdir -p "$(dirname "$AUTOSTART")" 2>/dev/null; echo "$1" > "$AUTOSTART"; }
case "$1" in
    start)
        [ "$(cat "$AUTOSTART" 2>/dev/null)" = "0" ] && { echo "$NAME: autostart disabled"; exit 0; }
        start ;;
    force-start) start ;;
    enable)  set_autostart 1 ;;
    disable) set_autostart 0 ;;
    stop)    stop ;;
    restart) stop; sleep 1; start ;;
    reload)  reload ;;
    status)  status ;;
    *) echo "usage: $0 {start|force-start|stop|restart|reload|enable|disable|status}"; exit 1 ;;
esac
