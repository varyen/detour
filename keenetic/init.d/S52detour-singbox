#!/opt/bin/sh
# Detour / Keenetic — sing-box (Trojan transparent proxy) Entware service.
# Entware's rc.unslung runs /opt/etc/init.d/S* on boot. No procd here.
# Enable-marker gates the netfilter.d hook so the nat REDIRECT rules survive
# NDM firewall rebuilds. ⚠ VALIDATE the daemon stays up under start-stop-daemon.

export PATH="/opt/bin:/opt/sbin:/usr/bin:/usr/sbin:/bin:/sbin"  # Entware tools live in /opt
. /opt/etc/detour/detour.conf 2>/dev/null

PIDF="/opt/var/run/detour-singbox.pid"
MARK="/opt/etc/detour/singbox.enabled"        # running indicator (gates the fw hook)
AUTOSTART="/opt/etc/detour/autostart.singbox" # «Автозапуск» flag (1|0); absent = on
HOOK="/opt/etc/ndm/netfilter.d/50-detour.sh"
DNS_SVC="/opt/etc/init.d/S50detour-dns"
NAME="sing-box"

apply_fw() { [ -x "$HOOK" ] && "$HOOK" iptables nat >/dev/null 2>&1; }
# Domain→ipset DNS: run while EITHER proxy is enabled; stop when both are off.
dns_up()   { [ -x "$DNS_SVC" ] && "$DNS_SVC" start  >/dev/null 2>&1; }
dns_reload() { [ -x "$DNS_SVC" ] && "$DNS_SVC" reload >/dev/null 2>&1; }
dns_down_if_idle() {
    [ -f /opt/etc/detour/zapret.enabled ] && return
    [ -x "$DNS_SVC" ] && "$DNS_SVC" stop >/dev/null 2>&1
}

start() {
    [ -x "$SINGBOX_BIN" ] || { echo "$NAME: missing $SINGBOX_BIN"; exit 1; }
    [ -f "$SINGBOX_CONF" ] || { echo "$NAME: missing $SINGBOX_CONF"; exit 1; }
    mkdir -p /opt/var/run "$(dirname "$SINGBOX_LOG")"
    # Truncate-on-start (parity with the OpenWrt init's `> $LOG`): keeps the
    # persistent /opt/var/log sing-box log bounded per session. Truncate-in-place
    # (not rename) so detour-logbridge's `tail -f` survives it. The daemon redirect
    # below + sing-box's own log.output re-fill it from empty.
    : > "$SINGBOX_LOG"
    touch "$MARK"
    echo "Starting $NAME ..."
    # -b background, -m make pidfile, -d chdir for relative config paths.
    start-stop-daemon -S -q -b -m -p "$PIDF" \
        -d /opt/etc/sing-box \
        -x "$SINGBOX_BIN" -- run -c "$SINGBOX_CONF" >>"$SINGBOX_LOG" 2>&1
    sleep 1
    dns_up          # ensure ipset/dnsmasq is up + regenerated for domain routing
    apply_fw
}

stop() {
    echo "Stopping $NAME ..."
    rm -f "$MARK"
    start-stop-daemon -K -q -p "$PIDF" 2>/dev/null
    rm -f "$PIDF"
    # Drop our nat rules by re-running the hook (it skips disabled svc).
    apply_fw
    dns_down_if_idle
}

# reload: re-read domain lists into the ipsets (no daemon restart needed).
reload() { dns_reload; apply_fw; }

status() {
    if [ -f "$PIDF" ] && kill -0 "$(cat "$PIDF")" 2>/dev/null; then
        echo "$NAME running (pid $(cat "$PIDF"))"
    else
        echo "$NAME stopped"
    fi
}

# «Автозапуск» (autostart): rc.unslung boot-starts every executable S* with `start`,
# so the boot path honours the panel flag; manual start (panel ▶) uses `force-start`
# to start regardless. enable/disable only flip the durable flag — they no longer
# start/stop (parity with the OpenWrt panel, where «Автозапуск» is independent of the
# running state). The flag lives under /opt/etc/detour, so a service the operator
# turned off stays off across reinstalls and reboots.
set_autostart() { mkdir -p "$(dirname "$AUTOSTART")" 2>/dev/null; echo "$1" > "$AUTOSTART"; }
case "$1" in
    start)
        [ "$(cat "$AUTOSTART" 2>/dev/null)" = "0" ] && { echo "$NAME: autostart disabled"; exit 0; }
        start ;;
    force-start) start ;;
    enable)  set_autostart 1 ;;
    disable) set_autostart 0 ;;
    stop)    stop ;;
    restart|reconfigure)
        # Reconfigure, NOT a teardown: bounce only the daemon and KEEP the enabled
        # marker so the REDIRECT rules — and the detour DNS server — stay up the
        # whole time. The brief gap then fails CLOSED (LAN hits :12345 and is
        # refused, never routed direct). DNS is reloaded GRACEFULLY (dns_reload =
        # regen + SIGHUP), never restarted: a DNS-server restart here stalls all
        # LAN/router name resolution for seconds and freezes both this panel and
        # the native KeeneticOS panel. Only `stop` (manual «Выкл») clears the
        # marker and allows direct traffic. ⚠ VALIDATE on device.
        start-stop-daemon -K -q -p "$PIDF" 2>/dev/null
        rm -f "$PIDF"
        sleep 1
        start
        dns_reload ;;
    reload)  reload ;;
    status)  status ;;
    *) echo "usage: $0 {start|force-start|stop|restart|reconfigure|reload|enable|disable|status}"; exit 1 ;;
esac
