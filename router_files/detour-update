    upstream=$(gh_latest_tag "$NFQWS2_UPSTREAM_REPO") || upstream=$(prev_field "$NFQWS2_STATE_FILE" upstream)
    upnew=false
    [ -n "$upstream" ] && version_gt "$upstream" "${cur%-*}" && upnew=true
    write_nfqws2_state "$cur" "$avail" "$upstream" "$upnew"
    if [ "$cur" != "$avail" ]; then
        log "nfqws2 update available (feed): $cur -> $avail"
    elif [ "$upnew" = true ]; then
        log "nfqws2: newer upstream on GitHub ${cur%-*} -> $upstream (not in feed yet)"
    else
        log "nfqws2 up to date ($cur)"
    fi
}

cmd_nfqws2_apply() {
    [ "$KEENETIC" = 1 ] && die "zapret2 (nfqws2) is not supported on Keenetic (no NFQUEUE)"
    [ -e "$LOCKFILE" ] && die "another apply in progress ($LOCKFILE)"
    : > "$LOCKFILE"
    trap 'rm -f "$LOCKFILE"' EXIT INT TERM
    ensure_feed
    log "opkg update + upgrade nfqws2 from the feed..."
    opkg_update_retry || log "WARNING: opkg update не удался после 4 попыток — ставлю из кэша индекса (новая версия может быть уже скачана)"
    if opkg list-installed "$NFQWS2_PKG" 2>/dev/null | grep -q "^$NFQWS2_PKG "; then
        # `opkg upgrade` no-ops if already newest; fall back to a forced install.
        opkg upgrade "$NFQWS2_PKG" 2>&1 \
            || opkg install --force-overwrite "$NFQWS2_PKG" 2>&1 \
            || die "opkg upgrade nfqws2 failed"
    else
        opkg install --force-overwrite "$NFQWS2_PKG" 2>&1 \
            || die "opkg install nfqws2 failed"
    fi
    cmd_nfqws2_check >/dev/null 2>&1 || true
    log "nfqws2 now at $(nfqws2_installed_version)"
}

# check-all — one cron tick: panel + all three feed binaries. Each runs in a
# subshell so a failure (feed unreachable, gh_assets `exit 1`, `die`) isolates to
# that component and never aborts the rest. The 6h auto-check cron calls this so
# the panel can light up any stale version chip from the written state files.
cmd_check_all() {
    ( cmd_check )        || log "check-all: panel check failed"
    ( cmd_bins_check )   || log "check-all: sing-box check failed"
    ( cmd_tpws_check )   || log "check-all: tpws check failed"
    ( cmd_nfqws2_check ) || log "check-all: nfqws2 check failed"
    return 0
}

cmd_apply() {
    [ -e "$LOCKFILE" ] && die "another apply in progress ($LOCKFILE)"
    : > "$LOCKFILE"
    trap 'rm -f "$LOCKFILE"' EXIT INT TERM

    local assets tag ipk_url sig_url newver cur
    log "fetching latest release info..."
    assets=$(gh_assets) || exit 1
    tag=$(printf '%s\n' "$assets" | sed -n 1p)
    ipk_url=$(select_url "$assets" "$ASSET_RE")
    sig_url=$(select_url "$assets" "$ASSET_SIG_RE")
    [ -n "$ipk_url" ] || { rm -f "$LOCKFILE"; die "no panel .ipk asset on $tag"; }
    [ -n "$sig_url" ] || { rm -f "$LOCKFILE"; die "no panel .ipk.sig asset on $tag"; }
    newver="${tag#v}"
    cur=$(current_version)
    log "current=$cur target=$newver"

    if ! version_gt "$newver" "$cur" && [ "$newver" = "$cur" ]; then
        log "already on $cur — refusing downgrade/same install"
        write_state "up_to_date" "v$cur is already installed" "$newver"
        return 0
    fi

    # Publish an intermediate state so the panel's poller shows progress AND any
    # stale "applied" from a previous run is cleared — so the next "applied" is
    # unambiguously from THIS install.
    write_state "installing" "устанавливается v$newver…" "$newver"

    local tmp ipk sig
    tmp=$(mktemp -d)
    ipk="$tmp/${PACKAGE_NAME}_${newver}_${ARCH}.ipk"
    sig="$ipk.sig"
    log "downloading $ipk_url ..."
    gh_curl_retry -fsSL --max-time 600 \
        -H "Accept: application/octet-stream" \
        -o "$ipk" "$ipk_url" || { rm -rf "$tmp"; die "ipk download failed"; }
    gh_curl_retry -fsSL --max-time 60 \
        -H "Accept: application/octet-stream" \
        -o "$sig" "$sig_url" || { rm -rf "$tmp"; die "sig download failed"; }

    # The panel `Depends: sing-box, tpws-zapret` — make sure the feed is
    # configured and both are present so opkg resolves the deps at install time.
    ensure_singbox
    ensure_tpws

    # Subshell: an inner `die` (usign/opkg failure) exits only the subshell, so the
    # `if !` catches it and we publish an "error" state for the poller — otherwise
    # die's `exit 1` would kill the worker mid-install and leave a stale state.
    if ! ( verify_and_install_ipk "$ipk" "$sig" ); then
        rm -rf "$tmp"
        write_state "error" "install failed for v$newver" "$newver"
        exit 1
    fi
    rm -rf "$tmp"
    write_state "applied" "installed v$newver via opkg" "$newver"
    log "installed v$newver successfully"
    # Keenetic only: refresh the sing-box chip state with THIS (just-installed) updater
    # so a fixed detour-bins.json replaces the stale one an older buggy bins-check left
    # (current=0.0.0 → chip pinned amber). Skipped on OpenWrt where the chip is already
    # correct — the extra opkg update + GitHub probe would only slow the apply down for
    # no gain. Both platforms now run the apply DETACHED, so timeouts aren't a concern.
    # Cheap + non-fatal.
    if [ "$KEENETIC" = 1 ]; then cmd_bins_check >/dev/null 2>&1 || true; fi
    return 0   # never let the trailing refresh flip cmd_apply's success status
}

cmd_apply_local() {
    local ipk="$1"
    [ -n "$ipk" ] || die "usage: apply-local <ipk-file>"
    local sig="$ipk.sig"
    # Local panel install still needs sing-box + tpws-zapret present for the Depends.
    ensure_singbox
    ensure_tpws
    write_state "installing" "устанавливается из файла…" "$(current_version)"
    # Subshell so an inner `die` becomes a catchable failure (see cmd_apply).
    if ! ( verify_and_install_ipk "$ipk" "$sig" ); then
        write_state "error" "установка из файла не удалась" "$(current_version)"
        exit 1
    fi
    local cur
    cur=$(current_version)
    write_state "applied" "installed v$cur via local ipk" "$cur"
    # Keenetic only: refresh the sing-box chip state (see cmd_apply for the rationale).
    if [ "$KEENETIC" = 1 ]; then cmd_bins_check >/dev/null 2>&1 || true; fi
    return 0   # never let the trailing refresh flip cmd_apply_local's success status
}

cmd_rollback() {
    [ -d "$BACKUP_DIR" ] || die "no backups in $BACKUP_DIR"
    # Pick the most recent backup that is NOT the currently-installed version.
    local cur best
    cur=$(current_version)
    best=$(ls -1t "$BACKUP_DIR"/${PACKAGE_NAME}_*.ipk 2>/dev/null \
        | grep -v "_${cur}\.ipk$" | head -1)
    [ -n "$best" ] || die "no rollback candidate (only $cur is backed up)"
    log "rolling back to: $best"
    # Backups don't have sig files alongside — TOFU the install (we already
    # verified them at the time they were stored).
    opkg install --force-reinstall "$best" || die "opkg install failed"
    local newver
    newver=$(echo "$best" | sed -n "s|.*${PACKAGE_NAME}_\(.*\)\.ipk|\1|p")
    log "rolled back to $newver"
    write_state "rolled_back" "rolled back to v$newver" "$newver"
}

cmd_status() {
    if [ -f "$STATE_FILE" ]; then cat "$STATE_FILE"
    else echo '{"status":"unknown","message":"no state file yet"}'
    fi
}

cmd_selftest() {
    local ok=1
    if ! command -v usign >/dev/null 2>&1; then echo "MISSING: usign"; ok=0; fi
    if ! command -v opkg >/dev/null 2>&1; then echo "MISSING: opkg"; ok=0; fi
    if ! command -v curl >/dev/null 2>&1; then echo "MISSING: curl"; ok=0; fi
    if ! command -v lua  >/dev/null 2>&1; then echo "MISSING: lua";  ok=0; fi
    if ! lua -e 'require("cjson.safe")' 2>/dev/null; then
        echo "MISSING: lua-cjson"; ok=0
    fi
    if [ -d "$OPKG_KEYRING" ] && ls -1 "$OPKG_KEYRING" 2>/dev/null | head -1 >/dev/null; then
        echo "OK: keyring $OPKG_KEYRING populated"
    elif [ -f "$PUBLIC_KEY" ]; then
        echo "OK: pinned key at $PUBLIC_KEY"
    else
        echo "MISSING: no public key for verification"; ok=0
    fi
    [ -f "$CONFIG" ] || { echo "MISSING: $CONFIG"; ok=0; }
    [ "$ok" = "1" ] && { echo "selftest: OK"; return 0; }
    echo "selftest: FAILED"
    return 1
}

# Persist KEY=VALUE into $CONFIG (create if missing, replace any existing line).
set_conf_flag() {
    local key="$1" val="$2" tmp
    mkdir -p "$(dirname "$CONFIG")"
    [ -f "$CONFIG" ] || : > "$CONFIG"
    tmp="$CONFIG.tmp.$$"
    grep -v "^${key}=" "$CONFIG" > "$tmp" 2>/dev/null
    echo "${key}=${val}" >> "$tmp"
    mv "$tmp" "$CONFIG"
    chmod 0600 "$CONFIG" 2>/dev/null
}

# Source of truth for "is autocheck on". On OpenWrt that's the installed cron line;
# on Keenetic there is NO crond (the firmware kills its job shell — S90detour-cron
# runs the schedule instead), so the AUTO_CHECK flag in update.conf is canonical,
# re-read live from disk (the cron daemon honors the same flag each cycle).
autocheck_enabled() {
    if [ "$KEENETIC" = 1 ]; then
        local ac
        ac=$(sed -n 's/^AUTO_CHECK=//p' "$CONFIG" 2>/dev/null | tail -1)
        [ "$ac" = "0" ] && echo 0 || echo 1
        return
    fi
    crontab -l 2>/dev/null | grep -q "$CHECK_CRON_MATCH" && echo 1 || echo 0
}

# autocheck on|off|status — toggle the unattended 6h check + persist the flag.
# OpenWrt installs/removes the crontab line; Keenetic only flips AUTO_CHECK in
# update.conf — S90detour-cron's loop re-reads it and runs (or skips) check-all.
cmd_autocheck() {
    case "${1:-status}" in
        on)
            set_conf_flag AUTO_CHECK 1
            if [ "$KEENETIC" != 1 ]; then
                ( crontab -l 2>/dev/null | grep -v "$CHECK_CRON_MATCH"; echo "$CHECK_CRON_LINE" ) | crontab -
                /etc/init.d/cron enable >/dev/null 2>&1
                /etc/init.d/cron restart >/dev/null 2>&1
            fi
            log "autocheck enabled"
            ;;
        off)
            set_conf_flag AUTO_CHECK 0
            if [ "$KEENETIC" != 1 ]; then
                crontab -l 2>/dev/null | grep -v "$CHECK_CRON_MATCH" | crontab - 2>/dev/null
                /etc/init.d/cron restart >/dev/null 2>&1
            fi
            log "autocheck disabled"
            ;;
        status) ;;
        *) die "autocheck: expected on|off|status" ;;
    esac
    [ "$(autocheck_enabled)" = "1" ] && printf '{"enabled":true}\n' || printf '{"enabled":false}\n'
}

ACTION="${1:-help}"
case "$ACTION" in
    check)             cmd_check ;;
    check-all)         cmd_check_all ;;
    autocheck)         cmd_autocheck "${2:-status}" ;;
    apply)             cmd_apply ;;
    apply-local)       cmd_apply_local "${2:-}" ;;
    bins-check)        cmd_bins_check ;;
    bins-apply)        cmd_bins_apply ;;
    bins-status)       cat "$BINS_STATE_FILE" 2>/dev/null || echo '{"status":"unknown"}' ;;
    tpws-check)        cmd_tpws_check ;;
    tpws-apply)        cmd_tpws_apply ;;
    tpws-status)       cat "$TPWS_STATE_FILE" 2>/dev/null || echo '{"status":"unknown"}' ;;
    nfqws2-check)      cmd_nfqws2_check ;;
    nfqws2-apply)      cmd_nfqws2_apply ;;
    nfqws2-status)     cat "$NFQWS2_STATE_FILE" 2>/dev/null || echo '{"status":"unknown"}' ;;
    rollback)          cmd_rollback ;;
    status)            cmd_status ;;
    selftest)          cmd_selftest ;;
    help|--help|-h)
        sed -n '2,34p' "$0"
        ;;
    *) echo "unknown subcommand: $ACTION" >&2
       echo "try: $0 help" >&2
       exit 2 ;;
esac
