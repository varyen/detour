#!/bin/sh
# detour-update — fetch + verify + install signed .ipk releases.
#
# Each release on GitHub is a usign-signed .ipk file plus its detached
# signature. The flow is:
#   1. Query GH API for the latest tag and asset URLs.
#   2. Download .ipk + .ipk.sig into /tmp.
#   3. usign -V the .ipk against the pinned public key.
#   4. opkg install /tmp/<file>.ipk.
# opkg owns the file install, version registry, and dependency check;
# postinst in the package handles service restart and first-install seeding.
#
# The panel release is ONE .ipk asset (detour_<ver>_all.ipk). sing-box is NOT a
# release asset — it is pulled from our self-hosted opkg feed (build_feed.py →
# varyen/detour@feed). The panel `Depends: sing-box`, so `apply` ensures the feed
# is configured + sing-box is installed before installing the panel. The `bins-*`
# subcommands now drive sing-box THROUGH opkg (`opkg upgrade sing-box`), not a
# detour-bins package.
#
# Subcommands:
#   check                  — query GH for latest PANEL tag; write state file; on a
#                            newly-available version, Web Push once (deduped)
#   check-all              — one tick: panel + sing-box + tpws + nfqws2 checks (cron)
#   autocheck on|off|status — toggle the unattended 6h auto-check cron (default on)
#   apply                  — ensure feed+sing-box, then install latest panel release
#   apply-local <ipk>      — install a panel .ipk already on disk (verifies sig)
#   bins-check             — opkg-check whether a newer sing-box is in the feed
#   bins-apply             — opkg update + upgrade sing-box from the feed
#   bins-status            — print the sing-box update state file
#   tpws-check             — opkg-check whether a newer tpws-zapret is in the feed
#   tpws-apply             — opkg update + upgrade tpws-zapret from the feed
#   tpws-status            — print the tpws-zapret update state file
#   nfqws2-check           — opkg-check whether a newer nfqws2 (zapret2) is in the feed
#   nfqws2-apply           — opkg update + upgrade nfqws2 from the feed
#   nfqws2-status          — print the nfqws2 (zapret2) update state file
#   rollback               — re-install the previous panel .ipk from backup
#   status                 — print panel state file
#   selftest               — usign / opkg / pinned-key sanity check
#
# Config (/etc/detour/update.conf) — OPTIONAL. Owner/repo default to the public
# varyen/detour repo, so self-update works with no config file at all. Provide it
# only to override the source repo or add a token:
#   GH_OWNER=user      (default: varyen)
#   GH_REPO=repo       (default: detour)
#   GH_TOKEN=ghp_...   (optional; repo is public — only raises the API rate limit
#                       or allows a private fork)

set -u

CONFIG=/etc/detour/update.conf
PUBLIC_KEY=/etc/detour/release.usign.pub
OPKG_KEYRING=/etc/opkg/keys
VERSION_FILE=/etc/detour/version
STATE_FILE=/var/state/detour-update.json
BACKUP_DIR=/var/detour-backup
LOCKFILE=/tmp/detour-update.lock
LOG_TAG=detour-update
PACKAGE_NAME=detour
SINGBOX_PKG=sing-box
TPWS_PKG=tpws-zapret
NFQWS2_PKG=nfqws2
BINS_STATE_FILE=/var/state/detour-bins.json     # sing-box update state (panel reads this path)
TPWS_STATE_FILE=/var/state/detour-tpws.json     # tpws-zapret update state (panel reads this path)
NFQWS2_STATE_FILE=/var/state/detour-nfqws2.json # nfqws2 (zapret2) update state (panel reads this)
# Upstream project repos — the "a newer version is out on GitHub" signal, checked
# INDEPENDENTLY of our opkg feed. Detection only: install still goes through the
# feed (so opkg keeps the version registry / postinst / sysupgrade keeplist). The
# panel lights an amber chip when upstream > installed but the feed isn't bumped yet.
SINGBOX_UPSTREAM_REPO="SagerNet/sing-box"
TPWS_UPSTREAM_REPO="bol-van/zapret"
NFQWS2_UPSTREAM_REPO="bol-van/zapret2"
PUSH_BIN=/usr/sbin/detour-push                  # Web Push sender — alert when a new panel version appears
NOTIFIED_FILE=/var/state/detour-update-notified # last panel version we pushed about (dedup the 6h cron)
# Self-hosted opkg feed serving sing-box. Keep in sync with build_release.py
# (FEED_LINE) and deploy_router.py.
FEED_NAME=detour
FEED_LINE="src/gz detour https://raw.githubusercontent.com/varyen/detour/feed/aarch64"
FEED_CONF=/etc/opkg/customfeeds.conf
# The panel .ipk is published as `Architecture: all`; this is only the local
# temp-download filename — opkg reads the real arch from the package control.
ARCH=all

# Default to the canonical public repo so self-update works even when
# update.conf is absent (the repo is public → no token required). update.conf,
# if present, is sourced below and overrides these.
GH_OWNER=varyen
GH_REPO=detour
GH_TOKEN=""
AUTO_CHECK=1          # 6h cron auto-check (default on). Opt out via `autocheck off` or AUTO_CHECK=0.

# GitHub release asset name patterns — OpenWrt panel by default. Keenetic uses the
# separate detour-keenetic_*.ipk asset (overridden in the platform shim below).
ASSET_RE='^detour_.*\.ipk$'
ASSET_SIG_RE='^detour_.*\.ipk\.sig$'
STASH_IPK=/etc/detour/installed.ipk

# --- Keenetic/Entware platform shim (mirrors detour-api / detour-hosts) --------
# The PANEL has no opkg feed here, so panel self-update = pull the
# detour-keenetic_*.ipk asset and opkg-install it. sing-box + tpws DO come from our
# own mipsel feed now (feed/mipsel) — same as OpenWrt — so the feed/ensure steps run.
# usign may be absent on Entware → the .ipk signature check is skipped if so (the
# asset still comes straight from GitHub). GH_TOKEN is OPTIONAL here (public repo) —
# gh_curl omits auth when it's empty.
KEENETIC=0
if [ -d /opt/etc/ndm ] || [ -f /opt/etc/detour/platform ]; then
    KEENETIC=1
    export PATH="/opt/bin:/opt/sbin:/usr/bin:/usr/sbin:/bin:/sbin"
    CONFIG=/opt/etc/detour/update.conf
    PUBLIC_KEY=/opt/etc/detour/release.usign.pub
    OPKG_KEYRING=/opt/etc/opkg/keys
    VERSION_FILE=/opt/etc/detour/version
    STATE_FILE=/opt/var/state/detour-update.json
    BACKUP_DIR=/opt/var/detour-backup
    BINS_STATE_FILE=/opt/var/state/detour-bins.json
    TPWS_STATE_FILE=/opt/var/state/detour-tpws.json
    NFQWS2_STATE_FILE=/opt/var/state/detour-nfqws2.json
    PUSH_BIN=/opt/sbin/detour-push
    NOTIFIED_FILE=/opt/var/state/detour-update-notified
    PACKAGE_NAME=detour-keenetic
    ASSET_RE='^detour-keenetic_.*\.ipk$'
    ASSET_SIG_RE='^detour-keenetic_.*\.ipk\.sig$'
    STASH_IPK=/opt/etc/detour/installed.ipk
    # sing-box + tpws now come from OUR mipsel feed (feed/mipsel) — same model as
    # OpenWrt — so the panel can ship the latest 1.13.x instead of waiting on Entware's
    # lagging `sing-box-go`. Entware's `sing-box-go` (Provides: sing-box) remains an
    # automatic fallback for `Depends: sing-box` if our feed is ever unreachable, but
    # ensure_singbox migrates to (and pins) our package and retires sing-box-go.
    SINGBOX_PKG=sing-box
    FEED_CONF=/opt/etc/opkg/customfeeds.conf
    FEED_LINE="src/gz detour https://raw.githubusercontent.com/varyen/detour/feed/mipsel"
    # GH_OWNER/GH_REPO inherit the varyen/detour defaults set above.
fi
[ -f "$CONFIG" ] && . "$CONFIG"
# A stale/placeholder update.conf may carry empty GH_OWNER=/GH_REPO= (an older
# OpenWrt postinst seeded exactly that) and would clobber the public-repo defaults
# set above, killing self-update with "GH_OWNER/GH_REPO missing". Re-assert the
# defaults whenever they came back blank, so self-update never depends on
# update.conf for the canonical public repo.
[ -n "$GH_OWNER" ] || GH_OWNER=varyen
[ -n "$GH_REPO" ] || GH_REPO=detour

# The 6h auto-check cron runs `check-all` (panel + sing-box + tpws + nfqws2) so
# the panel can light up any stale version chip. The manual panel "Проверить"
# buttons and `detour-update check` always work regardless of this cron — only the
# unattended tick is gated. CHECK_CRON_MATCH stays "detour-update check" so it also
# matches the legacy `check` line (a substring of `check-all`) for clean removal.
CHECK_CRON_LINE="0 */6 * * * /usr/sbin/detour-update check-all >/var/log/detour-update.log 2>&1"
CHECK_CRON_MATCH="detour-update check"
[ "$KEENETIC" = 1 ] && CHECK_CRON_LINE="0 */6 * * * /opt/sbin/detour-update check-all >/opt/var/log/detour-update.log 2>&1"

log() { logger -t "$LOG_TAG" -- "$*" 2>/dev/null; echo "[$LOG_TAG] $*" >&2; }
die() { log "ERROR: $*"; exit 1; }

current_version() {
    if [ -f "$VERSION_FILE" ]; then cat "$VERSION_FILE"
    else opkg list-installed "$PACKAGE_NAME" 2>/dev/null | awk '{print $3}' | head -1
         [ -z "$(opkg list-installed "$PACKAGE_NAME" 2>/dev/null)" ] && echo "0.0.0"
    fi
}

# version_gt A B → exit 0 if A > B (semver X.Y.Z numeric)
version_gt() {
    awk -v a="$1" -v b="$2" 'BEGIN {
        split(a, A, "."); split(b, B, ".")
        for (i = 1; i <= 3; i++) {
            ai = A[i]+0; bi = B[i]+0
            if (ai > bi) exit 0
            if (ai < bi) exit 1
        }
        exit 1
    }'
}

json_escape() {
    printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g; s/\t/\\t/g; s/\r//g' | tr '\n' ' '
}

# prev_field <state-file> <key> → value of "key":"value" in a flat JSON state file
# ("" if absent). Used to keep the last-known upstream version when a GitHub query
# fails (censored / throttled link), so a transient miss never clears the chip.
prev_field() {
    [ -f "$1" ] || return 0
    sed -n 's/.*"'"$2"'"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$1" | head -1
}

write_state() {
    local status="$1" message="$2" available="$3"
    local cur now
    cur=$(current_version)
    now=$(date -u "+%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || date -u +%Y-%m-%dT%H:%M:%SZ)
    mkdir -p "$(dirname "$STATE_FILE")"
    cat > "$STATE_FILE" <<EOF
{
  "current_version": "$cur",
  "available_version": "$(json_escape "$available")",
  "last_check": "$now",
  "status": "$(json_escape "$status")",
  "message": "$(json_escape "$message")"
}
EOF
}

# Pull the latest release metadata from GitHub. Outputs (on stdout):
#   line 1     : <tag_name>
#   lines 2..N : <asset_name>\t<download_url>   (one per release asset)
# A release carries two .ipk assets now (panel + bins); callers select by name.
# curl wrapper: add a Bearer auth header only when GH_TOKEN is set. The repo is
# PUBLIC, so unauthenticated requests work (just a lower rate limit) — self-update
# needs no PAT. A token only raises the limit / allows a private repo.
#
# --connect-timeout 15 caps the TCP+TLS handshake. WITHOUT it, a stalled handshake
# to the asset CDN on a throttled/censored RU link hangs for curl's *300s* default
# (surfaces as "curl: (28) SSL connection timeout") — i.e. FIVE MINUTES of a frozen
# apply log with no output before gh_curl_retry can even log the failure and retry.
# 15s makes a dead connection fail fast so the live log keeps ticking attempt→attempt.
# Transfer time is still bounded separately by each caller's --max-time.
gh_curl() {
    if [ -n "$GH_TOKEN" ]; then curl --connect-timeout 15 -H "Authorization: Bearer $GH_TOKEN" "$@"
    else curl --connect-timeout 15 "$@"; fi
}

# Retry wrapper around gh_curl. api.github.com and especially the asset CDN
# (release-assets.githubusercontent.com) are *intermittently* unresolvable on
# censored / throttled links (RU): a single curl miss (DNS error 6, connect
# reset, timeout) would otherwise fail the whole self-update — exactly the
# "Could not resolve host: release-assets.githubusercontent.com" the panel hit.
# Re-invoking curl forces a fresh DNS lookup, which usually succeeds within a
# couple of tries. Passes all args through unchanged; logs attempts to stderr
# (never stdout, so captured output stays clean).
gh_curl_retry() {
    local _n=0 _rc
    while [ "$_n" -lt 4 ]; do
        _n=$((_n + 1))
        gh_curl "$@"
        _rc=$?
        [ "$_rc" -eq 0 ] && return 0
        # curl 23 = "failure writing output to destination" → the FS is full (on
        # Keenetic /tmp is a ~124 MB tmpfs the sing-box log can fill). Retrying
        # can't help and just spams the log — bail now with a clear reason.
        [ "$_rc" -eq 23 ] && { log "GitHub request failed: cannot write output (disk full? check /tmp)"; return 1; }
        [ "$_n" -lt 4 ] && { log "GitHub request attempt $_n/4 failed — retrying in 3s..."; sleep 3; }
    done
    return 1
}

gh_assets() {
    [ -n "$GH_OWNER" ] && [ -n "$GH_REPO" ] || die "GH_OWNER/GH_REPO missing in $CONFIG"
    local url tmp
    url="https://api.github.com/repos/$GH_OWNER/$GH_REPO/releases/latest"
    tmp=$(mktemp)
    gh_curl_retry -fsSL \
        -H "Accept: application/vnd.github+json" \
        -H "X-GitHub-Api-Version: 2022-11-28" \
        --max-time 30 \
        -o "$tmp" "$url" || { rm -f "$tmp"; die "GH API request failed"; }
    # Tiny Lua JSON parser (lua-cjson is a hard dep).
    lua - <<'LUA' "$tmp"
-- Entware/Keenetic ships a pure-Lua cjson.safe under /opt/share/lua/5.1/ (no C
-- lua-cjson in the feed). Prepend that path so require finds it; harmless on
-- OpenWrt (dir absent → falls through to the system cjson).
package.path = "/opt/share/lua/5.1/?.lua;/opt/share/lua/5.1/?/init.lua;" .. package.path
local cjson = require("cjson.safe")
local f = io.open(arg[1], "r"); if not f then os.exit(1) end
local raw = f:read("*a"); f:close()
local doc = cjson.decode(raw); if not doc then os.exit(1) end
print(doc.tag_name or "")
for _, a in ipairs(doc.assets or {}) do
    if a.name and a.browser_download_url then
        print(a.name .. "\t" .. a.browser_download_url)
    end
end
LUA
    local rc=$?
    rm -f "$tmp"
    [ "$rc" = "0" ] || die "failed to parse GH API response"
}

# gh_latest_tag <owner/repo> → latest non-prerelease release tag (v-stripped) on
# stdout; returns 1 on network/parse failure so the caller can fall back to the
# last-known value. Reuses the gh_curl retry wrapper + lua-cjson parser. This is
# the upstream-version probe for the binary chips (sing-box / zapret / zapret2),
# separate from gh_assets (which is hardwired to our own GH_OWNER/GH_REPO).
gh_latest_tag() {
    local repo="$1" tmp tag
    tmp=$(mktemp 2>/dev/null) || return 1
    if ! gh_curl_retry -fsSL \
            -H "Accept: application/vnd.github+json" \
            -H "X-GitHub-Api-Version: 2022-11-28" \
            --max-time 30 -o "$tmp" \
            "https://api.github.com/repos/$repo/releases/latest" 2>/dev/null; then
        rm -f "$tmp"; return 1
    fi
    tag=$(lua - "$tmp" 2>/dev/null <<'LUA'
package.path = "/opt/share/lua/5.1/?.lua;/opt/share/lua/5.1/?/init.lua;" .. package.path
local cjson = require("cjson.safe")
local f = io.open(arg[1], "r"); if not f then os.exit(1) end
local raw = f:read("*a"); f:close()
local doc = cjson.decode(raw); if not doc then os.exit(1) end
print(doc.tag_name or "")
LUA
)
    rm -f "$tmp"
    [ -n "$tag" ] || return 1
    printf '%s' "${tag#v}"
}

# select_url "<assets>" "<name-regex>" → URL of first asset whose name matches.
select_url()  { printf '%s\n' "$1" | awk -F '\t' -v re="$2" 'NR>1 && $1 ~ re { print $2; exit }'; }
select_name() { printf '%s\n' "$1" | awk -F '\t' -v re="$2" 'NR>1 && $1 ~ re { print $1; exit }'; }

# Ensure our sing-box/tpws feed line is present in opkg's customfeeds.conf. Runs on
# BOTH platforms now: the Keenetic shim above points FEED_CONF/FEED_LINE at
# /opt/etc/opkg + feed/mipsel, so Keenetic gets its own mipsel feed (it used to skip).
ensure_feed() {
    mkdir -p "$(dirname "$FEED_CONF")" 2>/dev/null   # /opt/etc/opkg may not exist yet on Keenetic
    touch "$FEED_CONF" 2>/dev/null
    grep -qs "^src/gz $FEED_NAME " "$FEED_CONF" 2>/dev/null && return 0
    echo "$FEED_LINE" >> "$FEED_CONF" && log "added opkg feed: $FEED_LINE"
}

# Ensure sing-box is installed (from the feed). --force-overwrite takes over a
# pre-existing UNOWNED binary from older direct deploys. Non-fatal: the init.d
# tolerates a missing binary (traffic routes directly until sing-box arrives).
ensure_singbox() {
    ensure_feed
    if opkg list-installed "$SINGBOX_PKG" 2>/dev/null | grep -q "^$SINGBOX_PKG "; then
        return 0
    fi
    log "sing-box not installed — pulling from the feed"
    opkg update >/dev/null 2>&1
    opkg install --force-overwrite "$SINGBOX_PKG" >/dev/null 2>&1 \
        || log "WARNING: opkg install $SINGBOX_PKG failed (feed unreachable?)"
    # Keenetic: once OUR feed sing-box owns /opt/bin/sing-box, retire Entware's
    # sing-box-go so the two can't fight over the binary/opkg registry. Guarded on
    # ours being confirmed installed first — our `sing-box` already satisfies
    # detour-keenetic's `Depends: sing-box`, so the removal is dependency-safe.
    # Best-effort; --force-overwrite already reassigned the shared binary to us, so
    # removing sing-box-go won't delete /opt/bin/sing-box.
    if [ "$KEENETIC" = 1 ] \
       && opkg list-installed "$SINGBOX_PKG" 2>/dev/null | grep -q "^$SINGBOX_PKG " \
       && opkg list-installed sing-box-go 2>/dev/null | grep -q '^sing-box-go '; then
        opkg remove sing-box-go >/dev/null 2>&1 \
            && log "removed Entware sing-box-go (superseded by feed sing-box)"
    fi
}

# Installed sing-box version per opkg ("" if not opkg-owned).
sb_installed_version() {
    opkg list-installed "$SINGBOX_PKG" 2>/dev/null | awk '{print $3}' | head -1
}

# Version opkg would upgrade sing-box TO ("" = nothing newer than installed).
# Let opkg do the version math (`list-upgradable` lines: "<pkg> - <cur> - <new>")
# instead of sorting versions ourselves — busybox `sort` mis-ranks 1.13 vs 1.8.
sb_upgrade_version() {
    opkg list-upgradable 2>/dev/null | awk -v p="$SINGBOX_PKG" '$1==p {print $NF; exit}'
}

# Fire a Web Push when a NEW panel version becomes available. Deduped via a marker
# file so the unattended 6h cron alerts only ONCE per version (not every tick) — the
# panel chip already shows the update persistently; the push is just the one-time
# nudge, and it also reaches devices other than the one watching the panel. The same
# detour-push sender the health checker uses; best-effort — no-op if the sender is
# absent or there are no subscriptions. The marker is set regardless of how many
# pushes actually went out, so we never re-alert for the same version (a reboot
# clears /var/state and may re-nudge once, which is acceptable).
notify_update_available() {
    local newver="$1" cur="$2" last=""
    [ -x "$PUSH_BIN" ] || return 0
    [ -f "$NOTIFIED_FILE" ] && last=$(cat "$NOTIFIED_FILE" 2>/dev/null)
    [ "$last" = "$newver" ] && return 0
    "$PUSH_BIN" send "Detour: новая версия" \
        "Доступно обновление панели: v$cur → v$newver. Откройте панель, чтобы установить." \
        >/dev/null 2>&1
    mkdir -p "$(dirname "$NOTIFIED_FILE")" 2>/dev/null
    printf '%s' "$newver" > "$NOTIFIED_FILE"
}

cmd_check() {
    log "checking GitHub for latest release..."
    local assets tag ipk_url cur newver
    assets=$(gh_assets) || exit 1
    tag=$(printf '%s\n' "$assets" | sed -n 1p)
    ipk_url=$(select_url "$assets" "$ASSET_RE")
    [ -n "$tag" ] || die "no tag_name in GH response"
    [ -n "$ipk_url" ] || die "no panel .ipk asset on release $tag"
    newver="${tag#v}"
    cur=$(current_version)
    if version_gt "$newver" "$cur"; then
        log "update available: $cur -> $newver"
        write_state "update_available" "v$cur -> v$newver" "$newver"
        notify_update_available "$newver" "$cur"
    else
        log "up to date (current=$cur, latest=$newver)"
        write_state "up_to_date" "v$cur is the latest" "$newver"
    fi
}

# verify_and_install <ipk> <sig> <backup_basename> <stash_path> <opkg_flags>
#   backup_basename — filename under $BACKUP_DIR for the rollback copy ("" skips)
#   stash_path      — where to stash the installed .ipk (+.sig) for sysupgrade
#                     restore ("" skips)
#   opkg_flags      — extra opkg flags (bins uses --force-overwrite to take the
#                     binary files over from the old monolithic package)
verify_and_install() {
    local ipk="$1" sig="$2" backup_base="$3" stash="$4" opkg_flags="$5"
    [ -f "$ipk" ] || die "ipk missing: $ipk"
    [ -f "$sig" ] || die "ipk.sig missing: $sig"
    # Verify against pinned key. -P scans the keyring dir for any matching keynum.
    if [ "$KEENETIC" = 1 ] && ! command -v usign >/dev/null 2>&1; then
        # Entware usually has no `usign`. The asset still comes directly from the
        # project's GitHub release over HTTPS — skip the offline signature check.
        log "usign not available (Entware) — skipping signature check"
    elif [ -d "$OPKG_KEYRING" ] && ls "$OPKG_KEYRING"/* >/dev/null 2>&1; then
        usign -V -m "$ipk" -P "$OPKG_KEYRING" -x "$sig" \
            || die "usign verification failed (keyring=$OPKG_KEYRING)"
    elif [ -f "$PUBLIC_KEY" ]; then
        usign -V -m "$ipk" -p "$PUBLIC_KEY" -x "$sig" \
            || die "usign verification failed (key=$PUBLIC_KEY)"
    else
        die "no public key on this router — refusing to install unsigned"
    fi
    # Keep a copy of this exact .ipk before installing — used by rollback.
    mkdir -p "$BACKUP_DIR"
    [ -n "$backup_base" ] && cp -a "$ipk" "$BACKUP_DIR/$backup_base" 2>/dev/null
    # Cap the panel's backup count at 3.
    ls -1t "$BACKUP_DIR"/${PACKAGE_NAME}_*.ipk 2>/dev/null | tail -n +4 | xargs -r rm -f
    # opkg handles file replacement, dep resolution, postinst, etc.
    # shellcheck disable=SC2086
    opkg install $opkg_flags "$ipk" || die "opkg install failed"
    # Stash the just-installed package + its signature so the uci-defaults
    # restore script can re-install it after a router firmware sysupgrade
    # (sysupgrade preserves /etc/detour/ via /etc/sysupgrade.conf).
    if [ -n "$stash" ]; then
        mkdir -p "$(dirname "$stash")"
        cp -a "$ipk" "$stash" 2>/dev/null
        cp -a "$sig" "$stash.sig" 2>/dev/null
    fi
}

# Back-compat wrapper for the single-package (panel) callers.
verify_and_install_ipk() {
    verify_and_install "$1" "$2" "${PACKAGE_NAME}_$(current_version).ipk" \
        "$STASH_IPK" ""
}

# ---- sing-box (opkg feed) helpers ----
# Write the sing-box update-state file the panel reads. Keeps the legacy keys
# (current/available) so the CGI + UI need no schema change.
write_bins_state() {
    local cur="$1" avail="$2" upstream="${3:-}" upnew="${4:-false}" now
    now=$(date -u "+%Y-%m-%dT%H:%M:%SZ" 2>/dev/null)
    mkdir -p "$(dirname "$BINS_STATE_FILE")"
    cat > "$BINS_STATE_FILE" <<EOF
{"current":"$cur","available":"$avail","upstream":"$upstream","upstream_newer":$upnew,"asset":"$SINGBOX_PKG","last_check":"$now"}
EOF
}

cmd_bins_check() {
    log "checking the opkg feed for a newer sing-box..."
    ensure_feed
    opkg update >/dev/null 2>&1 || log "WARNING: opkg update failed (feed unreachable?)"
    local cur avail upstream upnew
    cur=$(sb_installed_version); [ -n "$cur" ] || cur="0.0.0"
    avail=$(sb_upgrade_version); [ -n "$avail" ] || avail="$cur"
    # WE own the sing-box feed on BOTH arches now (aarch64 + mipsel), so the "newer
    # upstream on GitHub" amber chip is actionable everywhere — bumping the feed is all
    # it takes. (Previously suppressed on Keenetic, where sing-box came from Entware's
    # uncontrollable sing-box-go and the chip would pin amber with nothing to install.)
    upstream=$(gh_latest_tag "$SINGBOX_UPSTREAM_REPO") || upstream=$(prev_field "$BINS_STATE_FILE" upstream)
    upnew=false
    [ -n "$upstream" ] && version_gt "$upstream" "${cur%-*}" && upnew=true
    write_bins_state "$cur" "$avail" "$upstream" "$upnew"
    if [ "$cur" != "$avail" ]; then
        log "sing-box update available (feed): $cur -> $avail"
    elif [ "$upnew" = true ]; then
        log "sing-box: newer upstream on GitHub ${cur%-*} -> $upstream (not in feed yet)"
    else
        log "sing-box up to date ($cur)"
    fi
}

# opkg update with retries + VISIBLE output. The detour feed is on
# raw.githubusercontent.com (Fastly), intermittently throttled on censored RU
# links: opkg's one-shot downloader fails with "wget returned 4" while a plain
# fetch of the same URL succeeds (verified on home). Retry a few times — each is a
# fresh connection. Output is NOT suppressed, so the live apply log shows exactly
# what opkg did (and the real error if it ultimately fails).
opkg_update_retry() {
    local n=0
    while :; do
        n=$((n + 1))
        log "opkg update (попытка $n/4)..."
        opkg update && return 0
        [ "$n" -ge 4 ] && return 1
        log "opkg update не удался — повтор через 3с..."
        sleep 3
    done
}

cmd_bins_apply() {
    [ -e "$LOCKFILE" ] && die "another apply in progress ($LOCKFILE)"
    : > "$LOCKFILE"
    # Hold the sing-box init's fail-closed flag across the opkg upgrade so the feed
    # package's prerm `stop` skips its firewall teardown: the REDIRECT rules stay up
    # across the binary swap → the daemon gap fails CLOSED (LAN → :12345 → refused),
    # never direct. postinst's `restart` clears the flag once the new daemon is up;
    # the trap is the safety net if opkg aborts mid-upgrade. This wraps the upgrade
    # from the PANEL side, so it protects even an already-installed feed package
    # whose own prerm predates the fix. OpenWrt only — the mipsel feed sing-box has a
    # NO-OP prerm (it never stops the daemon or touches iptables), and its postinst
    # bounces sing-box via S52detour-singbox `restart`, which keeps the REDIRECT marker
    # up → fail-closed without this flag. So no keepfw flag is needed on Keenetic.
    SB_KEEPFW=/tmp/.singbox-keepfw
    [ "$KEENETIC" = 1 ] && SB_KEEPFW=""
    trap 'rm -f "$LOCKFILE"; [ -n "$SB_KEEPFW" ] && rm -f "$SB_KEEPFW"' EXIT INT TERM
    ensure_feed
    log "opkg update + upgrade sing-box from the feed..."
    opkg_update_retry || log "WARNING: opkg update не удался после 4 попыток — ставлю из кэша индекса (новая версия может быть уже скачана)"
    # Set the flag NOW — right before the upgrade, AFTER the (possibly slow, flaky-
    # network) opkg update — so it is still fresh (< the 2-min staleness window) when
    # the prerm's `stop` runs. postinst's `restart` re-touches and then clears it.
    [ -n "$SB_KEEPFW" ] && : > "$SB_KEEPFW"
    if opkg list-installed "$SINGBOX_PKG" 2>/dev/null | grep -q "^$SINGBOX_PKG "; then
        # `opkg upgrade` no-ops if already newest; fall back to a forced install.
        opkg upgrade "$SINGBOX_PKG" 2>&1 \
            || opkg install --force-overwrite "$SINGBOX_PKG" 2>&1 \
            || die "opkg upgrade sing-box failed"
    else
        opkg install --force-overwrite "$SINGBOX_PKG" 2>&1 \
            || die "opkg install sing-box failed"
    fi
    cmd_bins_check >/dev/null 2>&1 || true
    log "sing-box now at $(sb_installed_version)"
}

# ---- tpws-zapret (opkg feed) helpers ----
# Mirror the sing-box helpers. tpws now ships from OUR feed on BOTH platforms
# (aarch64 + mipsel) — on Keenetic it used to be bundled in the panel package, but
# the mipsel feed serves it now, so the check/apply work there too.

# Installed tpws-zapret version per opkg ("" if not opkg-owned — e.g. when it is
# still the binary bundled by an older `detour` panel).
tpws_installed_version() {
    opkg list-installed "$TPWS_PKG" 2>/dev/null | awk '{print $3}' | head -1
}

# Version opkg would upgrade tpws-zapret TO ("" = nothing newer than installed).
tpws_upgrade_version() {
    opkg list-upgradable 2>/dev/null | awk -v p="$TPWS_PKG" '$1==p {print $NF; exit}'
}

# Ensure tpws-zapret is installed (from the feed). --force-overwrite takes over the
# tpws-zapret binary that an OLD bundled panel owned (/usr/bin on OpenWrt,
# /opt/sbin on Keenetic), transferring opkg ownership to the tpws-zapret feed
# package. Non-fatal: the init.d tolerates a missing binary (DPI bypass simply off
# until tpws arrives).
ensure_tpws() {
    ensure_feed
    if opkg list-installed "$TPWS_PKG" 2>/dev/null | grep -q "^$TPWS_PKG "; then
        return 0
    fi
    log "tpws-zapret not installed — pulling from the feed"
    opkg update >/dev/null 2>&1
    opkg install --force-overwrite "$TPWS_PKG" >/dev/null 2>&1 \
        || log "WARNING: opkg install $TPWS_PKG failed (feed unreachable?)"
}

# Write the tpws update-state file the panel reads (same shape as bins state).
write_tpws_state() {
    local cur="$1" avail="$2" upstream="${3:-}" upnew="${4:-false}" now
    now=$(date -u "+%Y-%m-%dT%H:%M:%SZ" 2>/dev/null)
    mkdir -p "$(dirname "$TPWS_STATE_FILE")"
    cat > "$TPWS_STATE_FILE" <<EOF
{"current":"$cur","available":"$avail","upstream":"$upstream","upstream_newer":$upnew,"asset":"$TPWS_PKG","last_check":"$now"}
EOF
}

cmd_tpws_check() {
    log "checking the opkg feed for a newer tpws-zapret..."
    ensure_feed
    opkg update >/dev/null 2>&1 || log "WARNING: opkg update failed (feed unreachable?)"
    local cur avail upstream upnew
    cur=$(tpws_installed_version); [ -n "$cur" ] || cur="0.0.0"
    avail=$(tpws_upgrade_version); [ -n "$avail" ] || avail="$cur"
    upstream=$(gh_latest_tag "$TPWS_UPSTREAM_REPO") || upstream=$(prev_field "$TPWS_STATE_FILE" upstream)
    upnew=false
    [ -n "$upstream" ] && version_gt "$upstream" "${cur%-*}" && upnew=true
    write_tpws_state "$cur" "$avail" "$upstream" "$upnew"
    if [ "$cur" != "$avail" ]; then
        log "tpws-zapret update available (feed): $cur -> $avail"
    elif [ "$upnew" = true ]; then
        log "tpws-zapret: newer upstream on GitHub ${cur%-*} -> $upstream (not in feed yet)"
    else
        log "tpws-zapret up to date ($cur)"
    fi
}

cmd_tpws_apply() {
    [ -e "$LOCKFILE" ] && die "another apply in progress ($LOCKFILE)"
    : > "$LOCKFILE"
    trap 'rm -f "$LOCKFILE"' EXIT INT TERM
    ensure_feed
    log "opkg update + upgrade tpws-zapret from the feed..."
    opkg_update_retry || log "WARNING: opkg update не удался после 4 попыток — ставлю из кэша индекса (новая версия может быть уже скачана)"
    if opkg list-installed "$TPWS_PKG" 2>/dev/null | grep -q "^$TPWS_PKG "; then
        # `opkg upgrade` no-ops if already newest; fall back to a forced install.
        opkg upgrade "$TPWS_PKG" 2>&1 \
            || opkg install --force-overwrite "$TPWS_PKG" 2>&1 \
            || die "opkg upgrade tpws-zapret failed"
    else
        opkg install --force-overwrite "$TPWS_PKG" 2>&1 \
            || die "opkg install tpws-zapret failed"
    fi
    cmd_tpws_check >/dev/null 2>&1 || true
    log "tpws-zapret now at $(tpws_installed_version)"
}

# ---- nfqws2 / zapret2 (opkg feed) helpers ----
# zapret2 ships as the `nfqws2` feed package (aarch64, OpenWrt only — KeeneticOS
# lacks NFQUEUE so the binary is never shipped there). Mirrors the sing-box/tpws
# feed flow; the nfqws2 package's own postinst re-applies zapret2 mode after an
# upgrade, so no service restart is needed here.

# Installed nfqws2 version per opkg ("" if not opkg-owned / not installed).
nfqws2_installed_version() {
    opkg list-installed "$NFQWS2_PKG" 2>/dev/null | awk '{print $3}' | head -1
}

# Version opkg would upgrade nfqws2 TO ("" = nothing newer than installed).
nfqws2_upgrade_version() {
    opkg list-upgradable 2>/dev/null | awk -v p="$NFQWS2_PKG" '$1==p {print $NF; exit}'
