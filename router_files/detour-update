{"current":"$cur","available":"$avail","upstream":"$upstream","upstream_newer":$upnew,"asset":"$NFQWS2_PKG","last_check":"$now"}
EOF
}

cmd_nfqws2_check() {
    if [ "$KEENETIC" = 1 ]; then
        write_nfqws2_state "n/a" "n/a"
        log "zapret2 (nfqws2) not supported on Keenetic (no NFQUEUE) — no feed check"
