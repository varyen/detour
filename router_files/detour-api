bins_update_check)
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    [ -x "$UPDATE_BIN" ] || { json_err "updater not installed"; exit 0; }
    OUT=$("$UPDATE_BIN" bins-check 2>&1)
    if [ -f "$BINS_STATE" ]; then
        cat "$BINS_STATE"
    else
        printf '{"status":"error","message":"%s"}' "$(printf '%s' "$OUT" | tail -5 | json_escape)"
    fi
    ;;

bins_update_apply)
    # opkg update + upgrade sing-box from our feed (via the updater).
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    [ -x "$UPDATE_BIN" ] || { json_err "updater not installed"; exit 0; }
    OUT=$("$UPDATE_BIN" bins-apply 2>&1)
    if [ $? -eq 0 ]; then
        json_ok
    else
        json_err "$(printf '%s' "$OUT" | tail -8 | json_escape)"
    fi
    ;;

singbox_opkg_upgrade)
    # Keenetic/Entware: pull the latest sing-box from the opkg feed (sing-box-go),
    # re-disable the package's own auto-start, then restart our service.
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    command -v opkg >/dev/null 2>&1 || { json_err "opkg not available"; exit 0; }
    OUT=$(opkg update 2>&1; echo '---'; opkg upgrade sing-box-go 2>&1)
    RC=$?
    if [ -f /opt/etc/init.d/S99sing-box ]; then
        /opt/etc/init.d/S99sing-box stop 2>/dev/null
        chmod 0644 /opt/etc/init.d/S99sing-box 2>/dev/null
    fi
    $SINGBOX_INITD restart >/dev/null 2>&1
    sleep 2
    if [ "$RC" -eq 0 ]; then
        printf '{"ok":true,"output":"%s"}' "$(printf '%s' "$OUT" | tail -12 | json_escape)"
    else
        json_err "$(printf '%s' "$OUT" | tail -12 | json_escape)"
    fi
    ;;

singbox_config)
    if [ "$REQUEST_METHOD" = "POST" ]; then
        echo "$POST_DATA" > "$SINGBOX_CONFIG"
        RESULT=$($SINGBOX_BIN check -c "$SINGBOX_CONFIG" 2>&1)
        if [ $? -eq 0 ]; then
            json_ok
        else
            ERRMSG=$(echo "$RESULT" | json_escape)
            json_err "$ERRMSG"
        fi
    else
        cat "$SINGBOX_CONFIG"
    fi
    ;;

singbox_start)  $SINGBOX_INITD start >/dev/null 2>&1; sleep 2; json_ok ;;
singbox_stop)   $SINGBOX_INITD stop >/dev/null 2>&1; sleep 1; json_ok ;;
singbox_restart) $SINGBOX_INITD restart >/dev/null 2>&1; sleep 3; json_ok ;;
singbox_enable) $SINGBOX_INITD enable >/dev/null 2>&1; json_ok ;;
singbox_disable) $SINGBOX_INITD disable >/dev/null 2>&1; json_ok ;;

singbox_log)
    if [ -f "$SINGBOX_LOG" ]; then
        LOG=$(tail -100 "$SINGBOX_LOG" | json_escape)
        printf '{"log":"%s"}' "$LOG"
    else
        echo '{"log":"(no log file)"}'
    fi
    ;;

singbox_log_clear) > "$SINGBOX_LOG" 2>/dev/null; json_ok ;;

# ==================== ZAPRET-TPWS ====================
zapret_start)   $ZAPRET_INITD start >/dev/null 2>&1; sleep 2; json_ok ;;
zapret_stop)    $ZAPRET_INITD stop >/dev/null 2>&1; sleep 1; json_ok ;;
zapret_restart) $ZAPRET_INITD stop >/dev/null 2>&1; sleep 1; $ZAPRET_INITD start >/dev/null 2>&1; sleep 2; json_ok ;;
zapret_enable)  $ZAPRET_INITD enable >/dev/null 2>&1; json_ok ;;
zapret_disable) $ZAPRET_INITD disable >/dev/null 2>&1; json_ok ;;

zapret_config)
    if [ "$REQUEST_METHOD" = "POST" ]; then
        echo "$POST_DATA" > "$ZAPRET_CONF"
        json_ok
    else
        ZP_ARGS=""
        [ -f "$ZAPRET_CONF" ] && ZP_ARGS=$(head -1 "$ZAPRET_CONF")
        printf '{"args":"%s"}' "$(echo "$ZP_ARGS" | json_escape)"
    fi
    ;;

zapret_domains)
    if [ "$REQUEST_METHOD" = "POST" ]; then
        mkdir -p /etc/zapret-tpws
        echo "$POST_DATA" > "$ZAPRET_DOMAINS"
        json_ok
    else
