chain_activate)
        if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
        CHAIN=$(normalize_profile_list "$POST_DATA")
        if [ -z "$CHAIN" ]; then json_err "chain required"; exit 0; fi

        SBMODE=$(get_singbox_mode)
        BUILD_ERR=$(build_config "$SBMODE" "$CHAIN")
        if [ $? -ne 0 ]; then
                json_err "config build failed: $(printf '%s' "$BUILD_ERR" | json_escape)"
                exit 0
        fi

        RMODE=$(resolve_routing_mode_for_chain "$CHAIN")
        UPSTREAM_IPS=$(collect_upstream_ips)
        write_settings "$CHAIN" "$RMODE" "$UPSTREAM_IPS" "$SBMODE"

        # Profile/chain switch only changes the upstream server — use the fast
        # reconfigure (skips the per-IP conntrack flush + DNS warm-up); fail-closed.
        $SINGBOX_INITD reconfigure >/dev/null 2>&1
        sleep 3
        json_ok
        ;;

profile_activate)
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    PNAME=$(echo "$QUERY_STRING" | sed -n 's/.*name=\([^&]*\).*/\1/p')
    PNAME=$(sanitize_name "$PNAME")
    if [ -z "$PNAME" ]; then json_err "name required"; exit 0; fi
    PFILE="$SINGBOX_PROFILES_DIR/$PNAME.json"
    if [ ! -f "$PFILE" ]; then json_err "profile not found"; exit 0; fi
        SBMODE=$(get_singbox_mode)
        BUILD_ERR=$(build_config "$SBMODE" "$PNAME")
        if [ $? -ne 0 ]; then
                json_err "config build failed: $(printf '%s' "$BUILD_ERR" | json_escape)"
                exit 0
        fi

        RMODE=$(resolve_routing_mode_for_chain "$PNAME")
        UPSTREAM_IPS=$(collect_upstream_ips)
        write_settings "$PNAME" "$RMODE" "$UPSTREAM_IPS" "$SBMODE"

