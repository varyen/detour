# ==================== HOSTS-DNS (priority hosts file via dnsmasq addn-hosts) ====================
# A "hosts override" (e.g. GeoHide DNS) pins domains to fixed IPs that dnsmasq
# serves with priority over upstream. This is a PARALLEL bypass — pinned domains
# go directly to the pinned IP, not through sing-box/zapret. All logic lives in
# /usr/sbin/detour-hosts; these handlers are thin wrappers relaying its JSON.
hosts_status)
    if [ -x "$HOSTS_BIN" ]; then
        "$HOSTS_BIN" status 2>/dev/null
    else
        printf '{"supported":false,"enabled":false,"error":"detour-hosts not installed"}'
    fi
    ;;

hosts_set)
    # POST {"url":"https://...","enabled":true|false}
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    [ -x "$HOSTS_BIN" ] || { json_err "detour-hosts not installed"; exit 0; }
    HD_URL=$(printf '%s' "$POST_DATA" | sed -n 's/.*"url"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)
    if [ -n "$HD_URL" ]; then
        "$HOSTS_BIN" seturl "$HD_URL" >/dev/null 2>&1 || { json_err "invalid url"; exit 0; }
    fi
    case "$POST_DATA" in
        *'"enabled":true'*|*'"enabled": true'*)   "$HOSTS_BIN" on  2>/dev/null ;;
        *'"enabled":false'*|*'"enabled": false'*) "$HOSTS_BIN" off 2>/dev/null ;;
        *) "$HOSTS_BIN" status 2>/dev/null ;;
    esac
    ;;

hosts_refresh)
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    [ -x "$HOSTS_BIN" ] || { json_err "detour-hosts not installed"; exit 0; }
    "$HOSTS_BIN" refresh 2>/dev/null
    ;;

hosts_exclude)
    # POST {"enabled":true|false} — toggle exclusion of already-proxied domains.
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    [ -x "$HOSTS_BIN" ] || { json_err "detour-hosts not installed"; exit 0; }
    case "$POST_DATA" in
        *'"enabled":true'*|*'"enabled": true'*)   "$HOSTS_BIN" exclude 1 2>/dev/null ;;
        *'"enabled":false'*|*'"enabled": false'*) "$HOSTS_BIN" exclude 0 2>/dev/null ;;
        *) json_err "enabled bool required" ;;
    esac
    ;;

hosts_get)
    # Filtered list content — fetched on demand only (can be large).
    if [ -f "$DETOUR_DIR/hosts-override.list" ]; then
        CONTENT=$(cat "$DETOUR_DIR/hosts-override.list" | json_escape)
        printf '{"hosts":"%s"}' "$CONTENT"
    else
        echo '{"hosts":""}'
    fi
    ;;

hosts_upload)
    # Raw body streamed to /tmp/detour-hosts-upload by the POST reader above.
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    [ -x "$HOSTS_BIN" ] || { json_err "detour-hosts not installed"; exit 0; }
    if [ ! -s /tmp/detour-hosts-upload ]; then json_err "no file uploaded"; exit 0; fi
    "$HOSTS_BIN" upload /tmp/detour-hosts-upload 2>/dev/null
    rm -f /tmp/detour-hosts-upload
    ;;

hosts_custom_get)
    # The user's own entries (separate from the source — survive refresh).
    if [ -f "$DETOUR_DIR/hosts-custom.list" ]; then
        CONTENT=$(cat "$DETOUR_DIR/hosts-custom.list" | json_escape)
        printf '{"custom":"%s"}' "$CONTENT"
    else
        echo '{"custom":""}'
    fi
    ;;

hosts_custom_save)
    # Raw body streamed to /tmp/detour-hosts-custom by the POST reader above.
    # An empty body (cleared textarea) yields no file → seed an empty one so the
    # worker clears the custom list. The worker rebuilds the served file = source
    # + custom and re-applies, so refreshing the source never wipes these.
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    [ -x "$HOSTS_BIN" ] || { json_err "detour-hosts not installed"; exit 0; }
    [ -f /tmp/detour-hosts-custom ] || : > /tmp/detour-hosts-custom
    "$HOSTS_BIN" custom-save /tmp/detour-hosts-custom 2>/dev/null
    rm -f /tmp/detour-hosts-custom
    ;;

hosts_custom_toggle)
    # POST {"enabled":true|false} — apply/suspend the custom block without losing it.
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    [ -x "$HOSTS_BIN" ] || { json_err "detour-hosts not installed"; exit 0; }
    case "$POST_DATA" in
        *'"enabled":true'*|*'"enabled": true'*)   "$HOSTS_BIN" custom-enable 1 2>/dev/null ;;
        *'"enabled":false'*|*'"enabled": false'*) "$HOSTS_BIN" custom-enable 0 2>/dev/null ;;
        *) json_err "enabled bool required" ;;
    esac
    ;;

subscription_fetch)
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    # POST body: {"url":"https://...","user_agent":"..."}  (UA optional)
    SUB_URL=$(printf '%s' "$POST_DATA" | sed -n 's/.*"url"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)
    SUB_UA=$(printf '%s' "$POST_DATA" | sed -n 's/.*"user_agent"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)
    [ -z "$SUB_UA" ] && SUB_UA="sing-box/1.13.2"
    if [ -z "$SUB_URL" ]; then json_err "url required"; exit 0; fi
    case "$SUB_URL" in
        http://*|https://*) ;;
        *) json_err "url must start with http:// or https://"; exit 0 ;;
    esac
    SUB_TMP=$(mktemp -d 2>/dev/null || echo "/tmp/sub_fetch.$$")
    mkdir -p "$SUB_TMP"
    # curl has -D (dump headers) and -A (UA); BusyBox wget on OpenWrt lacks both.
    if ! curl -sS -L -D "$SUB_TMP/hdrs" -o "$SUB_TMP/body" \
            --max-time 20 \
            -A "$SUB_UA" \
            -H "Accept: */*" \
            "$SUB_URL" 2>"$SUB_TMP/err"; then
        SUB_ERR=$(head -3 "$SUB_TMP/err" 2>/dev/null | json_escape)
        rm -rf "$SUB_TMP"
        json_err "fetch failed: $SUB_ERR"
        exit 0
    fi
    # Parse selected response headers (case-insensitive, last value across redirects wins).
    SUB_HDR_TITLE=$(grep -i '^profile-title:' "$SUB_TMP/hdrs" 2>/dev/null | sed 's/^[^:]*:[[:space:]]*//' | tr -d '\r' | tail -1)
    SUB_HDR_INTERVAL=$(grep -i '^profile-update-interval:' "$SUB_TMP/hdrs" 2>/dev/null | sed 's/^[^:]*:[[:space:]]*//' | tr -d '\r' | tail -1)
    SUB_HDR_USERINFO=$(grep -i '^subscription-userinfo:' "$SUB_TMP/hdrs" 2>/dev/null | sed 's/^[^:]*:[[:space:]]*//' | tr -d '\r' | tail -1)
    SUB_HDR_SUPPORT=$(grep -i '^support-url:' "$SUB_TMP/hdrs" 2>/dev/null | sed 's/^[^:]*:[[:space:]]*//' | tr -d '\r' | tail -1)
    SUB_HDR_CTYPE=$(grep -i '^content-type:' "$SUB_TMP/hdrs" 2>/dev/null | sed 's/^[^:]*:[[:space:]]*//' | tr -d '\r' | tail -1)
    SUB_BODY_ESC=$(json_escape < "$SUB_TMP/body")
    rm -rf "$SUB_TMP"
    printf '{"ok":true,"body":"%s","headers":{"profile-title":"%s","profile-update-interval":"%s","subscription-userinfo":"%s","support-url":"%s","content-type":"%s"}}' \
        "$SUB_BODY_ESC" \
        "$(printf '%s' "$SUB_HDR_TITLE" | json_escape)" \
        "$(printf '%s' "$SUB_HDR_INTERVAL" | json_escape)" \
        "$(printf '%s' "$SUB_HDR_USERINFO" | json_escape)" \
        "$(printf '%s' "$SUB_HDR_SUPPORT" | json_escape)" \
        "$(printf '%s' "$SUB_HDR_CTYPE" | json_escape)"
    ;;

subscription_save)
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    mkdir -p /etc/detour
    # Validate URL exists and looks remote
    SUB_URL=$(printf '%s' "$POST_DATA" | sed -n 's/.*"url"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)
    if [ -z "$SUB_URL" ]; then json_err "url required"; exit 0; fi
    case "$SUB_URL" in
        http://*|https://*) ;;
        *) json_err "url must start with http:// or https://"; exit 0 ;;
    esac
    # Persist as-is — client controls schema.
    printf '%s' "$POST_DATA" > /etc/detour/subscription.json
    chmod 600 /etc/detour/subscription.json
    json_ok
    ;;

subscription_get)
    if [ -f /etc/detour/subscription.json ]; then
        cat /etc/detour/subscription.json
    else
        echo '{}'
    fi
    ;;

subscription_refresh)
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    if [ ! -x $SUBREFRESH_BIN ]; then
        json_err "subscription-refresh helper missing"
        exit 0
    fi
    if $SUBREFRESH_BIN 2>/dev/null; then
        json_ok
    else
        json_err "refresh failed"
    fi
    ;;

# ===== Multi-subscription management (v2) =====
# Stored as one JSON object per file under /etc/detour/subscriptions/<id>.json
# Schema: {id, group, url, user_agent, user_agent_preset, interval_hours, autoupdate,
#          apply_routing, title, last_refresh, last_status, last_saved, last_removed}

subscriptions_list)
    SUBS_DIR="$DETOUR_DIR/subscriptions"
    mkdir -p "$SUBS_DIR" 2>/dev/null
    printf '{"ok":true,"subscriptions":['
    first=1
    for f in "$SUBS_DIR"/*.json; do
        [ -e "$f" ] || continue
        if [ "$first" = "1" ]; then first=0; else printf ','; fi
        cat "$f"
    done
    printf ']}'
    ;;

subscription_save_one)
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    SUBS_DIR="$DETOUR_DIR/subscriptions"
    mkdir -p "$SUBS_DIR"
    SUB_ID=$(printf '%s' "$POST_DATA" | sed -n 's/.*"id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)
    SUB_URL=$(printf '%s' "$POST_DATA" | sed -n 's/.*"url"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)
    if [ -z "$SUB_ID" ]; then json_err "id required"; exit 0; fi
    case "$SUB_ID" in
        *[!a-zA-Z0-9._-]*) json_err "id: only a-z A-Z 0-9 ._- allowed"; exit 0 ;;
    esac
    if [ -z "$SUB_URL" ]; then json_err "url required"; exit 0; fi
    case "$SUB_URL" in
        http://*|https://*) ;;
        *) json_err "url must start with http:// or https://"; exit 0 ;;
    esac
    printf '%s' "$POST_DATA" > "$SUBS_DIR/$SUB_ID.json.tmp"
    chmod 600 "$SUBS_DIR/$SUB_ID.json.tmp"
    mv "$SUBS_DIR/$SUB_ID.json.tmp" "$SUBS_DIR/$SUB_ID.json"
    json_ok
    ;;

subscription_delete_one)
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    SUBS_DIR="$DETOUR_DIR/subscriptions"
    SUB_ID=$(printf '%s' "$QUERY_STRING" | sed -n 's/.*[?&]id=\([^&]*\).*/\1/p' | head -1)
    if [ -z "$SUB_ID" ]; then json_err "id required"; exit 0; fi
    case "$SUB_ID" in
        *[!a-zA-Z0-9._-]*) json_err "id invalid"; exit 0 ;;
    esac
    rm -f "$SUBS_DIR/$SUB_ID.json"
    json_ok
    ;;

subscription_refresh_one)
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    SUB_ID=$(printf '%s' "$QUERY_STRING" | sed -n 's/.*[?&]id=\([^&]*\).*/\1/p' | head -1)
    if [ -z "$SUB_ID" ]; then json_err "id required"; exit 0; fi
    case "$SUB_ID" in
        *[!a-zA-Z0-9._-]*) json_err "id invalid"; exit 0 ;;
    esac
    if [ ! -x $SUBREFRESH_BIN ]; then
        json_err "subscription-refresh helper missing"; exit 0
    fi
    OUT=$($SUBREFRESH_BIN --id="$SUB_ID" --force 2>&1)
    EC=$?
    OUT_ESC=$(printf '%s' "$OUT" | json_escape)
    if [ $EC -eq 0 ]; then
        printf '{"ok":true,"output":"%s"}' "$OUT_ESC"
    else
        printf '{"ok":false,"error":"refresh failed (exit %d)","output":"%s"}' "$EC" "$OUT_ESC"
    fi
    ;;

subscription_refresh_all)
    # Iterate over every saved subscription and run a forced refresh.
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    if [ ! -x $SUBREFRESH_BIN ]; then
        json_err "subscription-refresh helper missing"; exit 0
    fi
    OUT=$($SUBREFRESH_BIN --all --force 2>&1)
    EC=$?
    OUT_ESC=$(printf '%s' "$OUT" | json_escape)
    if [ $EC -eq 0 ]; then
        printf '{"ok":true,"output":"%s"}' "$OUT_ESC"
    else
        printf '{"ok":false,"error":"refresh failed (exit %d)","output":"%s"}' "$EC" "$OUT_ESC"
    fi
    ;;

panel_export_config)
    # Bundle global panel state into one JSON envelope so the operator can
    # back it up before reflashing or migrate to a new router. VPN profiles
    # are NOT included here — they have their own profiles_export action.
    # Sensitive credentials (panel auth, GH token) are also excluded.
    NOW=$(date -u "+%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || date -u +%Y-%m-%dT%H:%M:%SZ)
    PA_VER=$(cat /etc/detour/version 2>/dev/null)
    printf '{"version":1,"exported_at":"%s","router_version":"%s","settings":' \
        "$NOW" "$(printf '%s' "$PA_VER" | json_escape)"
    if [ -f /etc/sing-box/settings.json ]; then cat /etc/sing-box/settings.json
    else printf '{}'; fi
    printf ',"subscription":'
    if [ -f /etc/detour/subscription.json ]; then cat /etc/detour/subscription.json
    else printf '{}'; fi
    printf ',"proxy_domains":"'
    [ -f /etc/sing-box/proxy-domains.list ] && cat /etc/sing-box/proxy-domains.list | json_escape
    printf '","whitelist_domains":"'
    [ -f /etc/sing-box/whitelist-domains.list ] && cat /etc/sing-box/whitelist-domains.list | json_escape
    printf '","zapret_conf":"'
    [ -f /etc/zapret-tpws.conf ] && cat /etc/zapret-tpws.conf | json_escape
    printf '","zapret_domains":"'
    [ -f /etc/zapret-tpws/domains.list ] && cat /etc/zapret-tpws/domains.list | json_escape
    printf '"}'
    ;;

panel_import_config)
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    # Use Lua + cjson to safely parse and write each section. Plain sed can't
    # handle nested JSON or multi-MB domain lists reliably.
    IMPORT_TMP=$(mktemp)
    printf '%s' "$POST_DATA" > "$IMPORT_TMP"
    if ! lua - "$IMPORT_TMP" <<'LUA'
local cjson = require("cjson.safe")
local f = io.open(arg[1], "r"); if not f then os.exit(1) end
local raw = f:read("*a"); f:close()
local doc = cjson.decode(raw)
if not doc or type(doc) ~= "table" then os.exit(2) end

-- Hard rejection list. These keys ARE NOT processed by this endpoint and
-- MUST NEVER be — they would let a forged config file overwrite panel auth
-- or the GitHub token. Use panel_change_password / deploy_router.py instead.
local FORBIDDEN = {
    auth=true, password=true, passwd=true, panel_user=true, panel_password=true,
    update_conf=true, gh_token=true, gh_owner=true, gh_repo=true,
}
for k in pairs(doc) do
    if FORBIDDEN[k] then
        io.stderr:write("FORBIDDEN_KEY:" .. k .. "\n")
        os.exit(3)
    end
end

local function atomic_write(path, body, mode)
    if body == nil then return end
    local tmp = path .. ".import.tmp"
    local w = io.open(tmp, "w"); if not w then return end
    w:write(body); w:close()
    if mode then os.execute("chmod " .. mode .. " " .. tmp) end
    os.rename(tmp, path)
end

if type(doc.settings) == "table" then
    atomic_write("/etc/sing-box/settings.json", cjson.encode(doc.settings), "0644")
end
if type(doc.subscription) == "table" and next(doc.subscription) then
    os.execute("mkdir -p /etc/detour")
    atomic_write("/etc/detour/subscription.json", cjson.encode(doc.subscription), "0600")
end
if type(doc.proxy_domains) == "string" and #doc.proxy_domains > 0 then
    atomic_write("/etc/sing-box/proxy-domains.list", doc.proxy_domains, "0644")
end
if type(doc.whitelist_domains) == "string" and #doc.whitelist_domains > 0 then
    atomic_write("/etc/sing-box/whitelist-domains.list", doc.whitelist_domains, "0644")
end
if type(doc.zapret_conf) == "string" and #doc.zapret_conf > 0 then
    atomic_write("/etc/zapret-tpws.conf", doc.zapret_conf, "0644")
end
if type(doc.zapret_domains) == "string" and #doc.zapret_domains > 0 then
    os.execute("mkdir -p /etc/zapret-tpws")
    atomic_write("/etc/zapret-tpws/domains.list", doc.zapret_domains, "0644")
end
os.exit(0)
LUA
    then
        # Lua exit codes:  3 = forbidden key seen, 2 = invalid JSON, 1 = io error.
        IMPORT_EC=$?
        IMPORT_BAD_KEY=$(lua - "$IMPORT_TMP" 2>&1 >/dev/null <<'LUA' || true
local cjson = require("cjson.safe")
local f = io.open(arg[1], "r"); if not f then os.exit() end
local doc = cjson.decode(f:read("*a")) or {}
local FORBIDDEN = {
    auth=true, password=true, passwd=true, panel_user=true, panel_password=true,
    update_conf=true, gh_token=true, gh_owner=true, gh_repo=true,
}
if type(doc) == "table" then
    for k in pairs(doc) do if FORBIDDEN[k] then io.stderr:write(k); break end end
end
LUA
)
        rm -f "$IMPORT_TMP"
        if [ -n "$IMPORT_BAD_KEY" ]; then
            json_err "forbidden key in config: $IMPORT_BAD_KEY (panel auth / GH token cannot be set via this endpoint — use the Change-password modal or deploy_router.py)"
        elif [ "$IMPORT_EC" = "2" ]; then
            json_err "config is not a valid JSON object"
        else
            json_err "config import failed (exit $IMPORT_EC)"
        fi
        exit 0
    fi
    rm -f "$IMPORT_TMP"
    # Restart services so the new domain lists + settings take effect.
    $SINGBOX_INITD restart >/dev/null 2>&1 &
    json_ok
    ;;

panel_change_password)
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    # Body: {"old_password":"...","new_password":"...","new_user":"..."}
    # new_user is optional — when present, renames the panel account.
    OLD_PW=$(printf '%s' "$POST_DATA" | sed -n 's/.*"old_password"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)
    NEW_PW=$(printf '%s' "$POST_DATA" | sed -n 's/.*"new_password"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)
    NEW_USER=$(printf '%s' "$POST_DATA" | sed -n 's/.*"new_user"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)
    if [ -z "$NEW_PW" ]; then json_err "new_password required"; exit 0; fi
    if [ "${#NEW_PW}" -lt 8 ]; then json_err "password must be at least 8 chars"; exit 0; fi
    # Identify current user from the active session cookie.
    SESSION_USER=""
    TOKEN=$(get_session_token)
    [ -n "$TOKEN" ] && [ -f "$SESSION_DIR/$TOKEN" ] && SESSION_USER=$(cat "$SESSION_DIR/$TOKEN")
    if [ -z "$SESSION_USER" ]; then json_err "no active session"; exit 0; fi
    if ! verify_password "$SESSION_USER" "$OLD_PW"; then
        sleep 1
        json_err "old password is incorrect"
        exit 0
    fi
    # Validate optional new username (same rules as first-install setup).
    EFFECTIVE_USER="$SESSION_USER"
    if [ -n "$NEW_USER" ] && [ "$NEW_USER" != "$SESSION_USER" ]; then
        case "$NEW_USER" in
            *[!a-zA-Z0-9._-]*) json_err "username: only a-z, A-Z, 0-9, ._- allowed"; exit 0 ;;
        esac
        if [ "${#NEW_USER}" -lt 2 ] || [ "${#NEW_USER}" -gt 32 ]; then
            json_err "username must be 2..32 chars"; exit 0
        fi
        EFFECTIVE_USER="$NEW_USER"
    fi
    NEW_HASH=$(printf '%s' "$NEW_PW" | openssl passwd -6 -stdin 2>/dev/null)
    if [ -z "$NEW_HASH" ]; then json_err "openssl hash failed"; exit 0; fi
    # Atomic replacement to avoid windowed half-write on the auth file.
    TMP_AUTH=$(mktemp)
    printf '%s:%s\n' "$EFFECTIVE_USER" "$NEW_HASH" > "$TMP_AUTH"
    chmod 0600 "$TMP_AUTH"
    mv "$TMP_AUTH" "$AUTH_FILE"
    # If username changed, drop ALL sessions (including current) — operator
    # must log in with the new credentials. Otherwise just invalidate peers.
    if [ "$EFFECTIVE_USER" != "$SESSION_USER" ]; then
        rm -f "$SESSION_DIR"/* 2>/dev/null
        printf '{"ok":true,"user_changed":true}'
    else
        for sess in "$SESSION_DIR"/*; do
            [ "$sess" = "$SESSION_DIR/$TOKEN" ] && continue
            rm -f "$sess" 2>/dev/null
        done
        json_ok
    fi
    ;;

# ==================== WEB PUSH (VAPID, payload-less) ====================
# The heavy lifting (VAPID keypair, JWT, curl to push services, subscription
# store) lives in /usr/sbin/detour-push; these actions are a thin CGI front.
# All are behind the auth gate above. The service worker fetches push_message
# with the session cookie (same-origin) to render the notification text.
push_config)
    # What the panel needs to subscribe: the VAPID public key (applicationServerKey)
    # and whether push is available on this box at all (needs openssl + the sender).
    if [ ! -x "$PUSH_BIN" ] || ! command -v openssl >/dev/null 2>&1; then
        printf '{"ok":true,"available":false,"vapid_public":"","sub_count":0}'
    else
        PUB=$("$PUSH_BIN" pubkey 2>/dev/null)
        CNT=$("$PUSH_BIN" count 2>/dev/null); case "$CNT" in ''|*[!0-9]*) CNT=0 ;; esac
        BP=$("$PUSH_BIN" bypass-status 2>/dev/null); case "$BP" in active|inactive) ;; *) BP="n/a" ;; esac
        if [ -n "$PUB" ]; then
            printf '{"ok":true,"available":true,"vapid_public":"%s","sub_count":%s,"bypass":"%s"}' "$PUB" "$CNT" "$BP"
        else
            printf '{"ok":true,"available":false,"vapid_public":"","sub_count":0,"bypass":"%s"}' "$BP"
        fi
    fi
    ;;

push_subscribe)
    # Body = PushSubscription.toJSON() (endpoint + keys). Stored, deduped by endpoint.
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    [ -x "$PUSH_BIN" ] || { json_err "push sender not installed"; exit 0; }
    if printf '%s' "$POST_DATA" | "$PUSH_BIN" add >/dev/null 2>&1; then
        json_ok
    else
        json_err "invalid subscription"
    fi
    ;;

push_unsubscribe)
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    [ -x "$PUSH_BIN" ] || { json_err "push sender not installed"; exit 0; }
    EP=$(printf '%s' "$POST_DATA" | lua -e 'local c=require("cjson.safe"); local o=c.decode(io.read("*a")); io.write((type(o)=="table" and type(o.endpoint)=="string") and o.endpoint or "")' 2>/dev/null)
    [ -n "$EP" ] || { json_err "endpoint required"; exit 0; }
    "$PUSH_BIN" remove "$EP" >/dev/null 2>&1
    json_ok
    ;;

push_test)
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    [ -x "$PUSH_BIN" ] || { json_err "push sender not installed"; exit 0; }
    SENT=$("$PUSH_BIN" test 2>/dev/null); case "$SENT" in ''|*[!0-9]*) SENT=0 ;; esac
    printf '{"ok":true,"sent":%s}' "$SENT"
    ;;

push_message)
    # Read by the service worker on each push to render the notification text.
    if [ -f "$PUSH_MSG" ]; then
        cat "$PUSH_MSG"
    else
        printf '{"title":"Detour VPN","body":"Состояние VPN изменилось"}'
    fi
    ;;

# ==================== HTTPS / LET'S ENCRYPT (acme.sh) ====================
# Thin front over /usr/sbin/detour-cert (issue/install/renew an LE cert so the panel
# can be served over HTTPS — required for Web Push). All behind the auth gate above.
cert_detect)
    # Capabilities + current cert state for the UI (acme present?, :80 server, target,
    # WAN IP, current domain/expiry).
    if [ -x "$CERT_BIN" ]; then
        "$CERT_BIN" detect
    else
        printf '{"ok":true,"acme_present":false,"http80":"none","target":"none","wan_ip":"","domain":"","expiry":""}'
    fi
    ;;

cert_status)
    if [ -x "$CERT_BIN" ]; then
        "$CERT_BIN" status
    elif [ -f "$CERT_STATE" ]; then
        cat "$CERT_STATE"
    else
        printf '{"ok":true,"domain":"","last_result":""}'
    fi
    ;;

cert_issue)
    # Body = {"domain":"...","email":"..."}. Issuance takes 10-40s, so run it
    # detached and let the panel poll cert_status.
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    [ -x "$CERT_BIN" ] || { json_err "detour-cert not installed"; exit 0; }
    CINFO=$(printf '%s' "$POST_DATA" | lua -e 'local c=require("cjson.safe"); local o=c.decode(io.read("*a")) or {}; io.write((type(o.domain)=="string" and o.domain or "").."\t"..(type(o.email)=="string" and o.email or ""))' 2>/dev/null)
    CDOM=$(printf '%s' "$CINFO" | cut -f1)
    CEML=$(printf '%s' "$CINFO" | cut -f2)
    # Strict charset guard — these are interpolated into detach_bg's `sh -c` string,
    # so reject anything outside a safe set (no spaces / shell metacharacters).
    case "$CDOM" in ''|*[!a-zA-Z0-9.-]*) json_err "bad domain"; exit 0 ;; esac
    case "$CEML" in ''|*[!a-zA-Z0-9.@_+-]*) json_err "bad email"; exit 0 ;; esac
    detach_bg "/tmp/detour-cert-bg.log" "$CERT_BIN" issue "$CDOM" "$CEML"
    printf '{"ok":true,"started":true}'
    ;;

# ==================== SWAP FILE (Keenetic/Entware flash) ====================
# /opt lives on a USB flash with little RAM behind it — without a swap file the
# stack gets OOM-killed and the panel is unstable. These actions drive the S05swap
# init script's create/remove from the panel modal. Keenetic-only (the UI hides the
# menu elsewhere); the actions also guard on PLATFORM so OpenWrt returns «н/д».
swap_status)
    if [ "$PLATFORM" != "keenetic" ]; then
        printf '{"ok":true,"supported":false}'
        exit 0
    fi
    EXISTS=false;  [ -f "$SWAPFILE" ] && EXISTS=true
    ACTIVE=false
    swapon -s 2>/dev/null | awk -v f="$SWAPFILE" '$1==f{found=1} END{exit !found}' && ACTIVE=true
    # file size in MB (cheap: ls byte size, not du which walks the file)
    SIZE_MB=0
    if [ -f "$SWAPFILE" ]; then
        SIZE_MB=$(ls -l "$SWAPFILE" 2>/dev/null | awk '{printf "%d", $5/1048576}')
        case "$SIZE_MB" in ''|*[!0-9]*) SIZE_MB=0 ;; esac
    fi
    FREE_MB=$(df -m /opt 2>/dev/null | tail -n 1 | awk '{print $4}')
    case "$FREE_MB" in ''|*[!0-9]*) FREE_MB=0 ;; esac
    SWAPPINESS=$(cat /proc/sys/vm/swappiness 2>/dev/null)
    case "$SWAPPINESS" in ''|*[!0-9]*) SWAPPINESS=-1 ;; esac
    TOOLS=false
    command -v mkswap >/dev/null 2>&1 && command -v swapon >/dev/null 2>&1 && TOOLS=true
    BUSY=false; [ -f /tmp/detour-swap.busy ] && BUSY=true
    LAST_RESULT=""; LAST_MSG=""
    if [ -f "$SWAP_STATE" ]; then
        LAST_RESULT=$(sed -n 's/.*"result"[^"]*"\([^"]*\)".*/\1/p' "$SWAP_STATE" 2>/dev/null)
        LAST_MSG=$(sed -n 's/.*"message"[^"]*"\([^"]*\)".*/\1/p' "$SWAP_STATE" 2>/dev/null)
    fi
    printf '{"ok":true,"supported":true,"exists":%s,"active":%s,"size_mb":%s,"free_mb":%s,"swappiness":%s,"tools":%s,"busy":%s,"last_result":"%s","last_message":"%s"}' \
        "$EXISTS" "$ACTIVE" "$SIZE_MB" "$FREE_MB" "$SWAPPINESS" "$TOOLS" "$BUSY" \
        "$LAST_RESULT" "$(printf '%s' "$LAST_MSG" | json_escape)"
    ;;

swap_create)
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    if [ "$PLATFORM" != "keenetic" ]; then json_err "swap доступен только на Keenetic"; exit 0; fi
    command -v mkswap >/dev/null 2>&1 || { json_err "swap-utils не установлен (opkg install swap-utils)"; exit 0; }
    [ -x "$SWAP_INITD" ] || { json_err "S05swap не установлен"; exit 0; }
    [ -f /tmp/detour-swap.busy ] && { json_err "Создание уже выполняется"; exit 0; }
    SZ=$(printf '%s' "$POST_DATA" | sed -n 's/.*"size_mb"[^0-9]*\([0-9][0-9]*\).*/\1/p')
    case "$SZ" in ''|*[!0-9]*) SZ=512 ;; esac
    [ "$SZ" -lt 64 ]   && SZ=64
    [ "$SZ" -gt 4096 ] && SZ=4096
    FREE_MB=$(df -m /opt 2>/dev/null | tail -n 1 | awk '{print $4}')
    case "$FREE_MB" in ''|*[!0-9]*) FREE_MB=0 ;; esac
    if [ "$FREE_MB" -lt $((SZ + 32)) ]; then
        json_err "Недостаточно места на /opt: свободно ${FREE_MB}MB, нужно $((SZ + 32))MB"; exit 0
    fi
    : > "$SWAP_STATE" 2>/dev/null
    # Mark busy SYNCHRONOUSLY (before detach_bg's 1s settle), so a poll arriving in
    # the gap before the worker starts still sees busy=true and keeps waiting instead
    # of reading the just-truncated empty state and stopping early. The worker clears
    # it on every exit path.
    : > /tmp/detour-swap.busy 2>/dev/null
    # dd of up to 4GB on USB flash is slow → run detached; panel polls swap_status.
    detach_bg "/tmp/detour-swap-bg.log" "$SWAP_INITD" create "$SZ"
    printf '{"ok":true,"started":true,"size_mb":%s}' "$SZ"
    ;;

swap_remove)
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    if [ "$PLATFORM" != "keenetic" ]; then json_err "swap доступен только на Keenetic"; exit 0; fi
    [ -x "$SWAP_INITD" ] || { json_err "S05swap не установлен"; exit 0; }
    "$SWAP_INITD" remove >/dev/null 2>&1
    printf '{"ok":true}'
    ;;

*) json_err "unknown action: $ACTION" ;;

esac