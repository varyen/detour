    if [ -z "$SB_PID" ]; then json_err "sing-box is not running"; exit 0; fi
    UPSTREAM_IPS=$(get_upstream_ips)
    iptables -t nat -N SINGBOX_KS 2>/dev/null
    iptables -t nat -F SINGBOX_KS
    iptables -t nat -A SINGBOX_KS -d 10.0.0.0/8 -j RETURN
    iptables -t nat -A SINGBOX_KS -d 172.16.0.0/12 -j RETURN
    iptables -t nat -A SINGBOX_KS -d 192.168.0.0/16 -j RETURN
    iptables -t nat -A SINGBOX_KS -d 127.0.0.0/8 -j RETURN
    if [ -n "$UPSTREAM_IPS" ]; then
        OLD_IFS="$IFS"
        IFS=','
        set -- $UPSTREAM_IPS
        IFS="$OLD_IFS"
        for ip in "$@"; do
            [ -n "$ip" ] && iptables -t nat -A SINGBOX_KS -d "$ip" -j RETURN
        done
    fi
    iptables -t nat -A SINGBOX_KS -p tcp -j REDIRECT --to-ports 12345
    iptables -t nat -D PREROUTING -i $LAN_IF -j SINGBOX_KS 2>/dev/null
