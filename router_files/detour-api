        json_ok
    ;;

# ==================== SETTINGS ====================
settings)
    if [ "$REQUEST_METHOD" = "POST" ]; then
        # POST body may set "routing_mode" (proxy-list|all-except) and/or
        # "singbox_mode" (single|multi). Missing keys keep their current value.
        NEW_RMODE=$(printf '%s' "$POST_DATA" | sed -n 's/.*"routing_mode"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)
        NEW_SBMODE=$(printf '%s' "$POST_DATA" | sed -n 's/.*"singbox_mode"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)
        [ -z "$NEW_RMODE" ] && NEW_RMODE=$(get_routing_mode)
        [ -z "$NEW_SBMODE" ] && NEW_SBMODE=$(get_singbox_mode)
        case "$NEW_RMODE" in
            proxy-list|all-except) ;;
            *) json_err "invalid routing_mode"; exit 0 ;;
        esac
        case "$NEW_SBMODE" in
            single|multi) ;;
            *) json_err "invalid singbox_mode"; exit 0 ;;
        esac
        ACHAIN=$(get_active_chain)
        # Rebuild config(s) for the resolved instance mode (single<->multi
        # generate different files). Validated before any restart.
        BUILD_ERR=$(build_config "$NEW_SBMODE" "$ACHAIN")
        if [ $? -ne 0 ]; then
            json_err "config build failed: $(printf '%s' "$BUILD_ERR" | json_escape)"
            exit 0
        fi
        UPSTREAM_IPS=$(collect_upstream_ips)
        write_settings "$ACHAIN" "$NEW_RMODE" "$UPSTREAM_IPS" "$NEW_SBMODE"
        $SINGBOX_INITD restart >/dev/null 2>&1
        sleep 3
        json_ok
    else
        if [ -f "$SINGBOX_SETTINGS" ]; then
            cat "$SINGBOX_SETTINGS"
        else
            echo '{"active_profile":"default","active_chain":"default","routing_mode":"proxy-list","upstream_ips":"","singbox_mode":"single"}'
        fi
    fi
    ;;

