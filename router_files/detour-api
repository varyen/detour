# ==================== PER-PROFILE PING (latency probe) ====================
# Lets the panel rank VPNs by ping. The cache is a flat TSV in tmpfs, one line
# per profile:  <id>\t<rtt_ms>\t<ok>\t<ts>\t<server>
#   rtt_ms : integer ms — ICMP RTT, or the TCP-handshake RTT when ICMP is
#            filtered (tcp_probe); -1 only when reachable but untimeable or not
#            yet measured.   ok : 1 reachable / 0 down.
# The panel calls ping_check for one profile at a time (round-robin, active VPN
# more often) so the box is never flooded; ping_status just reads the cache.
ping_status)
    NOW=$(date +%s 2>/dev/null); [ -z "$NOW" ] && NOW=0
    printf '{"now":%s,"results":{' "$NOW"
    if [ -f "$PING_DB" ]; then
        # $5 (server) is always a plain host/IP — emitted raw like vpn-keepalive does.
        awk -F'\t' 'BEGIN{first=1}
            NF>=4 {
                if(!first)printf ","; first=0;
                printf "\"%s\":{\"rtt\":%s,\"ok\":%s,\"ts\":%s,\"server\":\"%s\"}",
                    $1, ($2==""?-1:$2), ($3=="1"?"true":"false"), ($4==""?0:$4), $5;
            }' "$PING_DB"
    fi
    printf '}}'
    ;;

ping_check)
    PID_=$(echo "$QUERY_STRING" | sed -n 's/.*id=\([^&]*\).*/\1/p')
    PID_=$(sanitize_name "$PID_")
    if [ -z "$PID_" ]; then json_err "id required"; exit 0; fi
    PFILE="$SINGBOX_PROFILES_DIR/$PID_.json"
    if [ ! -f "$PFILE" ]; then json_err "profile not found"; exit 0; fi
    NOW=$(date +%s 2>/dev/null); [ -z "$NOW" ] && NOW=0
    PSRV=$(json_val "server" "$PFILE")
    PPORT=$(numeric_json_val "server_port" "$PFILE")
    PTYPE=$(json_val "type" "$PFILE")
    RTT=-1; OKV=0; METHOD="none"
    if [ -n "$PSRV" ]; then
        # ICMP gives latency + reachability in one shot (cheap, ~instant if up).
        # Retry once on an empty result: a single -c1 packet drops often enough
        # (loss, or a cold-DNS first lookup overrunning -W) to falsely mark a live
        # server as down — the retry kills those false negatives.
        PT=$(ping -c1 -W2 "$PSRV" 2>/dev/null | sed -n 's/.*time=\([0-9.]*\).*/\1/p' | head -1)
        [ -z "$PT" ] && PT=$(ping -c1 -W2 "$PSRV" 2>/dev/null | sed -n 's/.*time=\([0-9.]*\).*/\1/p' | head -1)
        if [ -n "$PT" ]; then
            RTT=$(echo "$PT" | awk '{printf "%.0f", $1}')
            OKV=1; METHOD="icmp"
        else
            # ICMP filtered → a TCP handshake gives BOTH reachability AND a real
            # latency number (one round-trip, comparable to the ICMP RTT), so the
            # panel shows "42 ms" instead of a bare tick for servers that drop ICMP.
            # TCP types only (UDP-based wireguard/hysteria2/tuic have no handshake).
            case "$PTYPE" in
                wireguard|hysteria2|tuic) : ;;
                *)
                    TR=$(tcp_probe "$PSRV" "$PPORT"); TRC=$?
                    if [ "$TRC" = "0" ]; then
                        OKV=1; METHOD="tcp"
                        case "$TR" in ''|*[!0-9]*) RTT=-1 ;; *) RTT="$TR" ;; esac
                    fi
                    ;;
            esac
        fi
    fi
    # Upsert this profile's line into the cache (drop old, append new, atomic mv).
    TMPDB="$PING_DB.$$"
    if [ -f "$PING_DB" ]; then
        awk -F'\t' -v id="$PID_" '$1!=id' "$PING_DB" > "$TMPDB" 2>/dev/null
    fi
    printf '%s\t%s\t%s\t%s\t%s\n' "$PID_" "$RTT" "$OKV" "$NOW" "$PSRV" >> "$TMPDB"
    mv "$TMPDB" "$PING_DB" 2>/dev/null
    OKJSON=false; [ "$OKV" = "1" ] && OKJSON=true
    printf '{"id":"%s","rtt":%s,"ok":%s,"ts":%s,"server":"%s","method":"%s"}' \
        "$PID_" "$RTT" "$OKJSON" "$NOW" "$(printf '%s' "$PSRV" | json_escape)" "$METHOD"
    ;;

# ==================== FUNCTIONAL HEALTH CHECK (real fetch through sing-box) ====================
# detour-health (staggered cron `tick`: each profile re-checked on its own random
# 45-60 min cadence) spins up a throwaway sing-box and does a REAL HTTP fetch of
# each target URL THROUGH every profile's outbound — catching "server pings but
# the site is dead at the egress" that ping_check cannot. These handlers
# are thin readers/controllers over its cache (HEALTH_DB), the editable target
# list (HEALTH_URLS), the auto-switch flags (settings.json) and a manual re-run.

health_status)
    NOW=$(date +%s 2>/dev/null); [ -z "$NOW" ] && NOW=0
    HEN=$(get_settings_val health_check_enabled); [ -z "$HEN" ] && HEN=1
    HAS=$(get_settings_val health_auto_switch);   [ -z "$HAS" ] && HAS=0
    HSP=$(get_settings_val health_speed_enabled); [ -z "$HSP" ] && HSP=1
    EN_J=true;  case "$HEN" in 0|off|false|no) EN_J=false ;; esac
    AS_J=false; case "$HAS" in 1|on|true|yes) AS_J=true ;; esac
    SP_J=true;  case "$HSP" in 0|off|false|no) SP_J=false ;; esac
    URLS_J=$(health_urls_json); [ -z "$URLS_J" ] && URLS_J='[]'
    SW_J=null; [ -f "$HEALTH_SWITCH" ] && SW_J=$(cat "$HEALTH_SWITCH" 2>/dev/null)
    [ -z "$SW_J" ] && SW_J=null
    HEALTHY_J=false; [ -x "$HEALTH_BIN" ] && [ ! -f "$HEALTH_UNSUPP" ] && HEALTHY_J=true
    printf '{"now":%s,"supported":%s,"enabled":%s,"auto_switch":%s,"speed":%s,"urls":%s,"switch":%s,"results":{' \
        "$NOW" "$HEALTHY_J" "$EN_J" "$AS_J" "$SP_J" "$URLS_J" "$SW_J"
    if [ -f "$HEALTH_DB" ]; then
        # TSV: id \t ok \t ts \t rtt \t delays(csv ms|-1) \t dl_kbits(optional). $5
        # has no tabs, so wrapping it in [] yields a JSON array; rebuild it to
        # normalise blanks. Field 6 (download kbit/s) is optional → default -1.
        awk -F'\t' 'BEGIN{first=1}
            NF>=5 {
                if(!first)printf ","; first=0;
                n=split($5,a,","); d="";
                for(i=1;i<=n;i++){ if(i>1)d=d","; v=a[i]; if(v=="")v="-1"; d=d v }
                dl=(NF>=6)?$6:"-1"; if(dl=="" || dl !~ /^-?[0-9]+$/) dl="-1";
                printf "\"%s\":{\"ok\":%s,\"ts\":%s,\"rtt\":%s,\"dl\":%s,\"delays\":[%s]}",
                    $1, ($2=="1"?"true":"false"), ($3==""?0:$3), ($4==""?-1:$4), dl, d;
            }' "$HEALTH_DB"
    fi
    printf '}}'
    ;;

# Manual re-check. POST with no body → kick a full background sweep (returns
# immediately; the panel polls health_status as lines land). POST id=<profile>
# → synchronous single-profile probe (~5-10s), returns that profile's fresh line.
health_check)
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    [ -x "$HEALTH_BIN" ] || { json_err "detour-health not installed"; exit 0; }
    HID=$(echo "$QUERY_STRING" | sed -n 's/.*id=\([^&]*\).*/\1/p')
    HID=$(sanitize_name "$HID")
    if [ -n "$HID" ]; then
        if [ ! -f "$SINGBOX_PROFILES_DIR/$HID.json" ]; then json_err "profile not found"; exit 0; fi
        LINE=$("$HEALTH_BIN" one "$HID" 2>/dev/null)
        OKV=$(printf '%s' "$LINE" | awk -F'\t' '{print $2}')
        TSV=$(printf '%s' "$LINE" | awk -F'\t' '{print $3}')
        RTTV=$(printf '%s' "$LINE" | awk -F'\t' '{print $4}')
        DLS=$(printf '%s' "$LINE" | awk -F'\t' '{print $5}')
        DLK=$(printf '%s' "$LINE" | awk -F'\t' '{print $6}')   # download kbit/s (optional)
        [ -z "$OKV" ] && OKV=0
        [ -z "$TSV" ] && TSV=0
        [ -z "$RTTV" ] && RTTV=-1
        [ -z "$DLS" ] && DLS=-1
        case "$DLK" in ''|*[!0-9-]*) DLK=-1 ;; esac
        OKJ=false; [ "$OKV" = "1" ] && OKJ=true
        printf '{"ok":true,"id":"%s","result":{"ok":%s,"ts":%s,"rtt":%s,"dl":%s,"delays":[%s]}}' \
            "$HID" "$OKJ" "$TSV" "$RTTV" "$DLK" "$DLS"
    else
        # Detach the full sweep so the request returns at once AND the sweep keeps
        # running after uhttpd reaps the CGI. A bare `&` is NOT enough: the child
        # gets SIGHUP when the CGI exits and dies mid-sweep (no setsid on this
        # busybox). start-stop-daemon -b reparents it into its own session (the same
        # mechanism S90detour-cron uses), so it survives; fallbacks for other envs.
        if command -v start-stop-daemon >/dev/null 2>&1; then
            start-stop-daemon -S -q -b -x "$HEALTH_BIN" -- sweep >/dev/null 2>&1
        elif command -v setsid >/dev/null 2>&1; then
            setsid "$HEALTH_BIN" sweep >/dev/null 2>&1 &
        else
            "$HEALTH_BIN" sweep </dev/null >/dev/null 2>&1 &
        fi
        printf '{"ok":true,"started":true}'
    fi
    ;;

# GET → raw target list (one "label|url" per line); POST body replaces it. The
# panel edits it as a textarea. Saved verbatim; detour-health/health_urls_json
# parse it. Empty/invalid lines are ignored at read time.
health_urls)
    if [ "$REQUEST_METHOD" = "POST" ]; then
        printf '%s' "$POST_DATA" > "$HEALTH_URLS"
        json_ok
    else
        if [ -f "$HEALTH_URLS" ]; then
            printf '{"list":"%s"}' "$(cat "$HEALTH_URLS" | json_escape)"
        else
            printf '{"list":""}'
        fi
    fi
    ;;

# Toggle the two health flags WITHOUT a sing-box restart. POST {"enabled":0|1,
# "auto_switch":0|1} (missing key keeps its current value). write_settings
# re-emits the whole settings file (preserving the rest) with our overrides.
health_config)
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    NEW_EN=$(printf '%s' "$POST_DATA" | sed -n 's/.*"enabled"[[:space:]]*:[[:space:]]*"\{0,1\}\([01]\)"\{0,1\}.*/\1/p' | head -1)
    NEW_AS=$(printf '%s' "$POST_DATA" | sed -n 's/.*"auto_switch"[[:space:]]*:[[:space:]]*"\{0,1\}\([01]\)"\{0,1\}.*/\1/p' | head -1)
    NEW_SP=$(printf '%s' "$POST_DATA" | sed -n 's/.*"speed"[[:space:]]*:[[:space:]]*"\{0,1\}\([01]\)"\{0,1\}.*/\1/p' | head -1)
    CUR_EN=$(get_settings_val health_check_enabled); [ -z "$CUR_EN" ] && CUR_EN=1
    CUR_AS=$(get_settings_val health_auto_switch);   [ -z "$CUR_AS" ] && CUR_AS=0
    CUR_SP=$(get_settings_val health_speed_enabled); [ -z "$CUR_SP" ] && CUR_SP=1
    [ -z "$NEW_EN" ] && NEW_EN="$CUR_EN"
    [ -z "$NEW_AS" ] && NEW_AS="$CUR_AS"
    [ -z "$NEW_SP" ] && NEW_SP="$CUR_SP"
    ACHAIN=$(get_active_chain)
    RMODE=$(get_routing_mode)
    UPSTREAM=$(get_settings_val upstream_ips)
    SBMODE=$(get_singbox_mode)
    HEALTH_ENABLED_OVERRIDE="$NEW_EN" HEALTH_AUTOSWITCH_OVERRIDE="$NEW_AS" \
        HEALTH_SPEED_OVERRIDE="$NEW_SP" \
        write_settings "$ACHAIN" "$RMODE" "$UPSTREAM" "$SBMODE"
    printf '{"ok":true,"enabled":%s,"auto_switch":%s,"speed":%s}' \
        "$([ "$NEW_EN" = "1" ] && echo true || echo false)" \
        "$([ "$NEW_AS" = "1" ] && echo true || echo false)" \
        "$([ "$NEW_SP" = "1" ] && echo true || echo false)"
    ;;

# Syslog log-bridge toggles. GET → current state; POST {"enabled":0|1,"singbox":0|1}
# (missing key keeps its current value). write_settings re-emits the whole settings
# file with our overrides, then we (re)start/stop the bridge to match. No proxy
# restart — this only governs the decoupled tail→logger forwarder.
log_config)
    if [ "$REQUEST_METHOD" = "POST" ]; then
        NEW_EN=$(printf '%s' "$POST_DATA" | sed -n 's/.*"enabled"[[:space:]]*:[[:space:]]*"\{0,1\}\([01]\)"\{0,1\}.*/\1/p' | head -1)
        NEW_SB=$(printf '%s' "$POST_DATA" | sed -n 's/.*"singbox"[[:space:]]*:[[:space:]]*"\{0,1\}\([01]\)"\{0,1\}.*/\1/p' | head -1)
        CUR_EN=$(get_settings_val log_to_syslog);         [ -z "$CUR_EN" ] && CUR_EN=0
        CUR_SB=$(get_settings_val log_to_syslog_singbox); [ -z "$CUR_SB" ] && CUR_SB=0
        [ -z "$NEW_EN" ] && NEW_EN="$CUR_EN"
        [ -z "$NEW_SB" ] && NEW_SB="$CUR_SB"
        ACHAIN=$(get_active_chain)
        RMODE=$(get_routing_mode)
        UPSTREAM=$(get_settings_val upstream_ips)
        SBMODE=$(get_singbox_mode)
        LOG_SYSLOG_OVERRIDE="$NEW_EN" LOG_SYSLOG_SB_OVERRIDE="$NEW_SB" \
            write_settings "$ACHAIN" "$RMODE" "$UPSTREAM" "$SBMODE"
        # restart picks up the freshly-written settings: starts the bridge (master
        # on) or no-ops/stops it (master off). Backgrounded so the toggle response
        # isn't held by start-stop-daemon. Init is always present (enabled at install).
        [ -x "$LOGBRIDGE_INITD" ] && "$LOGBRIDGE_INITD" restart >/dev/null 2>&1 &
        printf '{"ok":true,"enabled":%s,"singbox":%s}' \
            "$([ "$NEW_EN" = "1" ] && echo true || echo false)" \
            "$([ "$NEW_SB" = "1" ] && echo true || echo false)"
    else
        CUR_EN=$(get_settings_val log_to_syslog);         [ -z "$CUR_EN" ] && CUR_EN=0
        CUR_SB=$(get_settings_val log_to_syslog_singbox); [ -z "$CUR_SB" ] && CUR_SB=0
        printf '{"enabled":%s,"singbox":%s}' \
            "$([ "$CUR_EN" = "1" ] && echo true || echo false)" \
            "$([ "$CUR_SB" = "1" ] && echo true || echo false)"
    fi
    ;;

# ==================== PANEL SELF-UPDATE ====================
panel_update_status)
    if [ -f "$UPDATE_STATE" ]; then
        cat "$UPDATE_STATE"
    else
        echo '{"status":"unknown","message":"no state yet"}'
    fi
    ;;

panel_update_check)
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    [ -x "$UPDATE_BIN" ] || { json_err "updater not installed"; exit 0; }
    # Honor the updater's exit code. On failure (e.g. GitHub/DNS unreachable)
    # `detour-update check` dies WITHOUT rewriting the state file, so catting it
    # would surface the PREVIOUS check's result — a phantom "update available"
    # left over from before the last install. Report the failure instead.
    if OUT=$("$UPDATE_BIN" check 2>&1); then
        if [ -f "$UPDATE_STATE" ]; then cat "$UPDATE_STATE"
        else printf '{"status":"error","message":"%s"}' "$(printf '%s' "$OUT" | tail -5 | json_escape)"; fi
    else
        printf '{"status":"error","message":"проверка не удалась: %s"}' "$(printf '%s' "$OUT" | tail -5 | json_escape)"
    fi
    ;;

panel_update_apply)
    # Install the latest signed release straight from GitHub via opkg. Runs DETACHED
    # on BOTH platforms with all output streamed to the live apply log (apply_log),
    # so the panel shows the installer log in real time — same UX as the binary
    # updates (bins/tpws/nfqws2). The detached worker survives even the panel's own
    # restart, so the .ipk install can never be killed by an HTTP/proxy timeout.
    #   - Keenetic: detaching is mandatory — the install would otherwise be killed when
    #     S51detour-panel (the lighttpd hosting this CGI) restarts. The SELFUPDATE_MARK
    #     tells the package prerm/postinst to keep that lighttpd serving for the whole
    #     install and restart it only at the very end, so apply_log streams live.
    #   - OpenWrt: the panel rides the system uhttpd (NOT restarted by the install —
    #     see postinst), so this CGI stays reachable throughout.
    # Both platforms then drive completion/reload straight from the log's exit-code
    # sentinel (the state-file poll is only a Keenetic fallback — see index.html).
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    [ -x "$UPDATE_BIN" ] || { json_err "updater not installed"; exit 0; }
    [ "$PLATFORM" = keenetic ] && : > "$SELFUPDATE_MARK" 2>/dev/null
    : > "$APPLY_LOG" 2>/dev/null
    detach_bg "$APPLY_LOG" "\"$UPDATE_BIN\" apply; echo \"$APPLY_DONE_MARK rc=\$?\""
    printf '{"ok":true,"status":"updating"}'
    ;;

autocheck_status)
    # Read-only: is the unattended 6h auto-check cron installed? (default: no)
    if [ -x "$UPDATE_BIN" ]; then
        "$UPDATE_BIN" autocheck status 2>/dev/null || printf '{"enabled":false}'
    else
        printf '{"enabled":false}'
    fi
    ;;

autocheck_set)
    # Toggle the unattended 6h auto-check cron. Body: {"enabled":true|false}.
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    [ -x "$UPDATE_BIN" ] || { json_err "updater not installed"; exit 0; }
    case "$POST_DATA" in
        *'"enabled":true'*|*'"enabled": true'*)   AC_MODE=on ;;
        *'"enabled":false'*|*'"enabled": false'*) AC_MODE=off ;;
        *) json_err "enabled bool required"; exit 0 ;;
    esac
    OUT=$("$UPDATE_BIN" autocheck "$AC_MODE" 2>&1)
    if [ $? -eq 0 ]; then
        "$UPDATE_BIN" autocheck status 2>/dev/null
    else
        json_err "$(printf '%s' "$OUT" | tail -5 | json_escape)"
    fi
    ;;

panel_update_sig)
    # Step 1 of a local .ipk install: store the (small, text) usign signature.
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    printf '%s' "$POST_DATA" > /tmp/detour-upload.ipk.sig
    json_ok
    ;;

panel_update_local)
    # Step 2: install the streamed .ipk (body already written to /tmp by the
    # POST reader above). apply-local verifies the usign signature next to it.
    # Runs DETACHED on BOTH platforms, streaming to the live apply log (apply_log)
    # so the UI shows the install output in real time (see panel_update_apply for
    # the per-platform rationale). The .ipk is already fully on disk; the worker
    # removes it after installing.
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    IPK=/tmp/detour-upload.ipk
    SIG=/tmp/detour-upload.ipk.sig
    if [ ! -s "$IPK" ]; then json_err "no .ipk uploaded"; exit 0; fi
    # Pick the install command: signed via the updater (usign-verify + rollback),
    # else a plain opkg install (operator opted out of the signature, e.g. Keenetic).
    if [ -x "$UPDATE_BIN" ] && [ -s "$SIG" ]; then
        INSTALL_CMD="\"$UPDATE_BIN\" apply-local \"$IPK\""
    else
        INSTALL_CMD="opkg install --force-reinstall \"$IPK\""
    fi
    # Keenetic: keep the panel's lighttpd serving across the install (see panel_update_apply).
    [ "$PLATFORM" = keenetic ] && : > "$SELFUPDATE_MARK" 2>/dev/null
    : > "$APPLY_LOG" 2>/dev/null
    detach_bg "$APPLY_LOG" "$INSTALL_CMD; _rc=\$?; rm -f \"$IPK\" \"$SIG\"; echo \"$APPLY_DONE_MARK rc=\$_rc\""
    printf '{"ok":true,"status":"updating"}'
    ;;

# ==================== sing-box UPDATE (opkg feed) ====================
# sing-box is pulled from our opkg feed (OpenWrt) via detour-update bins-*; the
# state file keeps the legacy {current,available} keys so the UI is unchanged.
bins_update_status)
    if [ -f "$BINS_STATE" ]; then
        cat "$BINS_STATE"
    else
        echo '{"status":"unknown","message":"no bins state yet"}'
    fi
    ;;

bins_update_check)
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    [ -x "$UPDATE_BIN" ] || { json_err "updater not installed"; exit 0; }
    # Honor the updater's exit code (see panel_update_check) — don't pass off the
    # previous bins-check state as a fresh result when the check actually failed.
    if OUT=$("$UPDATE_BIN" bins-check 2>&1); then
        if [ -f "$BINS_STATE" ]; then cat "$BINS_STATE"
        else printf '{"status":"error","message":"%s"}' "$(printf '%s' "$OUT" | tail -5 | json_escape)"; fi
    else
        printf '{"status":"error","message":"проверка не удалась: %s"}' "$(printf '%s' "$OUT" | tail -5 | json_escape)"
    fi
    ;;

bins_update_apply)
    # opkg update + upgrade sing-box from our feed (via the updater). Runs detached
    # with a live log (apply_log) — see start_apply.
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    [ -x "$UPDATE_BIN" ] || { json_err "updater not installed"; exit 0; }
    start_apply "\"$UPDATE_BIN\" bins-apply"
    ;;

# ==================== tpws-zapret UPDATE (opkg feed) ====================
# tpws-zapret is pulled from the same opkg feed via detour-update tpws-*; the
# state file mirrors the sing-box {current,available} shape so the UI is uniform.
tpws_update_status)
    if [ -f "$TPWS_STATE" ]; then
