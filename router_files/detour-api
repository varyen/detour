iptables)
    NAT=$(iptables -t nat -L PREROUTING -v -n 2>/dev/null | json_escape)
    NFT=$(nft list chain inet fw4 input_lan 2>/dev/null | json_escape)
    printf '{"nat":"%s","nft":"%s"}' "$NAT" "$NFT"
