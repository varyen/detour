# ==================== nfqws2 / zapret2 UPDATE (opkg feed) ====================
# nfqws2 (zapret2) is pulled from the same opkg feed via detour-update nfqws2-*;
# the state file mirrors the sing-box/tpws {current,available} shape. zapret2 is
# OpenWrt-only — on Keenetic nfqws2-check writes {"current":"n/a",...} and apply errors.
nfqws2_update_status)
    if [ -f "$NFQWS2_STATE" ]; then
        cat "$NFQWS2_STATE"
    else
        echo '{"status":"unknown","message":"no nfqws2 state yet"}'
    fi
    ;;

nfqws2_update_check)
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    [ -x "$UPDATE_BIN" ] || { json_err "updater not installed"; exit 0; }
    if OUT=$("$UPDATE_BIN" nfqws2-check 2>&1); then
        if [ -f "$NFQWS2_STATE" ]; then cat "$NFQWS2_STATE"
        else printf '{"status":"error","message":"%s"}' "$(printf '%s' "$OUT" | tail -5 | json_escape)"; fi
    else
        printf '{"status":"error","message":"проверка не удалась: %s"}' "$(printf '%s' "$OUT" | tail -5 | json_escape)"
    fi
    ;;

nfqws2_update_apply)
    # opkg update + upgrade nfqws2 from our feed (via the updater). Detached + live
    # log (apply_log).
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    [ -x "$UPDATE_BIN" ] || { json_err "updater not installed"; exit 0; }
    start_apply "\"$UPDATE_BIN\" nfqws2-apply"
    ;;

apply_log)
    # Live tail of the detached apply log + completion flag. lua-cjson does the JSON
    # string escaping so multi-line opkg output round-trips safely. Empty/no file →
    # done:false with an empty log (nothing has run yet).
    lua - "$APPLY_LOG" "$APPLY_DONE_MARK" <<'LUA' 2>/dev/null
local cjson = require("cjson.safe")
local path, mark = arg[1], arg[2]
local f = io.open(path, "r")
local s = f and f:read("*a") or ""
if f then f:close() end
local done, rc = false, ""
local i = s:find(mark, 1, true)
if i then
    done = true
    rc = s:match(mark .. " rc=(%d+)") or ""
    s = s:sub(1, i - 1)   -- drop the sentinel line (and anything after it)
end
io.write(cjson.encode({ ok = true, done = done, rc = rc, log = s }) or '{"ok":false}')
LUA
    ;;

# Combined update overview — the panel polls this on load / every refresh to blink
# any stale version chip. Reads only the cached state files (written by
# `detour-update check-all` every 6h); never spawns a live GitHub/opkg query.
updates_overview)
    # feed_upd <statefile> → "true"/"false": an update is pending when the cached
    # `available` differs from `current` and is a real version (not ?, n/a, empty).
    feed_upd() {
        local f="$1" cur avail
        [ -f "$f" ] || { echo false; return; }
        cur=$(json_val current "$f"); avail=$(json_val available "$f")
        if [ -n "$avail" ] && [ "$avail" != "?" ] && [ "$avail" != "n/a" ] && [ "$avail" != "$cur" ]; then
            echo true
        else
            echo false
        fi
    }
    P_STATUS=""; P_AVAIL=""
    if [ -f "$UPDATE_STATE" ]; then
        P_STATUS=$(json_val status "$UPDATE_STATE")
        P_AVAIL=$(json_val available_version "$UPDATE_STATE")
    fi
    # up_ver  → latest upstream version string (detour-update's GitHub probe).
    # up_new  → "true"/"false": upstream is newer than installed AND the feed has
    #           NOT caught up yet (so it's an info-only "вышла на GitHub" signal,
    #           distinct from feed update_available). upstream_newer is an UNQUOTED
    #           JSON bool, so json_val (quoted-only) can't read it — match it directly.
    up_ver() { [ -f "$1" ] && json_val upstream "$1" || true; }
    up_new() {
        local v
        [ -f "$1" ] || { echo false; return; }
        v=$(sed -n 's/.*"upstream_newer"[[:space:]]*:[[:space:]]*\(true\|false\).*/\1/p' "$1" | head -1)
        # Suppress when the feed already offers the upgrade — green chip wins.
        if [ "$v" = true ] && [ "$(feed_upd "$1")" != true ]; then echo true; else echo false; fi
    }
    P_UPD=false; [ "$P_STATUS" = "update_available" ] && P_UPD=true
    SB_UPD=$(feed_upd "$BINS_STATE")
    TPWS_UPD=$(feed_upd "$TPWS_STATE")
    NFQWS2_UPD=$(feed_upd "$NFQWS2_STATE")
    SB_UPV=$(up_ver "$BINS_STATE");   SB_UPN=$(up_new "$BINS_STATE")
    TPWS_UPV=$(up_ver "$TPWS_STATE"); TPWS_UPN=$(up_new "$TPWS_STATE")
    NFQWS2_UPV=$(up_ver "$NFQWS2_STATE"); NFQWS2_UPN=$(up_new "$NFQWS2_STATE")
    printf '{"panel":{"update_available":%s,"available_version":"%s"},"singbox":{"update_available":%s,"upstream":"%s","upstream_newer":%s},"tpws":{"update_available":%s,"upstream":"%s","upstream_newer":%s},"nfqws2":{"update_available":%s,"upstream":"%s","upstream_newer":%s}}\n' \
        "$P_UPD" "$P_AVAIL" \
        "$SB_UPD" "$SB_UPV" "$SB_UPN" \
        "$TPWS_UPD" "$TPWS_UPV" "$TPWS_UPN" \
        "$NFQWS2_UPD" "$NFQWS2_UPV" "$NFQWS2_UPN"
    ;;

# ==================== DPI-BYPASS ENGINE SWITCH (zapret | zapret2 | off) ====================
# detour-bypass owns the mutually-exclusive engine selection + persistent state
# (/etc/detour/bypass.{mode,autostart}). zapret2 is OpenWrt-only (needs NFQUEUE).
bypass_status)
    if [ -x "$BYPASS_BIN" ]; then
        "$BYPASS_BIN" status
    else
        echo '{"mode":"off","autostart":0,"running":"none","zapret2_supported":false,"platform":"unknown"}'
    fi
    ;;

bypass_set)
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    [ -x "$BYPASS_BIN" ] || { json_err "detour-bypass not installed"; exit 0; }
    BMODE=$(echo "$QUERY_STRING" | sed -n 's/.*[?&]mode=\([^&]*\).*/\1/p' | head -1)
    case "$BMODE" in off|zapret|zapret2) ;; *) json_err "invalid mode (off|zapret|zapret2)"; exit 0 ;; esac
    OUT=$("$BYPASS_BIN" set "$BMODE" 2>&1)
    if [ $? -eq 0 ]; then
        printf '{"ok":true,"mode":"%s"}' "$BMODE"
    else
        json_err "$(printf '%s' "$OUT" | tail -8 | json_escape)"
    fi
    ;;

bypass_stop)
    # Stop the running engine but KEEP the persisted mode (selected engine), so
    # the UI shows the sing-box-style Старт/Стоп toggle (stopped → ▶ Старт).
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    [ -x "$BYPASS_BIN" ] || { json_err "detour-bypass not installed"; exit 0; }
    OUT=$("$BYPASS_BIN" stop 2>&1)
    if [ $? -eq 0 ]; then json_ok; else json_err "$(printf '%s' "$OUT" | tail -8 | json_escape)"; fi
    ;;

bypass_autostart)
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    [ -x "$BYPASS_BIN" ] || { json_err "detour-bypass not installed"; exit 0; }
    BON=$(echo "$QUERY_STRING" | sed -n 's/.*[?&]on=\([^&]*\).*/\1/p' | head -1)
    case "$BON" in 1|on) BV=on ;; 0|off) BV=off ;; *) json_err "invalid on flag (0|1)"; exit 0 ;; esac
    OUT=$("$BYPASS_BIN" autostart "$BV" 2>&1)
    if [ $? -eq 0 ]; then json_ok; else json_err "$(printf '%s' "$OUT" | tail -5 | json_escape)"; fi
    ;;

bypass_strategy)
    # GET: echo the stored nfqws2 strategy (empty → UI uses status.strategy default).
    # POST (body = one-line arg string): save it and re-apply if zapret2 is active.
    if [ "$REQUEST_METHOD" != "POST" ]; then
        head -1 "$BYPASS_STRATEGY_FILE" 2>/dev/null || echo ""
        exit 0
    fi
    [ -x "$BYPASS_BIN" ] || { json_err "detour-bypass not installed"; exit 0; }
    S=$(printf '%s' "$POST_DATA" | head -1 | tr -d '\r')
    [ -n "$S" ] || { json_err "empty strategy"; exit 0; }
    case "$S" in *--lua-desync=*) ;; *) json_err "стратегия должна содержать --lua-desync=..."; exit 0 ;; esac
    mkdir -p "$(dirname "$BYPASS_STRATEGY_FILE")" 2>/dev/null
    printf '%s\n' "$S" > "$BYPASS_STRATEGY_FILE"
    if [ "$("$BYPASS_BIN" mode 2>/dev/null)" = zapret2 ]; then
        OUT=$("$BYPASS_BIN" set zapret2 2>&1)
        [ $? -eq 0 ] || { json_err "$(printf '%s' "$OUT" | tail -6 | json_escape)"; exit 0; }
    fi
    json_ok
    ;;

singbox_opkg_upgrade)
    # Keenetic/Entware: pull the latest sing-box from Entware (sing-box-go), re-disable
    # the package's own auto-start, then restart our service. Runs DETACHED with a live
    # log (apply_log) so the panel streams opkg output in real time — same UX as the
    # OpenWrt feed applies. sing-box's restart doesn't touch the panel's lighttpd, so
    # this CGI survives; detaching also keeps a slow opkg run off the HTTP timeout
    # (previously the synchronous run could truncate as «Unexpected end of JSON input»).
    # The sentinel rc reflects `opkg upgrade`, not the trailing restart/bins-check.
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    command -v opkg >/dev/null 2>&1 || { json_err "opkg not available"; exit 0; }
    SB_CMD="opkg update; echo '--- opkg upgrade sing-box-go ---'; opkg upgrade sing-box-go; SB_RC=\$?;"
    SB_CMD="$SB_CMD if [ -f /opt/etc/init.d/S99sing-box ]; then /opt/etc/init.d/S99sing-box stop 2>/dev/null; chmod 0644 /opt/etc/init.d/S99sing-box 2>/dev/null; fi;"
    SB_CMD="$SB_CMD $SINGBOX_INITD restart >/dev/null 2>&1; \"$UPDATE_BIN\" bins-check >/dev/null 2>&1; [ \"\$SB_RC\" = 0 ]"
    start_apply "$SB_CMD"
    ;;

singbox_config)
    if [ "$REQUEST_METHOD" = "POST" ]; then
        echo "$POST_DATA" > "$SINGBOX_CONFIG"
        RESULT=$($SINGBOX_BIN check -c "$SINGBOX_CONFIG" 2>&1)
        if [ $? -eq 0 ]; then
            json_ok
        else
            ERRMSG=$(echo "$RESULT" | json_escape)
            json_err "$ERRMSG"
        fi
    else
        cat "$SINGBOX_CONFIG"
    fi
    ;;

singbox_start)  $SINGBOX_INITD $SVC_START >/dev/null 2>&1; sleep 2; json_ok ;;
singbox_stop)   $SINGBOX_INITD stop >/dev/null 2>&1; sleep 1; json_ok ;;
singbox_restart) $SINGBOX_INITD restart >/dev/null 2>&1; sleep 3; json_ok ;;
singbox_enable) $SINGBOX_INITD enable >/dev/null 2>&1; set_autostart singbox 1; json_ok ;;
singbox_disable) $SINGBOX_INITD disable >/dev/null 2>&1; set_autostart singbox 0; json_ok ;;

singbox_log)
    if [ -f "$SINGBOX_LOG" ]; then
        LOG=$(tail -100 "$SINGBOX_LOG" | json_escape)
        printf '{"log":"%s"}' "$LOG"
    else
        echo '{"log":"(no log file)"}'
    fi
    ;;

singbox_log_clear) > "$SINGBOX_LOG" 2>/dev/null; json_ok ;;

