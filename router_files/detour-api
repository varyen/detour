# Emit the configured health targets as a JSON array [{label,url},...], falling
# back to the built-in defaults detour-health uses when the list file is absent.
# (Defined here, outside the case, so the health_status branch can call it.)
health_urls_json() {
    lua - "$HEALTH_URLS" <<'LUA' 2>/dev/null
local cjson = require("cjson.safe")
local f = io.open(arg[1], "r")
local urls = {}
if f then
  for line in f:lines() do
    line = line:gsub("^%s+",""):gsub("%s+$","")
    if line ~= "" and line:sub(1,1) ~= "#" then
      local label, u = line:match("^(.-)%s*|%s*(.+)$")
      if not u then u = line; label = nil end
      if u:match("^https?://") then
        if not label or label == "" then label = (u:match("^https?://([^/]+)") or u) end
        urls[#urls+1] = { label = label, url = u }
      end
    end
  end
