panel_export_config)
    # Bundle global panel state into one JSON envelope so the operator can
    # back it up before reflashing or migrate to a new router. VPN profiles
    # are NOT included here — they have their own profiles_export action.
    # Sensitive credentials (panel auth, GH token) are also excluded.
    NOW=$(date -u "+%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || date -u +%Y-%m-%dT%H:%M:%SZ)
    PA_VER=$(cat /etc/detour/version 2>/dev/null)
    printf '{"version":1,"exported_at":"%s","router_version":"%s","settings":' \
        "$NOW" "$(printf '%s' "$PA_VER" | json_escape)"
    if [ -f /etc/sing-box/settings.json ]; then cat /etc/sing-box/settings.json
    else printf '{}'; fi
    printf ',"subscription":'
    if [ -f /etc/detour/subscription.json ]; then cat /etc/detour/subscription.json
    else printf '{}'; fi
    printf ',"proxy_domains":"'
    [ -f /etc/sing-box/proxy-domains.list ] && cat /etc/sing-box/proxy-domains.list | json_escape
    printf '","whitelist_domains":"'
    [ -f /etc/sing-box/whitelist-domains.list ] && cat /etc/sing-box/whitelist-domains.list | json_escape
    printf '","zapret_conf":"'
    [ -f /etc/zapret-tpws.conf ] && cat /etc/zapret-tpws.conf | json_escape
    printf '","zapret_domains":"'
    [ -f /etc/zapret-tpws/domains.list ] && cat /etc/zapret-tpws/domains.list | json_escape
    printf '"}'
    ;;

panel_import_config)
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    # Use Lua + cjson to safely parse and write each section. Plain sed can't
    # handle nested JSON or multi-MB domain lists reliably.
    IMPORT_TMP=$(mktemp)
    printf '%s' "$POST_DATA" > "$IMPORT_TMP"
    if ! lua - "$IMPORT_TMP" <<'LUA'
local cjson = require("cjson.safe")
local f = io.open(arg[1], "r"); if not f then os.exit(1) end
local raw = f:read("*a"); f:close()
local doc = cjson.decode(raw)
if not doc or type(doc) ~= "table" then os.exit(2) end

-- Hard rejection list. These keys ARE NOT processed by this endpoint and
-- MUST NEVER be — they would let a forged config file overwrite panel auth
-- or the GitHub token. Use panel_change_password / deploy_router.py instead.
local FORBIDDEN = {
    auth=true, password=true, passwd=true, panel_user=true, panel_password=true,
    update_conf=true, gh_token=true, gh_owner=true, gh_repo=true,
}
for k in pairs(doc) do
    if FORBIDDEN[k] then
        io.stderr:write("FORBIDDEN_KEY:" .. k .. "\n")
        os.exit(3)
    end
end

local function atomic_write(path, body, mode)
    if body == nil then return end
    local tmp = path .. ".import.tmp"
    local w = io.open(tmp, "w"); if not w then return end
    w:write(body); w:close()
    if mode then os.execute("chmod " .. mode .. " " .. tmp) end
    os.rename(tmp, path)
end

if type(doc.settings) == "table" then
    atomic_write("/etc/sing-box/settings.json", cjson.encode(doc.settings), "0644")
end
if type(doc.subscription) == "table" and next(doc.subscription) then
    os.execute("mkdir -p /etc/detour")
    atomic_write("/etc/detour/subscription.json", cjson.encode(doc.subscription), "0600")
end
if type(doc.proxy_domains) == "string" and #doc.proxy_domains > 0 then
    atomic_write("/etc/sing-box/proxy-domains.list", doc.proxy_domains, "0644")
end
if type(doc.whitelist_domains) == "string" and #doc.whitelist_domains > 0 then
    atomic_write("/etc/sing-box/whitelist-domains.list", doc.whitelist_domains, "0644")
end
if type(doc.zapret_conf) == "string" and #doc.zapret_conf > 0 then
    atomic_write("/etc/zapret-tpws.conf", doc.zapret_conf, "0644")
end
if type(doc.zapret_domains) == "string" and #doc.zapret_domains > 0 then
    os.execute("mkdir -p /etc/zapret-tpws")
    atomic_write("/etc/zapret-tpws/domains.list", doc.zapret_domains, "0644")
end
os.exit(0)
LUA
    then
        # Lua exit codes:  3 = forbidden key seen, 2 = invalid JSON, 1 = io error.
        IMPORT_EC=$?
        IMPORT_BAD_KEY=$(lua - "$IMPORT_TMP" 2>&1 >/dev/null <<'LUA' || true
local cjson = require("cjson.safe")
local f = io.open(arg[1], "r"); if not f then os.exit() end
local doc = cjson.decode(f:read("*a")) or {}
local FORBIDDEN = {
    auth=true, password=true, passwd=true, panel_user=true, panel_password=true,
    update_conf=true, gh_token=true, gh_owner=true, gh_repo=true,
}
if type(doc) == "table" then
    for k in pairs(doc) do if FORBIDDEN[k] then io.stderr:write(k); break end end
end
LUA
)
        rm -f "$IMPORT_TMP"
        if [ -n "$IMPORT_BAD_KEY" ]; then
            json_err "forbidden key in config: $IMPORT_BAD_KEY (panel auth / GH token cannot be set via this endpoint — use the Change-password modal or deploy_router.py)"
        elif [ "$IMPORT_EC" = "2" ]; then
            json_err "config is not a valid JSON object"
        else
            json_err "config import failed (exit $IMPORT_EC)"
        fi
        exit 0
    fi
    rm -f "$IMPORT_TMP"
    # Restart services so the new domain lists + settings take effect.
    $SINGBOX_INITD restart >/dev/null 2>&1 &
    json_ok
    ;;

panel_change_password)
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    # Body: {"old_password":"...","new_password":"...","new_user":"..."}
    # new_user is optional — when present, renames the panel account.
    OLD_PW=$(printf '%s' "$POST_DATA" | sed -n 's/.*"old_password"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)
    NEW_PW=$(printf '%s' "$POST_DATA" | sed -n 's/.*"new_password"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)
    NEW_USER=$(printf '%s' "$POST_DATA" | sed -n 's/.*"new_user"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)
    if [ -z "$NEW_PW" ]; then json_err "new_password required"; exit 0; fi
    if [ "${#NEW_PW}" -lt 8 ]; then json_err "password must be at least 8 chars"; exit 0; fi
    # Identify current user from the active session cookie.
    SESSION_USER=""
    TOKEN=$(get_session_token)
    [ -n "$TOKEN" ] && [ -f "$SESSION_DIR/$TOKEN" ] && SESSION_USER=$(cat "$SESSION_DIR/$TOKEN")
    if [ -z "$SESSION_USER" ]; then json_err "no active session"; exit 0; fi
    if ! verify_password "$SESSION_USER" "$OLD_PW"; then
        sleep 1
        json_err "old password is incorrect"
        exit 0
    fi
    # Validate optional new username (same rules as first-install setup).
    EFFECTIVE_USER="$SESSION_USER"
    if [ -n "$NEW_USER" ] && [ "$NEW_USER" != "$SESSION_USER" ]; then
        case "$NEW_USER" in
            *[!a-zA-Z0-9._-]*) json_err "username: only a-z, A-Z, 0-9, ._- allowed"; exit 0 ;;
        esac
        if [ "${#NEW_USER}" -lt 2 ] || [ "${#NEW_USER}" -gt 32 ]; then
            json_err "username must be 2..32 chars"; exit 0
        fi
        EFFECTIVE_USER="$NEW_USER"
    fi
    NEW_HASH=$(printf '%s' "$NEW_PW" | openssl passwd -6 -stdin 2>/dev/null)
    if [ -z "$NEW_HASH" ]; then json_err "openssl hash failed"; exit 0; fi
    # Atomic replacement to avoid windowed half-write on the auth file.
    TMP_AUTH=$(mktemp)
    printf '%s:%s\n' "$EFFECTIVE_USER" "$NEW_HASH" > "$TMP_AUTH"
    chmod 0600 "$TMP_AUTH"
    mv "$TMP_AUTH" "$AUTH_FILE"
    # If username changed, drop ALL sessions (including current) — operator
    # must log in with the new credentials. Otherwise just invalidate peers.
    if [ "$EFFECTIVE_USER" != "$SESSION_USER" ]; then
        rm -f "$SESSION_DIR"/* 2>/dev/null
        printf '{"ok":true,"user_changed":true}'
    else
        for sess in "$SESSION_DIR"/*; do
            [ "$sess" = "$SESSION_DIR/$TOKEN" ] && continue
            rm -f "$sess" 2>/dev/null
        done
        json_ok
    fi
    ;;

*) json_err "unknown action: $ACTION" ;;

esac