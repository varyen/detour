allvpn_on)
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    SB_PID=$(pgrep -f "$SINGBOX_BIN" 2>/dev/null | head -1)
    if [ -z "$SB_PID" ]; then json_err "sing-box is not running"; exit 0; fi
    UPSTREAM_IPS=$(get_upstream_ips)
    iptables -t nat -N SINGBOX_ALLVPN 2>/dev/null
    iptables -t nat -F SINGBOX_ALLVPN
    iptables -t nat -A SINGBOX_ALLVPN -d 10.0.0.0/8 -j RETURN
    iptables -t nat -A SINGBOX_ALLVPN -d 172.16.0.0/12 -j RETURN
    iptables -t nat -A SINGBOX_ALLVPN -d 192.168.0.0/16 -j RETURN
    iptables -t nat -A SINGBOX_ALLVPN -d 127.0.0.0/8 -j RETURN
    if [ -n "$UPSTREAM_IPS" ]; then
        OLD_IFS="$IFS"
        IFS=','
        set -- $UPSTREAM_IPS
        IFS="$OLD_IFS"
        for ip in "$@"; do
            [ -n "$ip" ] && iptables -t nat -A SINGBOX_ALLVPN -d "$ip" -j RETURN
        done
    fi
    iptables -t nat -A SINGBOX_ALLVPN -p tcp -j REDIRECT --to-ports 12345
    iptables -t nat -D PREROUTING -i $LAN_IF -j SINGBOX_ALLVPN 2>/dev/null
    iptables -t nat -I PREROUTING 1 -i $LAN_IF -j SINGBOX_ALLVPN
    # Force VPN road-warrior interfaces through the proxy too (same as LAN).
    for VIF in $(vpn_redirect_ifaces); do
        [ -n "$VIF" ] || continue
        iptables -t nat -D PREROUTING -i "$VIF" -j SINGBOX_ALLVPN 2>/dev/null
        iptables -t nat -I PREROUTING 1 -i "$VIF" -j SINGBOX_ALLVPN
    done
    # Keenetic: drop a marker so the netfilter.d hook re-asserts after NDM rebuilds.
    [ -n "$ALLVPN_MARK" ] && touch "$ALLVPN_MARK" 2>/dev/null
    json_ok
    ;;

allvpn_off)
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    [ -n "$ALLVPN_MARK" ] && rm -f "$ALLVPN_MARK" 2>/dev/null
    iptables -t nat -D PREROUTING -i $LAN_IF -j SINGBOX_ALLVPN 2>/dev/null
    for VIF in $(vpn_redirect_ifaces); do
        [ -n "$VIF" ] || continue
        iptables -t nat -D PREROUTING -i "$VIF" -j SINGBOX_ALLVPN 2>/dev/null
    done
    iptables -t nat -F SINGBOX_ALLVPN 2>/dev/null
    iptables -t nat -X SINGBOX_ALLVPN 2>/dev/null
    json_ok
    ;;

# ==================== PROFILES ====================
profiles_list)
    printf '{"profiles":['
    FIRST=1
    for f in "$SINGBOX_PROFILES_DIR"/*.json; do
        [ -f "$f" ] || continue
        PNAME=$(basename "$f" .json)
        PTYPE=$(json_val "type" "$f")
        PDESC=$(json_val "name" "$f")
        PGROUP=$(json_val "group" "$f")
        PRMODE=$(json_val "routing_mode" "$f")
        # auto-switch eligible = id is NOT in the exclude list (absent file = eligible).
        if [ -f "$AUTOSWITCH_EXCLUDE" ] && grep -qxF "$PNAME" "$AUTOSWITCH_EXCLUDE" 2>/dev/null; then
            PAS=false
        else
            PAS=true
        fi
        if [ "$FIRST" = "1" ]; then FIRST=0; else printf ','; fi
        printf '{"id":"%s","type":"%s","name":"%s","group":"%s","routing_mode":"%s","autoswitch":%s}' \
            "$PNAME" "$PTYPE" \
            "$(echo "$PDESC" | json_escape)" \
            "$(echo "$PGROUP" | json_escape)" \
            "$PRMODE" "$PAS"
    done
    printf '],"active":"%s","active_chain":' "$(get_active_profile)"
    print_csv_json_array "$(get_active_chain)"
    printf '}'
    ;;

autoswitch_set)
    # Mark profiles eligible/ineligible for auto-switch. ?eligible=1|0 + POST body =
    # profile ids (newline- or comma-separated). eligible=1 → remove from the exclude
    # list; 0 → add. The exclude LIST (not the profile JSON) is the store, because
    # subscription-refresh rebuilds profile JSON from scratch and would drop a flag.
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    AS_ELIG=$(echo "$QUERY_STRING" | sed -n 's/.*[?&]eligible=\([^&]*\).*/\1/p' | head -1)
    mkdir -p "$(dirname "$AUTOSWITCH_EXCLUDE")" 2>/dev/null
    touch "$AUTOSWITCH_EXCLUDE" 2>/dev/null
    AS_IDS="/tmp/detour-autoswitch-ids.$$"
    # `|| [ -n "$_l" ]` so the FINAL id is processed even when the body has no
    # trailing newline — the panel sends ids.join("\n") (and a single id has none).
    printf '%s' "$POST_DATA" | tr ',\r' '\n\n' | while IFS= read -r _l || [ -n "$_l" ]; do
        _s=$(printf '%s' "$_l" | tr -cd 'a-zA-Z0-9_-')
        [ -n "$_s" ] && echo "$_s"
    done | sort -u > "$AS_IDS"
    if [ -s "$AS_IDS" ]; then
        if [ "$AS_ELIG" = "1" ]; then
            # eligible → drop these ids from the exclude list
            awk 'NR==FNR{rm[$0]=1; next} !($0 in rm)' "$AS_IDS" "$AUTOSWITCH_EXCLUDE" \
                > "$AUTOSWITCH_EXCLUDE.new" 2>/dev/null
        else
            # ineligible → union the ids into the exclude list (dedup, drop blanks)
            awk 'NF && !seen[$0]++' "$AUTOSWITCH_EXCLUDE" "$AS_IDS" \
                > "$AUTOSWITCH_EXCLUDE.new" 2>/dev/null
        fi
        mv "$AUTOSWITCH_EXCLUDE.new" "$AUTOSWITCH_EXCLUDE" 2>/dev/null
    fi
    rm -f "$AS_IDS"
    AS_CNT=$(grep -c . "$AUTOSWITCH_EXCLUDE" 2>/dev/null); [ -z "$AS_CNT" ] && AS_CNT=0
    printf '{"ok":true,"excluded":%s}' "$AS_CNT"
    ;;

profile_get)
    PNAME=$(echo "$QUERY_STRING" | sed -n 's/.*name=\([^&]*\).*/\1/p')
    PNAME=$(sanitize_name "$PNAME")
    if [ -z "$PNAME" ]; then json_err "name required"; exit 0; fi
    PFILE="$SINGBOX_PROFILES_DIR/$PNAME.json"
    if [ ! -f "$PFILE" ]; then json_err "profile not found"; exit 0; fi
    cat "$PFILE"
    ;;

profiles_export)
    # Bulk-export every profile JSON, concatenated into one array.
    # Each on-disk profile is already a valid JSON object, so concat with commas
    # yields a valid array without needing jq.
    printf '{"version":1,"exported_at":"%s","profiles":[' "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    FIRST=1
    for f in "$SINGBOX_PROFILES_DIR"/*.json; do
        [ -f "$f" ] || continue
        if [ "$FIRST" = "1" ]; then FIRST=0; else printf ','; fi
        cat "$f"
    done
    printf ']}'
    ;;

profile_save)
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    # POST body is the full profile JSON {name, type, uri, outbound}
    # Extract the "id" field for filename, or use sanitized "name"
    P_ID=$(printf '%s' "$POST_DATA" | sed -n 's/.*"id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)
    [ -z "$P_ID" ] && P_ID=$(printf '%s' "$POST_DATA" | sed -n 's/.*"name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)
    P_ID=$(sanitize_name "$P_ID")
    if [ -z "$P_ID" ]; then json_err "profile id/name required"; exit 0; fi
    echo "$POST_DATA" > "$SINGBOX_PROFILES_DIR/$P_ID.json"
    json_ok
    ;;

profile_delete)
    if [ "$REQUEST_METHOD" != "POST" ]; then json_err "POST required"; exit 0; fi
    PNAME=$(echo "$QUERY_STRING" | sed -n 's/.*name=\([^&]*\).*/\1/p')
    PNAME=$(sanitize_name "$PNAME")
    if [ -z "$PNAME" ]; then json_err "name required"; exit 0; fi
        ACTIVE_CHAIN=$(get_active_chain)
        if csv_contains "$ACTIVE_CHAIN" "$PNAME"; then json_err "cannot delete active chain profile"; exit 0; fi
    PFILE="$SINGBOX_PROFILES_DIR/$PNAME.json"
