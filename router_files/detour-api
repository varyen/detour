#!/bin/sh
# Detour API - CGI script for uhttpd (with session auth)

# ==================== CONFIG ====================
SINGBOX_CONFIG_DIR="/etc/sing-box"
SINGBOX_DOMAINS="/etc/sing-box/proxy-domains.list"
SINGBOX_CONFIG="/etc/sing-box/config.json"
SINGBOX_ROUTEMAP="/etc/sing-box/route-map.list"
SINGBOX_LOG="/var/log/sing-box.log"
SINGBOX_INITD="/etc/init.d/sing-box"
SINGBOX_SETTINGS="/etc/sing-box/settings.json"
SINGBOX_PROFILES_DIR="/etc/sing-box/profiles"
# Profiles EXCLUDED from auto-switch (one id per line; absent/empty = all eligible).
# Read by detour-health's candidate pick; managed by the autoswitch_set action below.
AUTOSWITCH_EXCLUDE="/etc/sing-box/autoswitch-exclude.list"
SINGBOX_WHITELIST="/etc/sing-box/whitelist-domains.list"
ZAPRET_INITD="/etc/init.d/zapret-tpws"
ZAPRET_CONF="/etc/zapret-tpws.conf"
ZAPRET_DOMAINS="/etc/zapret-tpws/domains.list"
LOGBRIDGE_INITD="/etc/init.d/detour-logbridge"   # syslog log-bridge service (gated by log_to_syslog)

KEEPALIVE_STATE="/var/state/vpn-keepalive.json"
KEEPALIVE_BIN="/usr/sbin/vpn-keepalive"
UPDATE_BIN="/usr/sbin/detour-update"
BYPASS_BIN="/usr/sbin/detour-bypass"
BYPASS_STRATEGY_FILE="/etc/detour/nfqws2.strategy"
VERSION_FILE="/etc/detour/version"
UPDATE_STATE="/var/state/detour-update.json"
BINS_STATE="/var/state/detour-bins.json"   # sing-box update state (written by detour-update bins-check)
TPWS_STATE="/var/state/detour-tpws.json"   # tpws-zapret update state (written by detour-update tpws-check)
NFQWS2_STATE="/var/state/detour-nfqws2.json" # nfqws2 (zapret2) update state (written by detour-update nfqws2-check)
PING_DB="/tmp/detour-ping.db"               # per-profile latency cache (TSV in tmpfs; cleared on reboot)
HEALTH_DB="/tmp/detour-health.db"           # per-profile FUNCTIONAL check cache (TSV; written by detour-health)
HEALTH_SWITCH="/tmp/detour-health.switch"   # last auto-switch event marker (JSON; written by detour-health)
HEALTH_UNSUPP="/tmp/detour-health.unsupported" # set by detour-health when sing-box lacks clash_api
HEALTH_URLS="/etc/sing-box/health-urls.list" # health-check targets: "label|url" per line (panel-editable)
HEALTH_BIN="/usr/sbin/detour-health"
PUSH_BIN="/usr/sbin/detour-push"            # Web Push (VAPID) sender — backs the push_* actions
PUSH_MSG="/tmp/detour-push.msg"             # latest push message JSON (read by the service worker; tmpfs, not remapped)
CERT_BIN="/usr/sbin/detour-cert"            # Let's Encrypt helper (acme.sh) — backs the cert_* actions
CERT_STATE="/var/state/detour-cert.json"    # cert issue/renew status (written by detour-cert)
# Swap file (Keenetic/Entware only — /opt on a USB flash needs swap or the stack
# gets OOM-killed). Managed via the S05swap init script; backs the swap_* actions.
SWAPFILE="/opt/swapfile"
SWAP_INITD="/etc/init.d/S05swap"
SWAP_STATE="/var/state/detour-swap.json"

AUTH_FILE="/etc/detour.auth"
SESSION_DIR="/tmp/detour-sessions"
LOGIN_THROTTLE_DIR="/tmp/detour-login"   # per-IP login brute-force state (tmpfs; cleared on reboot). Not remapped on Keenetic (like SESSION_DIR).
SINGBOX_BIN="/usr/bin/sing-box"
TPWS_BIN="/usr/bin/tpws-zapret"
NFQWS_BIN="/usr/bin/nfqws2"
SUBREFRESH_BIN="/usr/sbin/subscription-refresh"
HOSTS_BIN="/usr/sbin/detour-hosts"
LAN_IF="br-lan"
DETOUR_DIR="/etc/detour"
# Init action for a panel-driven manual start. On OpenWrt the rc.common `start`
# always starts; on Keenetic boot-`start` is gated by the autostart flag, so manual
# starts use `force-start` to start regardless (overridden in the shim below).
SVC_START="start"
# =================================================
# ============ PLATFORM SHIM (OpenWrt | Keenetic/Entware) ============
# On KeeneticOS the whole stack lives under /opt (Entware) and the firewall is
# iptables re-applied via /opt/etc/ndm/netfilter.d/. Detect Entware and remap.
# Inert on OpenWrt. ⚠ VALIDATE on device (paths, LAN_IF, allvpn persistence).
PLATFORM="openwrt"
if [ -d /opt/etc/ndm ] || [ -f /opt/etc/detour/platform ]; then
    PLATFORM="keenetic"; OPT=/opt
    # lighttpd hands CGIs a minimal PATH; Entware tools (sed/grep/openssl/base64/
    # mkdir/find…) live in /opt/bin:/opt/sbin. Without this every external command
    # silently fails → e.g. the QUERY_STRING `sed` returns empty → false 401s.
    export PATH="/opt/bin:/opt/sbin:/usr/bin:/usr/sbin:/bin:/sbin"
    SINGBOX_CONFIG_DIR="$OPT/etc/sing-box"
    SINGBOX_DOMAINS="$OPT/etc/sing-box/proxy-domains.list"
    SINGBOX_CONFIG="$OPT/etc/sing-box/config.json"
    SINGBOX_ROUTEMAP="$OPT/etc/sing-box/route-map.list"
    SINGBOX_LOG="$OPT/var/log/sing-box.log"
    SINGBOX_INITD="$OPT/etc/init.d/S52detour-singbox"
    SINGBOX_SETTINGS="$OPT/etc/sing-box/settings.json"
    SINGBOX_PROFILES_DIR="$OPT/etc/sing-box/profiles"
    AUTOSWITCH_EXCLUDE="$OPT/etc/sing-box/autoswitch-exclude.list"
    SINGBOX_WHITELIST="$OPT/etc/sing-box/whitelist-domains.list"
    ZAPRET_INITD="$OPT/etc/init.d/S53detour-zapret"
    ZAPRET_CONF="$OPT/etc/zapret-tpws.conf"
    ZAPRET_DOMAINS="$OPT/etc/zapret-tpws/domains.list"
    LOGBRIDGE_INITD="$OPT/etc/init.d/S91detour-logbridge"
    KEEPALIVE_STATE="$OPT/var/state/vpn-keepalive.json"
    KEEPALIVE_BIN="$OPT/sbin/vpn-keepalive"
    UPDATE_BIN="$OPT/sbin/detour-update"
    BYPASS_BIN="$OPT/sbin/detour-bypass"
    BYPASS_STRATEGY_FILE="$OPT/etc/detour/nfqws2.strategy"
    VERSION_FILE="$OPT/etc/detour/version"
    UPDATE_STATE="$OPT/var/state/detour-update.json"
    BINS_STATE="$OPT/var/state/detour-bins.json"
    TPWS_STATE="$OPT/var/state/detour-tpws.json"
    NFQWS2_STATE="$OPT/var/state/detour-nfqws2.json"
    AUTH_FILE="$OPT/etc/detour.auth"
    DETOUR_DIR="$OPT/etc/detour"
    # «Все через VPN» marker — the NDM netfilter.d hook re-asserts SINGBOX_ALLVPN
    # from this so the chain survives KeeneticOS firewall rebuilds (no fw4 on NDM).
    ALLVPN_MARK="$OPT/etc/detour/allvpn.enabled"
    SINGBOX_BIN="$OPT/bin/sing-box"   # Entware sing-box-go installs to /opt/bin
    TPWS_BIN="$OPT/sbin/tpws-zapret"
    NFQWS_BIN="$OPT/sbin/nfqws2"
    SUBREFRESH_BIN="$OPT/sbin/subscription-refresh"
    HOSTS_BIN="$OPT/sbin/detour-hosts"
    HEALTH_URLS="$OPT/etc/sing-box/health-urls.list"  # HEALTH_DB/SWITCH stay /tmp (not remapped, like PING_DB)
    HEALTH_BIN="$OPT/sbin/detour-health"
    PUSH_BIN="$OPT/sbin/detour-push"   # PUSH_MSG stays /tmp (not remapped, like HEALTH_DB)
    CERT_BIN="$OPT/sbin/detour-cert"
    CERT_STATE="$OPT/var/state/detour-cert.json"
    SWAPFILE="$OPT/swapfile"
    SWAP_INITD="$OPT/etc/init.d/S05swap"
    SWAP_STATE="$OPT/var/state/detour-swap.json"
    # LAN bridge from detour.conf (assumed br0); "Все через VPN" uses iptables (no nft fw4).
    LAN_IF="br0"
    SVC_START="force-start"   # Keenetic boot-`start` is autostart-gated; manual start bypasses it
    [ -f "$OPT/etc/detour/detour.conf" ] && . "$OPT/etc/detour/detour.conf" 2>/dev/null
    mkdir -p "$OPT/var/state" "$OPT/var/log"
fi

mkdir -p "$SESSION_DIR"
mkdir -p "$SINGBOX_PROFILES_DIR"

# ==================== HELPERS ====================
json_ok() { echo '{"ok":true}'; }
json_escape() {
    # sed handles the literal escapes (BusyBox awk's gsub(/"/,...) mangles quotes →
    # broken JSON, seen on Keenetic/Entware "Update" output); awk strips ANSI +
    # trailing CR and joins lines with \n. Order matters: backslash before quote.
    sed -e 's/\\/\\\\/g' -e 's/"/\\"/g' -e 's/	/\\t/g' | \
    awk 'BEGIN{first=1}{gsub(/\033\[[0-9;]*m/,"");sub(/\r$/,"");if(!first)printf "\\n";printf "%s",$0;first=0}'
}
json_err() { printf '{"ok":false,"error":"%s"}' "$(printf '%s' "$1" | json_escape)"; }
reply_json() {
    echo "Content-Type: application/json"
    echo "Cache-Control: no-cache"
}

# ---- «Автозапуск» (autostart) preference ----------------------------------
# A durable per-service flag (/etc/detour/autostart.{singbox,zapret} = 1|0), kept
# under the state dir so it survives panel REINSTALLS and reboots. It is the single
# source of truth for «Автозапуск» on BOTH platforms:
#   • OpenWrt — the init.d enable/disable symlink is the boot trigger, but it gets
#     clobbered on reinstall (postinst runs `enable`) and the proxy-guard hotplug
#     resurrects sing-box on each WAN ifup; the postinst + guard now consult this
#     flag instead, so a disabled service stays disabled.
#   • Keenetic — rc.unslung boot-starts every executable S* with `start`; the S52/
#     S53 scripts gate that `start` on this flag (manual start uses `force-start`).
autostart_file() {   # $1 = singbox|zapret
    echo "$DETOUR_DIR/autostart.$1"
}
set_autostart() {    # $1 = singbox|zapret, $2 = 1|0
    mkdir -p "$DETOUR_DIR" 2>/dev/null
    printf '%s\n' "$2" > "$(autostart_file "$1")" 2>/dev/null
}
# Resolve effective autostart state into the caller's var name ($3): the explicit
# flag wins; absent → fall back (OpenWrt: rc.d symlink $2; Keenetic: default ON,
# since rc.unslung boot-starts every executable S*).
read_autostart() {   # $1 = singbox|zapret, $2 = rc.d symlink path, $3 = out var
    local f val="false"
    f="$(autostart_file "$1")"
    if [ -f "$f" ]; then
        [ "$(cat "$f" 2>/dev/null)" = "1" ] && val="true"
    elif [ "$PLATFORM" = "keenetic" ]; then
        val="true"
    else
        [ -L "$2" ] 2>/dev/null && val="true"
    fi
    eval "$3=$val"
}

# Run a shell command line fully detached from this CGI's session/process group.
#   $1        = log file (worker stdout/stderr go here)
#   $2, $3, … = the command line (joined with spaces, parsed by `sh -c`)
# WHY: on Keenetic the panel is a dedicated lighttpd (S51detour-panel) and THIS
# CGI is its child. A panel-package install restarts that lighttpd in its
# prerm/postinst, which SIGTERMs lighttpd's whole CGI subtree — including the
# in-flight `opkg`/`detour-update` — and aborts the update half-done. setsid (or
# start-stop-daemon -b) re-parents the worker into a NEW session so it survives
# the panel restart. Returns immediately; the worker reports via the state file.
detach_bg() {
    _log="$1"; shift
    _sh=$(command -v sh 2>/dev/null); [ -n "$_sh" ] || _sh=/bin/sh
    # The leading sleep lets this CGI flush its HTTP response and exit before the
    # worker tears lighttpd down. Redirect is INSIDE the string so it survives
    # start-stop-daemon's own stdio handling (which would otherwise route to /dev/null).
    _cmd="{ sleep 1; $*; } >$_log 2>&1"
    if command -v setsid >/dev/null 2>&1; then
        setsid "$_sh" -c "$_cmd" </dev/null >/dev/null 2>&1 &
    elif command -v start-stop-daemon >/dev/null 2>&1; then
        # BusyBox applet (always present on Entware). -b daemonizes (fork+setsid).
        # CRITICAL: match by a UNIQUE, non-existent pidfile and start via -a — do
        # NOT use -x "$_sh". With -x, start-stop-daemon matches the executable
        # against every running /bin/sh (including this very CGI), concludes the
        # "service" is already up, and silently exits WITHOUT starting the worker
        # (verified on BusyBox: -x /bin/sh → exit 1, no start). -p <nonexistent>
        # gives it a match key that can't hit, so it always starts. The redirect
        # keeps the daemonized worker off this CGI's stdout pipe (so lighttpd can
        # flush our response before the panel restart, instead of an empty body).
        start-stop-daemon -S -b -q -p "/tmp/detour-bg-$$.pid" -a "$_sh" -- -c "$_cmd" </dev/null >/dev/null 2>&1
    else
        ( exec "$_sh" -c "$_cmd" </dev/null >/dev/null 2>&1 ) &
    fi
}

# Live apply log. The feed-binary applies (bins/tpws/nfqws2) run DETACHED with all
# output streamed here; the panel polls `apply_log` and shows it in real time so the
# operator sees exactly what opkg did and where it failed. Running detached also
# means a long opkg run can't be killed by an HTTP/proxy timeout — the truncated
# response that surfaced as «Unexpected end of JSON input» can no longer happen.
APPLY_LOG=/tmp/detour-apply.log
APPLY_DONE_MARK="===DETOUR_APPLY_DONE"
# Keenetic only: a panel self-install restarts the panel's OWN lighttpd (S51detour-panel),
# which serves this CGI and the apply_log stream — so the live log would go dark for the
# whole install (the OpenWrt panel rides the system uhttpd and has no such gap). The
# Keenetic package prerm/postinst key off this marker to KEEP lighttpd serving during the
# install and restart it only at the very end, so the browser streams the install log live
# (apply_log) — OpenWrt parity. Set right before the detached opkg starts; the new postinst
# removes it. (Harmless/ignored on OpenWrt, where nothing reads it.)
SELFUPDATE_MARK=/tmp/detour-panel-selfupdate

# start_apply <full-shell-command> — truncate the log, run the command detached
# (stdout+stderr → APPLY_LOG) with a completion sentinel carrying the exit code,
# and answer immediately so the panel can stream the log via `apply_log`.
start_apply() {
    : > "$APPLY_LOG" 2>/dev/null
    detach_bg "$APPLY_LOG" "$1; echo \"$APPLY_DONE_MARK rc=\$?\""
    printf '{"ok":true,"status":"started"}\n'
}

# Sanitize profile name: only a-zA-Z0-9_- allowed, no path traversal
sanitize_name() {
    echo "$1" | tr -cd 'a-zA-Z0-9_-' | head -c 64
}

# Read a JSON string value by key (simple sed parser for flat JSON)
json_val() {
    sed -n "s/.*\"$1\"[[:space:]]*:[[:space:]]*\"\([^\"]*\)\".*/\1/p" "$2" 2>/dev/null | head -1
}

get_settings_val() {
    local key="$1"
    [ -f "$SINGBOX_SETTINGS" ] && json_val "$key" "$SINGBOX_SETTINGS"
}

# VPN inbound interfaces (besides $LAN_IF) that should ALSO be forced through the
# proxy when "Все через VPN" (all-traffic redirect) is enabled — e.g. a WireGuard
# server iface. Shared with the init.d scripts via settings.json
# "vpn_redirect_ifaces" (space- or comma-separated; empty = none).
vpn_redirect_ifaces() {
    get_settings_val "vpn_redirect_ifaces" | tr ',' ' '
}

normalize_profile_list() {
    local raw="$1"
    local result=""
    local item
    echo "$raw" | tr ',' '\n' | while IFS= read -r item; do
        item=$(sanitize_name "$item")
        [ -n "$item" ] || continue
        printf '%s\n' "$item"
    done | awk '!seen[$0]++ { if (out) out = out "," $0; else out = $0 } END { print out }'
}

get_last_csv_item() {
    local csv="$1"
    local last=""
    local old_ifs="$IFS"
    IFS=','
    set -- $csv
    IFS="$old_ifs"
    for last in "$@"; do :; done
    printf '%s' "$last"
}

print_csv_json_array() {
    local csv="$1"
    local item
    local first=1
    local old_ifs="$IFS"
    printf '['
    if [ -n "$csv" ]; then
        IFS=','
        set -- $csv
        IFS="$old_ifs"
        for item in "$@"; do
            [ -n "$item" ] || continue
            if [ "$first" = "1" ]; then
                first=0
            else
                printf ','
            fi
            printf '"%s"' "$item"
        done
    fi
    printf ']'
}

csv_contains() {
    local csv="$1"
    local needle="$2"
    echo ",$csv," | grep -q ",${needle},"
}

extract_profile_outbound() {
    local profile_file="$1"
    awk '
    BEGIN { depth=0; capture=0; buf="" }
    {
        for(i=1;i<=length($0);i++) {
            c=substr($0,i,1)
            if(capture) {
                buf = buf c
                if(c=="{") depth++
                if(c=="}") { depth--; if(depth==0) { print buf; exit } }
            }
            if(!capture && substr($0,i,10) == "\"outbound\"") {
                j=i+10
                while(j<=length($0) && substr($0,j,1)!="{") j++
                if(j<=length($0)) {
                    capture=1; depth=1; buf="{"; i=j
                }
            }
        }
    }' "$profile_file"
}

translate_wireguard_profile() {
    local endpoint_json="$1"
    local line

    line=$(printf '%s' "$endpoint_json" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g')
    line=$(printf '%s' "$line" | sed 's/"local_address"[[:space:]]*:/"address":/g')
    line=$(printf '%s' "$line" | sed 's/"server"[[:space:]]*:/"address":/g')
    line=$(printf '%s' "$line" | sed 's/"server_port"[[:space:]]*:/"port":/g')
    line=$(printf '%s' "$line" | sed 's/,"network"[[:space:]]*:[[:space:]]*"[^"]*"//g; s/"network"[[:space:]]*:[[:space:]]*"[^"]*",//g')
    printf '%s' "$line"
}

set_outbound_chain_fields() {
    local outbound_json="$1"
    local tag="$2"
    local detour="$3"
    local line

    line=$(printf '%s' "$outbound_json" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g')
    if echo "$line" | grep -q '"tag"[[:space:]]*:'; then
        line=$(printf '%s' "$line" | sed 's/"tag"[[:space:]]*:[[:space:]]*"[^"]*"/"tag":"'"$tag"'"/')
    else
        line=$(printf '%s' "$line" | sed 's/^{/{"tag":"'"$tag"'",/')
    fi

    if [ -n "$detour" ]; then
        if echo "$line" | grep -q '"detour"[[:space:]]*:'; then
            line=$(printf '%s' "$line" | sed 's/"detour"[[:space:]]*:[[:space:]]*"[^"]*"/"detour":"'"$detour"'"/')
        else
            line=$(printf '%s' "$line" | sed 's/^{/{"detour":"'"$detour"'",/')
        fi
    else
        line=$(printf '%s' "$line" | sed 's/,"detour"[[:space:]]*:[[:space:]]*"[^"]*"//; s/"detour"[[:space:]]*:[[:space:]]*"[^"]*",//')
    fi

    printf '%s' "$line"
}

# Resolve a hostname with a hard ~3s ceiling so a broken/old tunnel can't wedge
# the CGI (hung nslookup → zombie procs → router meltdown). BusyBox/Entware have
# no dependable `timeout` applet, so run nslookup detached and poll: once the
# budget is spent send TERM, then KILL, then reap (wait) to avoid zombies, and
# finally emit whatever it managed to write. Output matches a bare nslookup so
# the caller's awk parser is unchanged.
nslookup_with_timeout() {
    local host="$1"
    local server="$2"
    local tmpf="/tmp/detour-nslookup.$$"
    local pid count
    nslookup "$host" "$server" > "$tmpf" 2>/dev/null &
    pid=$!
    count=0
    while kill -0 "$pid" 2>/dev/null; do
        if [ "$count" -ge 2 ]; then
            kill "$pid" 2>/dev/null
            sleep 1
            kill -9 "$pid" 2>/dev/null
            break
        fi
        sleep 1
        count=$((count + 1))
    done
    wait "$pid" 2>/dev/null
    cat "$tmpf" 2>/dev/null
    rm -f "$tmpf"
}

collect_upstream_ips() {
    {
        sed -n 's/.*"server"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$SINGBOX_CONFIG" 2>/dev/null
        for cf in "$SINGBOX_CONFIG_DIR"/config-*.json; do
            [ -f "$cf" ] && sed -n 's/.*"server"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$cf" 2>/dev/null
        done
    } | \
    while IFS= read -r host; do
        [ -n "$host" ] || continue
        if echo "$host" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$'; then
            printf '%s\n' "$host"
        else
            nslookup_with_timeout "$host" 127.0.0.1 | \
                awk '/^Address [0-9]+: /{print $3} /^Address: /{print $2}' | \
                grep -E '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$' || true
        fi
    done | awk '!seen[$0]++ { if (out) out = out "," $0; else out = $0 } END { print out }'
}

write_settings() {
    local active_chain="$1"
    local routing_mode="$2"
    local upstream_ips="$3"
    local singbox_mode="$4"
    local active_profile

    active_chain=$(normalize_profile_list "$active_chain")
    [ -z "$active_chain" ] && active_chain="default"
    active_profile=$(get_last_csv_item "$active_chain")
    case "$singbox_mode" in single|multi) ;; *) singbox_mode="single" ;; esac

    # Preserve vpn_redirect_ifaces (VPN road-warrior redirect) across rewrites —
    # this function emits a fixed key set, so re-read and re-emit it or it's lost.
    local vpn_ifaces
    vpn_ifaces=$(get_settings_val "vpn_redirect_ifaces")

    # Health-check flags: same deal. Re-read from the current file so a profile
    # switch / settings POST doesn't wipe them; callers (health_config action)
    # change a value by exporting an override before calling us. Defaults: the
    # functional check is ON, auto-switch is OFF.
    local health_enabled health_autoswitch health_speed
    health_enabled=${HEALTH_ENABLED_OVERRIDE:-$(get_settings_val "health_check_enabled")}
    [ -z "$health_enabled" ] && health_enabled="1"
    health_autoswitch=${HEALTH_AUTOSWITCH_OVERRIDE:-$(get_settings_val "health_auto_switch")}
    [ -z "$health_autoswitch" ] && health_autoswitch="0"
    # Speed measurement: ON by default; measured only for the active profile hourly
    # (+ on-demand per row) by detour-health, so it adds little traffic. Preserve a
    # custom health_speed_url across rewrites the same way (this fn emits a fixed key
    # set, so a key not re-read here would be lost on the next settings POST).
    health_speed=${HEALTH_SPEED_OVERRIDE:-$(get_settings_val "health_speed_enabled")}
    [ -z "$health_speed" ] && health_speed="1"
    local health_speed_url
    health_speed_url=$(get_settings_val "health_speed_url")

    # Syslog log-bridge flags (default OFF). Same preserve-or-override dance:
    # the log_config action sets them via env before calling us; every other
    # settings rewrite re-reads them from the current file so they survive.
    local log_syslog log_syslog_sb
    log_syslog=${LOG_SYSLOG_OVERRIDE:-$(get_settings_val "log_to_syslog")}
    [ -z "$log_syslog" ] && log_syslog="0"
    log_syslog_sb=${LOG_SYSLOG_SB_OVERRIDE:-$(get_settings_val "log_to_syslog_singbox")}
    [ -z "$log_syslog_sb" ] && log_syslog_sb="0"

    cat > "$SINGBOX_SETTINGS" <<EOF
{
  "active_profile": "$active_profile",
  "active_chain": "$active_chain",
  "routing_mode": "$routing_mode",
  "upstream_ips": "$upstream_ips",
  "singbox_mode": "$singbox_mode",
  "vpn_redirect_ifaces": "$vpn_ifaces",
  "health_check_enabled": "$health_enabled",
  "health_auto_switch": "$health_autoswitch",
  "health_speed_enabled": "$health_speed",
  "health_speed_url": "$health_speed_url",
  "log_to_syslog": "$log_syslog",
  "log_to_syslog_singbox": "$log_syslog_sb"
}
EOF
}

# Per-profile routing_mode override: if a profile.json has a non-empty
# "routing_mode" field, that mode wins over the global one when the profile
# is activated. Lets a subscription drop in profiles that auto-switch to
# "all-except" (bypass-list) on activation while user-created profiles
# leave the system-wide mode untouched.
get_profile_routing_mode() {
    local pname="$1"
    local pfile="$SINGBOX_PROFILES_DIR/$pname.json"
    [ -f "$pfile" ] || return 0
    local mode
    mode=$(json_val "routing_mode" "$pfile")
    case "$mode" in
        proxy-list|all-except) printf '%s' "$mode" ;;
        *) ;;
    esac
}

# Routing mode used by chain_activate: per-profile override (taken from the
# LAST profile in the chain, since that's what handles egress) → fall back
# to the existing global setting.
resolve_routing_mode_for_chain() {
    local chain_csv="$1"
    local last
    last=$(get_last_csv_item "$chain_csv")
    local override
    override=$(get_profile_routing_mode "$last")
    if [ -n "$override" ]; then
        printf '%s' "$override"
    else
        get_routing_mode
    fi
}

get_singbox_mode() {
    local m=$(get_settings_val "singbox_mode")
    case "$m" in
        single|multi) printf '%s' "$m" ;;
        *) printf 'single' ;;
    esac
}

# Numeric JSON value reader (json_val only matches quoted string values).
numeric_json_val() {
    sed -n "s/.*\"$1\"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/p" "$2" 2>/dev/null | head -1
}

# TCP-handshake latency probe to HOST:PORT. Echoes integer ms on success (the
# SYN/SYN-ACK round-trip — one round-trip, directly comparable to an ICMP RTT),
# nothing on failure; return 0 = reachable, non-zero = unreachable. Used when a
# server filters ICMP so the panel shows a real number instead of a bare
# "reachable" tick — the same application-layer latency Clash-style clients show.
# Prefers luasocket: connect() returns exactly at handshake completion and
# socket.gettime() is sub-ms, so there is no nc fork or /proc/uptime centisecond
# flooring. Falls back to busybox nc timed against /proc/uptime (~10ms grade,
# ~+10ms spawn bias) where luasocket is absent (e.g. some Keenetic/Entware builds).
tcp_probe() {
    _tp_h="$1"; _tp_p="$2"
    [ -n "$_tp_h" ] && [ -n "$_tp_p" ] && [ "$_tp_p" != "0" ] || return 1
    # luasocket path — accurate, and the connect doubles as the reachability check.
    # exit: 0 ok (ms on stdout) / 1 connect failed / 3 no luasocket; lua missing → 127.
    _tp_ms=$(lua - "$_tp_h" "$_tp_p" 2>/dev/null <<'LUA'
local ok, socket = pcall(require, "socket")
if not ok then os.exit(3) end
local h, p = arg[1], tonumber(arg[2])
local c = socket.tcp(); c:settimeout(3)
local t0 = socket.gettime()
local cok = c:connect(h, p)
local t1 = socket.gettime()
c:close()
if not cok then os.exit(1) end
io.write(string.format("%d", math.floor((t1 - t0) * 1000 + 0.5)))
LUA
)
    _tp_rc=$?
    if [ "$_tp_rc" = "0" ]; then
        case "$_tp_ms" in ''|*[!0-9]*) echo "-1" ;; *) echo "$_tp_ms" ;; esac
        return 0
    fi
    [ "$_tp_rc" = "1" ] && return 1   # luasocket present, connect failed → down
    # No luasocket (or no lua): busybox nc + /proc/uptime fallback.
    command -v nc >/dev/null 2>&1 || return 1
    _tp_t0=$(cut -d' ' -f1 /proc/uptime 2>/dev/null)
    if timeout 3 nc "$_tp_h" "$_tp_p" </dev/null >/dev/null 2>&1; then
        _tp_t1=$(cut -d' ' -f1 /proc/uptime 2>/dev/null)
        if [ -n "$_tp_t0" ] && [ -n "$_tp_t1" ]; then
            echo "$_tp_t0 $_tp_t1" | awk '{d=($2-$1)*1000; if(d<0)d=0; printf "%d", d}'
        else
            echo "-1"   # reachable but couldn't time it → keep old "TCP up" semantics
        fi
        return 0
    fi
    return 1
}

# Emit unique route-map target profile ids, in file order. Section headers:
#   // === route:PROFILEID ===
route_map_targets() {
    [ -f "$SINGBOX_ROUTEMAP" ] || return 0
    awk '
    /^[[:space:]]*\/\/[[:space:]]*===[[:space:]]*route:/ {
        line=$0
        sub(/^[[:space:]]*\/\/[[:space:]]*===[[:space:]]*route:[[:space:]]*/, "", line)
        sub(/[[:space:]]*===.*$/, "", line)
        gsub(/[^a-zA-Z0-9_-]/, "", line)
        if (line != "" && !seen[line]++) print line
    }' "$SINGBOX_ROUTEMAP"
}

# Emit classified entries ("D domain" / "I ipcidr") belonging to ONE target.
route_map_section() {
    local id="$1"
    [ -f "$SINGBOX_ROUTEMAP" ] || return 0
    awk -v want="$id" '
    /^[[:space:]]*\/\/[[:space:]]*===[[:space:]]*route:/ {
        t=$0
        sub(/^[[:space:]]*\/\/[[:space:]]*===[[:space:]]*route:[[:space:]]*/, "", t)
        sub(/[[:space:]]*===.*$/, "", t)
        gsub(/[^a-zA-Z0-9_-]/, "", t)
        inblk = (t == want) ? 1 : 0
        next
    }
    {
        if (!inblk) next
        line=$0
        sub(/\/\/.*/, "", line); sub(/#.*/, "", line); gsub(/\r/, "", line)
        gsub(/^[ \t]+|[ \t]+$/, "", line)
        sub(/^\*\./, "", line)
        if (line == "") next
        if (line ~ /^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+(\/[0-9]+)?$/) { print "I " line; next }
        if (line ~ /^[a-zA-Z0-9]([a-zA-Z0-9._-]*\.)+[a-zA-Z]{2,}$/) { print "D " line; next }
    }' "$SINGBOX_ROUTEMAP"
}

# Resolve the outbound tag a route target should use. If the target id is a
# member of the active chain, reuse that chain tag (no duplicate outbound).
# Otherwise the target gets a dedicated "out_<id>" outbound.
route_tag_for() {
    local id="$1" chain="$2" i total item old_ifs
    old_ifs="$IFS"; IFS=','; set -- $chain; IFS="$old_ifs"
    total=$#; i=0
    for item in "$@"; do
        i=$((i + 1))
        if [ "$item" = "$id" ]; then
            if [ "$i" -eq "$total" ]; then printf 'proxy'; else printf 'chain_%s' "$i"; fi
            return 0
        fi
    done
    printf 'out_%s' "$id"
}

# Single-instance mode: compute the extra outbounds/endpoints and route.rules
# fragment from the route map. Sets globals RX_OB, RX_EP, RX_RULES.
compute_route_extras() {
    local chain="$1"
    local target tag payload ptype dom_arr ip_arr robj rule_objs
    RX_OB=""; RX_EP=""; RX_RULES=""
    rule_objs=""
    for target in $(route_map_targets); do
        [ -f "$SINGBOX_PROFILES_DIR/$target.json" ] || continue
        dom_arr=$(route_map_section "$target" | awk '$1=="D"{ if(n++)printf","; printf "\"%s\"",$2 }')
        ip_arr=$(route_map_section "$target" | awk '$1=="I"{ if(n++)printf","; printf "\"%s\"",$2 }')
        [ -z "$dom_arr" ] && [ -z "$ip_arr" ] && continue
        tag=$(route_tag_for "$target" "$chain")
        if [ "$tag" = "out_$target" ]; then
            payload=$(extract_profile_outbound "$SINGBOX_PROFILES_DIR/$target.json")
            [ -n "$payload" ] || continue
            payload=$(set_outbound_chain_fields "$payload" "$tag" "")
            ptype=$(json_val "type" "$SINGBOX_PROFILES_DIR/$target.json")
            if [ "$ptype" = "wireguard" ]; then
                payload=$(translate_wireguard_profile "$payload")
                RX_EP="$RX_EP,
    $payload"
            else
                RX_OB="$RX_OB,
    $payload"
            fi
        fi
        if [ -n "$dom_arr" ]; then
            robj="{\"action\":\"route\",\"domain_suffix\":[$dom_arr],\"outbound\":\"$tag\"}"
            if [ -n "$rule_objs" ]; then rule_objs="$rule_objs,$robj"; else rule_objs="$robj"; fi
        fi
        if [ -n "$ip_arr" ]; then
            robj="{\"action\":\"route\",\"ip_cidr\":[$ip_arr],\"outbound\":\"$tag\"}"
            if [ -n "$rule_objs" ]; then rule_objs="$rule_objs,$robj"; else rule_objs="$robj"; fi
        fi
    done
    if [ -n "$rule_objs" ]; then
        # sing-box >=1.11 ignores the inbound-level "sniff" option: it no longer
        # populates the connection's domain, so domain_suffix rules would never
        # match and every connection would fall through to route.final. An
        # explicit {"action":"sniff"} rule (evaluated first) sniffs the SNI/Host
        # so the per-target domain rules below can match. Only emitted when there
        # are route rules, so an empty route-map still yields the old config
        # byte-for-byte.
        RX_RULES="    \"rules\": [{\"action\":\"sniff\"},$rule_objs],
"
    fi
}

# Render a sing-box config JSON to STDOUT.
#   $1 chain CSV
#   $2 extra outbounds JSON (comma-prefixed, e.g. ',\n    {...}') or empty
#   $3 extra endpoints JSON (comma-prefixed) or empty
#   $4 route rules fragment ('    "rules": [...],\n') or empty
#   $5 listen_port (default 12345)
# Returns 1 if the chain is invalid.
render_chain_config() {
    local chain_csv="$1"
    local extra_outbounds="$2"
    local extra_endpoints="$3"
    local route_rules="$4"
    local listen_port="${5:-12345}"
    local normalized old_ifs total idx pname pfile ptype payload tag detour
    local outbounds_json endpoints_json outbounds_block

    normalized=$(normalize_profile_list "$chain_csv")
    [ -z "$normalized" ] && return 1

    old_ifs="$IFS"
    IFS=','
    set -- $normalized
    IFS="$old_ifs"
    total=$#
    idx=0
    detour=""
    outbounds_json=""
    endpoints_json=""

    for pname in "$@"; do
        idx=$((idx + 1))
        pfile="$SINGBOX_PROFILES_DIR/$pname.json"
        [ -f "$pfile" ] || return 1
        payload=$(extract_profile_outbound "$pfile")
        [ -n "$payload" ] || return 1
        ptype=$(json_val "type" "$pfile")

        if [ "$idx" -lt "$total" ]; then
            tag="chain_$idx"
        else
            tag="proxy"
        fi

        payload=$(set_outbound_chain_fields "$payload" "$tag" "$detour")

        if [ "$ptype" = "wireguard" ]; then
            payload=$(translate_wireguard_profile "$payload")
            if [ -z "$endpoints_json" ]; then
                endpoints_json="    $payload"
            else
                endpoints_json="$endpoints_json,
    $payload"
            fi
        else
            if [ -z "$outbounds_json" ]; then
                outbounds_json="    $payload"
            else
                outbounds_json="$outbounds_json,
    $payload"
            fi
        fi
        detour="$tag"
    done

    # extra_* fragments are comma-prefixed (",\n    {obj}"). When the chain
    # contributed no entries of that kind, drop the leading comma-only line so
    # we don't emit an array that starts with a comma.
    if [ -n "$extra_endpoints" ]; then
        if [ -z "$endpoints_json" ]; then
            endpoints_json=$(printf '%s' "$extra_endpoints" | sed '1{/^,$/d;}')
        else
            endpoints_json="$endpoints_json$extra_endpoints"
        fi
    fi

    if [ -n "$outbounds_json" ]; then
        outbounds_block="$outbounds_json$extra_outbounds,
        {
            \"type\": \"direct\",
            \"tag\": \"direct\"
        }"
    elif [ -n "$extra_outbounds" ]; then
        outbounds_block="$(printf '%s' "$extra_outbounds" | sed '1{/^,$/d;}'),
        {
            \"type\": \"direct\",
            \"tag\": \"direct\"
        }"
    else
        outbounds_block="    {
            \"type\": \"direct\",
            \"tag\": \"direct\"
        }"
    fi

    # Always sniff the SNI/Host via a route action. The inbound-level "sniff" +
    # "sniff_override_destination" fields were REMOVED in sing-box 1.13.0 (FATAL on
    # 1.13.x, only a warning on ≤1.13.2) — they migrate to a {"action":"sniff"}
    # route rule. In route-map mode the rules fragment already leads with it; in
    # simple mode (no per-target rules) emit a sniff-only rules array so the proxy
    # still dials the sniffed domain.
    local route_block_rules
    if [ -n "$route_rules" ]; then
        route_block_rules="$route_rules"
    else
        route_block_rules="    \"rules\": [{\"action\":\"sniff\"}],
"
    fi

    cat <<EOF
{
  "log": {
    "level": "info",
    "output": "/var/log/sing-box.log",
    "timestamp": true
  },
  "inbounds": [
    {
      "type": "redirect",
      "tag": "redirect-in",
      "listen": "::",
      "listen_port": $listen_port
    }
  ],
$(if [ -n "$endpoints_json" ]; then cat <<EOEP
    "endpoints": [
$endpoints_json
    ],
EOEP
fi)
  "outbounds": [
$outbounds_block
  ],
  "route": {
$route_block_rules    "final": "proxy"
  }
}
EOF
    return 0
}

# Build all sing-box config(s) for the given mode + chain. Writes to temp files,
# validates EVERY config with `sing-box check`, then commits atomically. On any
# failure prints a reason to stdout, returns 1, and leaves live configs intact.
build_config() {
    local mode="$1"
    local chain="$2"
    local tmp_default="${SINGBOX_CONFIG}.tmp.$$"
    local err rc target tmp_t port idx pair src dst base tid
    local commit_list keep_targets

    commit_list=""
    keep_targets=""

    if [ "$mode" = "multi" ]; then
        # Default instance: active chain only, route rules suppressed.
        if ! render_chain_config "$chain" "" "" "" 12345 > "$tmp_default"; then
            rm -f "$tmp_default"; echo "failed to render default config (bad chain?)"; return 1
        fi
        err=$($SINGBOX_BIN check -c "$tmp_default" 2>&1)
        if [ $? -ne 0 ]; then
            rm -f "$tmp_default"; echo "default config invalid: $err"; return 1
        fi
        commit_list="$tmp_default:$SINGBOX_CONFIG"

        idx=0
        for target in $(route_map_targets); do
            [ -f "$SINGBOX_PROFILES_DIR/$target.json" ] || continue
            route_map_section "$target" | grep -q . || continue
            idx=$((idx + 1))
            port=$((12345 + idx))
            tmp_t="${SINGBOX_CONFIG_DIR}/config-$target.json.tmp.$$"
            if ! render_chain_config "$target" "" "" "" "$port" > "$tmp_t"; then
                for pair in $commit_list; do rm -f "${pair%%:*}"; done
                rm -f "$tmp_t"
                echo "failed to render config for target $target"; return 1
            fi
            err=$($SINGBOX_BIN check -c "$tmp_t" 2>&1)
            if [ $? -ne 0 ]; then
                for pair in $commit_list; do rm -f "${pair%%:*}"; done
                rm -f "$tmp_t"
                echo "config for target $target invalid: $err"; return 1
            fi
            commit_list="$commit_list ${tmp_t}:${SINGBOX_CONFIG_DIR}/config-$target.json"
            keep_targets="$keep_targets $target"
        done
    else
        # single mode: one config with route.rules + extra outbounds.
        compute_route_extras "$chain"
        if ! render_chain_config "$chain" "$RX_OB" "$RX_EP" "$RX_RULES" 12345 > "$tmp_default"; then
            rm -f "$tmp_default"; echo "failed to render config (bad chain?)"; return 1
        fi
        err=$($SINGBOX_BIN check -c "$tmp_default" 2>&1)
        if [ $? -ne 0 ]; then
            rm -f "$tmp_default"; echo "config invalid: $err"; return 1
        fi
        commit_list="$tmp_default:$SINGBOX_CONFIG"
    fi

    # COMMIT — move temps into place.
    for pair in $commit_list; do
        src="${pair%%:*}"; dst="${pair#*:}"
        mv "$src" "$dst"
    done
    # Drop per-target configs no longer referenced.
    for tmp_t in "$SINGBOX_CONFIG_DIR"/config-*.json; do
        [ -f "$tmp_t" ] || continue
        base=$(basename "$tmp_t" .json); tid=${base#config-}
        case " $keep_targets " in
            *" $tid "*) ;;
            *) rm -f "$tmp_t" ;;
        esac
    done
    return 0
}

# Back-compat shim: callers that pre-date multi-instance still call this.
build_config_for_chain() {
    build_config "$(get_singbox_mode)" "$1"
}

get_active_profile() {
    local p=$(get_last_csv_item "$(get_active_chain)")
    [ -z "$p" ] && p="default"
    echo "$p"
}

get_active_chain() {
    local c=$(get_settings_val "active_chain")
    [ -z "$c" ] && c=$(get_settings_val "active_profile")
    [ -z "$c" ] && c="default"
    echo "$c"
}

get_routing_mode() {
    local m=$(get_settings_val "routing_mode")
    [ -z "$m" ] && m="proxy-list"
    echo "$m"
}

get_upstream_ips() {
    get_settings_val "upstream_ips"
}

# ==================== AUTH ====================
get_session_token() {
    echo "$HTTP_COOKIE" | tr ';' '\n' | sed 's/^ *//' | \
        grep '^detour_session=' | head -1 | cut -d'=' -f2
}

check_auth() {
    local token=$(get_session_token)
    [ -z "$token" ] && return 1
    echo "$token" | grep -qE '^[a-f0-9]{64}$' || return 1
    [ -f "$SESSION_DIR/$token" ] || return 1
    touch "$SESSION_DIR/$token"
    return 0
}

verify_password() {
    [ ! -f "$AUTH_FILE" ] && return 1
    # EXACT username match (awk field compare, not a grep regex) — the supplied
    # username is attacker-controlled and must never be interpreted as a pattern.
    # Rejoin fields 2..NF in case a hash ever contains ':' (crypt $6$ doesn't, but
    # be safe), matching the old `cut -f2-` semantics.
    local stored_hash
    stored_hash=$(awk -F: -v u="$1" '$1==u{h=$2; for(i=3;i<=NF;i++) h=h":"$i; print h; exit}' "$AUTH_FILE")
    [ -z "$stored_hash" ] && return 1
    local salt=$(echo "$stored_hash" | cut -d'$' -f3)
    local computed=$(printf '%s' "$2" | openssl passwd -6 -salt "$salt" -stdin 2>/dev/null)
    [ "$computed" = "$stored_hash" ]
}

gen_token() {
    local a=$(cat /proc/sys/kernel/random/uuid | tr -d '-')
    local b=$(cat /proc/sys/kernel/random/uuid | tr -d '-')
    printf '%s%s' "$a" "$b"
}

# ---- Login brute-force throttle (per source IP) ---------------------------
# State: $LOGIN_THROTTLE_DIR/<ip> holds "failcount lastfail_epoch" (tmpfs — a
# reboot clearing a lockout is acceptable). Keyed on the source IP; when the
# request arrives through a LOCAL reverse proxy (REMOTE_ADDR is loopback, e.g.
# nginx-on-router → uhttpd) the real client is taken from the first
# X-Forwarded-For hop (the proxy is trusted because it's on this host).
# Identical on OpenWrt (uhttpd) and Keenetic (lighttpd) — both set REMOTE_ADDR.
LOGIN_FAIL_WINDOW=900     # sliding window (s): fails older than this are forgotten
LOGIN_MAX_FAILS=8         # consecutive fails within the window before lockout starts

login_throttle_key() {
    local ip="${REMOTE_ADDR:-}"
    case "$ip" in
        ""|127.0.0.1|::1|::ffff:127.0.0.1)
            [ -n "$HTTP_X_FORWARDED_FOR" ] && \
                ip=$(printf '%s' "$HTTP_X_FORWARDED_FOR" | cut -d, -f1 | tr -d ' ') ;;
    esac
    [ -n "$ip" ] || ip="unknown"
    # Map every non-hex char (dots/colons) to '_' → a safe, collision-free filename.
    printf '%s' "$ip" | tr -c 'a-fA-F0-9' '_' | head -c 64
}

# Escalating lockout duration (s) by how far the fail count is over the threshold.
login_lock_secs() {
    local over=$(( $1 - LOGIN_MAX_FAILS ))
    if   [ "$over" -lt 2 ];  then echo 30
    elif [ "$over" -lt 5 ];  then echo 120
    elif [ "$over" -lt 10 ]; then echo 600
    else echo 1800
    fi
}

# Sets LOGIN_LOCK_LEFT = seconds remaining; returns 1 if this IP is locked NOW.
login_check_lock() {
    LOGIN_LOCK_LEFT=0
    local f="$LOGIN_THROTTLE_DIR/$(login_throttle_key)"
    [ -f "$f" ] || return 0
    local count last now lock left
    read count last < "$f" 2>/dev/null
    case "$count" in ''|*[!0-9]*) return 0 ;; esac
    case "$last"  in ''|*[!0-9]*) last=0 ;; esac
    now=$(date +%s 2>/dev/null); case "$now" in ''|*[!0-9]*) return 0 ;; esac
    if [ $((now - last)) -gt "$LOGIN_FAIL_WINDOW" ]; then
        rm -f "$f" 2>/dev/null; return 0   # stale window → forget
    fi
    if [ "$count" -ge "$LOGIN_MAX_FAILS" ]; then
        lock=$(login_lock_secs "$count")
        left=$(( last + lock - now ))
        [ "$left" -gt 0 ] && { LOGIN_LOCK_LEFT=$left; return 1; }
    fi
    return 0
}

login_record_fail() {
    mkdir -p "$LOGIN_THROTTLE_DIR" 2>/dev/null
    local f="$LOGIN_THROTTLE_DIR/$(login_throttle_key)"
    local count=0 last=0 now
    now=$(date +%s 2>/dev/null); case "$now" in ''|*[!0-9]*) now=0 ;; esac
    if [ -f "$f" ]; then
        read count last < "$f" 2>/dev/null
        case "$count" in ''|*[!0-9]*) count=0 ;; esac
        case "$last"  in ''|*[!0-9]*) last=0 ;; esac
        [ $((now - last)) -gt "$LOGIN_FAIL_WINDOW" ] && count=0   # window expired → fresh count
    fi
    count=$((count + 1))
    printf '%s %s\n' "$count" "$now" > "$f" 2>/dev/null
}

login_record_success() {
    rm -f "$LOGIN_THROTTLE_DIR/$(login_throttle_key)" 2>/dev/null
}
# =================================================

# ==================== INTERNAL CLI (no HTTP / no auth) ====================
# Reached only when invoked as a plain command with argv (uhttpd/lighttpd run
# CGIs with NO argv — they pass everything via env — so a web request can never
# trigger this; it is a local, root-only entrypoint). Used by detour-health's
# opt-in auto-switch to activate a profile through the SAME pipeline the panel
# uses (build_config → write_settings → reconfigure), avoiding a second copy of
# that logic. All referenced functions are defined above.
if [ "$1" = "activate" ]; then
    CHAIN=$(normalize_profile_list "$2")
    [ -z "$CHAIN" ] && { echo "activate: chain/profile required" >&2; exit 2; }
    SBMODE=$(get_singbox_mode)
    if ! BUILD_ERR=$(build_config "$SBMODE" "$CHAIN" 2>&1); then
        echo "activate: config build failed: $BUILD_ERR" >&2; exit 1
    fi
    RMODE=$(resolve_routing_mode_for_chain "$CHAIN")
    UPSTREAM_IPS=$(collect_upstream_ips)
    write_settings "$CHAIN" "$RMODE" "$UPSTREAM_IPS" "$SBMODE"
    $SINGBOX_INITD reconfigure >/dev/null 2>&1
    echo "activate: $CHAIN"
    exit 0
fi
# =================================================

# Read POST data
POST_DATA=""
ACTION=$(echo "$QUERY_STRING" | sed -n 's/.*action=\([^&]*\).*/\1/p')
if [ "$REQUEST_METHOD" = "POST" ] && [ -n "$CONTENT_LENGTH" ] && [ "$CONTENT_LENGTH" -gt 0 ] 2>/dev/null; then
    # Large binary .ipk uploads stream straight to disk instead of buffering the
    # whole package in a shell variable.
    case "$ACTION" in
        panel_update_local) head -c "$CONTENT_LENGTH" > /tmp/detour-upload.ipk ;;
        hosts_upload) head -c "$CONTENT_LENGTH" > /tmp/detour-hosts-upload ;;
        hosts_custom_save) head -c "$CONTENT_LENGTH" > /tmp/detour-hosts-custom ;;
        *) POST_DATA=$(head -c "$CONTENT_LENGTH") ;;
    esac
fi

# Clean expired sessions (>7 days)
find "$SESSION_DIR" -type f -mmin +10080 -delete 2>/dev/null
# Drop stale login-throttle records (>60 min — well past the 15-min window and the
# 30-min max lockout, both measured from the last failed attempt).
find "$LOGIN_THROTTLE_DIR" -type f -mmin +60 -delete 2>/dev/null

# ==================== SETUP STATUS (no auth) ====================
# UI loads this once on the login page. If auth is unconfigured the UI shows
# the "set username + password" form instead of the login form.
if [ "$ACTION" = "panel_setup_status" ]; then
    reply_json
    echo ""
    if [ -s "$AUTH_FILE" ]; then
        printf '{"setup_required":false}'
    else
        printf '{"setup_required":true}'
    fi
    exit 0
fi

# ==================== FIRST-INSTALL SETUP (no auth) ====================
# One-shot endpoint: writes the auth file with the operator-chosen credentials.
# Refuses if the auth file is already populated, so it can't be used to reset
# an existing install — that's what panel_change_password is for.
if [ "$ACTION" = "panel_first_setup" ]; then
    reply_json
    if [ "$REQUEST_METHOD" != "POST" ]; then
        echo ""; json_err "POST required"; exit 0
    fi
    if [ -s "$AUTH_FILE" ]; then
        sleep 1
        echo ""; json_err "panel already configured — use change-password instead"
        exit 0
    fi
    SETUP_USER=$(printf '%s' "$POST_DATA" | sed -n 's/.*"user"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)
    SETUP_PASS=$(printf '%s' "$POST_DATA" | sed -n 's/.*"password"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)
    # Username allowed chars: a-zA-Z0-9._- ; 2..32 chars (keeps auth-file format intact).
    case "$SETUP_USER" in
        ""|*[!a-zA-Z0-9._-]*) echo ""; json_err "invalid username (allowed: a-zA-Z0-9._-)"; exit 0 ;;
    esac
    if [ "${#SETUP_USER}" -lt 2 ] || [ "${#SETUP_USER}" -gt 32 ]; then
        echo ""; json_err "username must be 2..32 chars"; exit 0
    fi
    if [ -z "$SETUP_PASS" ] || [ "${#SETUP_PASS}" -lt 8 ]; then
        echo ""; json_err "password must be at least 8 chars"; exit 0
    fi
    NEW_HASH=$(printf '%s' "$SETUP_PASS" | openssl passwd -6 -stdin 2>/dev/null)
    if [ -z "$NEW_HASH" ]; then echo ""; json_err "openssl hash failed"; exit 0; fi
    TMP_AUTH=$(mktemp)
    printf '%s:%s\n' "$SETUP_USER" "$NEW_HASH" > "$TMP_AUTH"
    chmod 0600 "$TMP_AUTH"
    mv "$TMP_AUTH" "$AUTH_FILE"
    # Auto-login: hand the operator a session cookie so they don't have to
    # re-enter the credentials they literally just typed.
    TOKEN=$(gen_token)
    echo "$SETUP_USER" > "$SESSION_DIR/$TOKEN"
    echo "Set-Cookie: detour_session=$TOKEN; Path=/; HttpOnly; SameSite=Strict; Max-Age=604800"
    echo ""
    json_ok
    exit 0
fi

# ==================== LOGIN (no auth) ====================
if [ "$ACTION" = "login" ]; then
    if [ "$REQUEST_METHOD" != "POST" ]; then
        reply_json; echo ""; json_err "POST required"; exit 0
    fi
    # Brute-force throttle: while this source IP is locked out, refuse with HTTP
    # 429 WITHOUT touching the password — so a flood of guesses never reaches the
    # check and the lockout simply rides out its escalating timer.
    if ! login_check_lock; then
        echo "Status: 429 Too Many Requests"
        reply_json
        echo "Retry-After: $LOGIN_LOCK_LEFT"
        echo ""
        printf '{"ok":false,"error":"Слишком много попыток входа. Повторите через %s с.","locked":true,"retry_after":%s}' "$LOGIN_LOCK_LEFT" "$LOGIN_LOCK_LEFT"
        exit 0
    fi
    reply_json
    DECODED=$(printf '%s' "$POST_DATA" | base64 -d 2>/dev/null)
    LOGIN_USER=$(printf '%s' "$DECODED" | head -1)
    LOGIN_PASS=$(printf '%s' "$DECODED" | tail -n +2)
    if verify_password "$LOGIN_USER" "$LOGIN_PASS"; then
        login_record_success
        TOKEN=$(gen_token)
        echo "$LOGIN_USER" > "$SESSION_DIR/$TOKEN"
        echo "Set-Cookie: detour_session=$TOKEN; Path=/; HttpOnly; SameSite=Strict; Max-Age=604800"
        echo ""
        json_ok
    else
        login_record_fail
        sleep 2
        echo ""
        json_err "Invalid credentials"
    fi
    exit 0
fi

# ==================== LOGOUT (no auth) ====================
if [ "$ACTION" = "logout" ]; then
    reply_json
    echo "Set-Cookie: detour_session=deleted; Path=/; HttpOnly; Max-Age=0"
    TOKEN=$(get_session_token)
    [ -n "$TOKEN" ] && rm -f "$SESSION_DIR/$TOKEN" 2>/dev/null
    echo ""
    json_ok
    exit 0
fi

